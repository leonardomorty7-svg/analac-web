{
  "name": "analac-web",
  "version": "0.0.1",
  "private": true,
  "description": "Monorepo para el rediseño completo del sitio web de ANALAC",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@analac/web",
    "dev:portal": "turbo run dev --filter=@analac/portal",
    "dev:cms": "turbo run dev --filter=@analac/cms",
    "dev:api": "turbo run dev --filter=@analac/api",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,astro,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,astro,md,json}\"",
    "db:generate": "turbo run db:generate --filter=@analac/api",
    "db:migrate": "turbo run db:migrate --filter=@analac/api",
    "db:studio": "turbo run db:studio --filter=@analac/api"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "prettier": "^3.4.2",
    "prettier-plugin-astro": "^0.14.1",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "eslint": "^9.17.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
