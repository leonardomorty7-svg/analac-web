---
// src/components/AliadosSection.astro

// Logos verificados — rutas corregidas por subdirectorio real
const aliados = [
  // Tier 1
  { file: 'tier-1/solla.webp',       nombre: 'Solla' },
  { file: 'tier-1/grupo-bios.webp',  nombre: 'Grupo Bios' },
  { file: 'tier-1/carval.webp',      nombre: 'Carval' },
  // Tier 2
  { file: 'tier-2/delaval.webp',     nombre: 'DeLaval' },
  { file: 'tier-2/saenz-fety.webp',  nombre: 'Sáenz Fety' },
  // Tier 3
  { file: 'tier-3/biogenesis.webp',  nombre: 'Biogénesis Bagó' },
  { file: 'tier-3/ganasal.webp',     nombre: 'Ganasal' },
  { file: 'tier-3/genetica-selecta.webp', nombre: 'Genética Selecta' },
  { file: 'tier-3/lares.webp',       nombre: 'LaRes' },
  { file: 'tier-3/noga.webp',        nombre: 'Noga' },
  { file: 'tier-3/nutrimixes.webp',  nombre: 'Nutrimixes' },
  { file: 'tier-3/nutryr.webp',      nombre: 'Nutryr' },
  { file: 'tier-3/ourofino.webp',    nombre: 'Ourofino' },
  { file: 'tier-3/partner.webp',     nombre: 'Edairy Partners' },
  { file: 'tier-3/semex.webp',       nombre: 'Semex' },
  { file: 'tier-3/silveragro.webp',  nombre: 'Silveragro' },
];
---

<section class="aliados-section fade-up">
  <div class="aliados-header">
    <span class="overline reveal" style="transition-delay: 0ms">RED DE ALIADOS ESTRATÉGICOS</span>
    <h2 class="aliados-title reveal" style="transition-delay: 150ms">Organizaciones e instituciones que respaldan <br class="break-desktop" />el sector lácteo colombiano</h2>
    <p class="aliados-p reveal" style="transition-delay: 280ms">Aportan conocimiento, soluciones y respaldo al fortalecimiento del ecosistema lácteo nacional.</p>
  </div>

  <!-- Carrusel infinito premium -->
  <div class="marquee-container reveal" style="transition-delay: 400ms">
    <div class="marquee-track" id="aliados-track">
      <!-- Set A (visible) -->
      {aliados.map((aliado) => (
        <div class="aliado-logo-wrapper">
          <img
            src={`/images/aliados/${aliado.file}`}
            alt={`Logo ${aliado.nombre}`}
            class="aliado-logo"
            loading="lazy"
            title={aliado.nombre}
          />
        </div>
      ))}
      <!-- Set B (espejo — hace el loop invisible) -->
      {aliados.map((aliado) => (
        <div class="aliado-logo-wrapper" aria-hidden="true">
          <img
            src={`/images/aliados/${aliado.file}`}
            alt=""
            class="aliado-logo"
            loading="lazy"
          />
        </div>
      ))}
    </div>
  </div>

  <div class="aliados-actions reveal" style="transition-delay: 600ms">
    <a href="/asociados-aliados" class="btn-primary">Conoce nuestra red de aliados</a>
  </div>
</section>

<style>
  /* ── Sección ── */
  .aliados-section {
    background: #ffffff;
    padding: 120px 0 100px;
    display: flex;
    flex-direction: column;
    align-items: center;
    overflow: hidden;
  }

  /* Ampliar el contenedor para que la primera línea del título
     quepa sin romperse antes del <br class="break-desktop"> */
  .aliados-header {
    text-align: center;
    max-width: 1100px;
    margin: 0 auto 72px;
    padding: 0 5vw;
  }

  .overline {
    font-size: 11px;
    color: #6db56d;
    letter-spacing: 0.12em;
    font-weight: 600;
    margin-bottom: 24px;
    display: inline-block;
  }

  .aliados-title {
    font-size: clamp(28px, 4vw, 40px);
    color: #060f07;
    line-height: 1.15;
    font-weight: 400;
    letter-spacing: -0.02em;
    margin-bottom: 24px;
    text-wrap: balance;
  }

  .break-desktop { display: none; }
  @media (min-width: 769px) {
    .break-desktop { display: inline; }
  }

  .aliados-p {
    font-size: 19px;
    color: rgba(6, 15, 7, 0.6);
    line-height: 1.6;
  }

  /* ── Contenedor del carrusel ──
     Máscara lateral para efecto de fade suave en los bordes */
  .marquee-container {
    width: 100vw;
    overflow: hidden;
    margin-bottom: 72px;
    /* Máscara: desvanece un 6% en cada extremo */
    -webkit-mask-image: linear-gradient(
      90deg,
      transparent 0%,
      #000 6%,
      #000 94%,
      transparent 100%
    );
    mask-image: linear-gradient(
      90deg,
      transparent 0%,
      #000 6%,
      #000 94%,
      transparent 100%
    );
  }

  /* ── Track: animación CSS pura, sin JS ──
     translateX(-50%) mueve exactamente el set A completo,
     loopando de forma imperceptible al set B (idéntico). */
  .marquee-track {
    display: flex;
    width: max-content;
    align-items: center;
    gap: 48px;
    padding: 16px 0;
    animation: marquee-scroll 50s linear infinite;
    will-change: transform;
  }

  /* Pausa suave al hover — el browser retiene la posición actual */
  .marquee-container:hover .marquee-track {
    animation-play-state: paused;
  }

  @keyframes marquee-scroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* ── Wrapper individual de cada logo ── */
  .aliado-logo-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 148px;
    height: 80px;
    padding: 14px 18px;
    cursor: pointer;
    /* Transición al escalar */
    transition: transform 0.3s ease;
  }

  .aliado-logo-wrapper:hover {
    transform: scale(1.07);
  }

  /* ── Logos: grises por defecto, color en hover ── */
  .aliado-logo {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    filter: grayscale(100%) opacity(0.45);
    transition: filter 0.3s ease;
    /* Evitar que el filtro herede la transformación del wrapper
       y genere un doble-scale involuntario */
    will-change: filter;
  }

  .aliado-logo-wrapper:hover .aliado-logo {
    filter: grayscale(0%) opacity(1);
  }

  /* ── Botón ── */
  .aliados-actions {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
    padding: 0 5vw;
  }

  .btn-primary {
    display: inline-block;
    background: #6db56d;
    color: #ffffff;
    padding: 14px 32px;
    border-radius: 100px;
    text-decoration: none;
    font-size: 15px;
    font-weight: 500;
    white-space: nowrap;
    transition: background 0.25s ease, transform 0.25s ease, box-shadow 0.25s ease;
    box-shadow: 0 4px 16px rgba(109,181,109,0.2);
  }
  .btn-primary:hover {
    background: #5aa35a;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(109,181,109,0.3);
  }

  /* ── Reveal animation ── */
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .aliados-section {
      padding: 64px 0 80px;
    }
    .aliados-header {
      margin-bottom: 48px;
    }
    .marquee-container {
      margin-bottom: 56px;
      /* Máscara más estrecha en mobile */
      -webkit-mask-image: linear-gradient(
        90deg,
        transparent 0%,
        #000 4%,
        #000 96%,
        transparent 100%
      );
      mask-image: linear-gradient(
        90deg,
        transparent 0%,
        #000 4%,
        #000 96%,
        transparent 100%
      );
    }
    .marquee-track {
      gap: 32px;
      /* Un poco más rápido en mobile sin saturar la vista */
      animation-duration: 38s;
    }
    .aliado-logo-wrapper {
      width: 120px;
      height: 68px;
      padding: 10px 14px;
    }
    .aliados-actions {
      width: 100%;
    }
    .btn-primary {
      width: 100%;
      text-align: center;
    }
  }
</style>

<script>
  const observer = new IntersectionObserver((entries, obs) => {
    entries.forEach(el => {
      if (el.isIntersecting) {
        el.target.classList.add('visible');
        obs.unobserve(el.target);
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.aliados-section .reveal').forEach(el => observer.observe(el));
</script>
