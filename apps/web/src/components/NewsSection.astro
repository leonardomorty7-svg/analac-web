---
// src/components/NewsSection.astro
---
<section class="news section-full">
  <div class="news-wrap">
    <header class="news-header">
      <div>
        <span class="overline">Actualidad</span>
        <h2 class="news-h2">Noticias del sector lácteo</h2>
      </div>
      <a href="/noticias" class="news-all">
        Ver todas las noticias →
      </a>
    </header>
    <div class="news-track">
      <article class="ncard ncard--featured">
        <img src="/images/news-1.jpg" alt="Noticia 1" 
             class="ncard-bg" />
        <div class="ncard-overlay"></div>
        <div class="ncard-content">
          <span class="ncard-tag">Análisis · Dic 2024</span>
          <h3 class="ncard-title">
            Cadena láctea en 2024: equipo y cercanía al consumidor
          </h3>
          <p class="ncard-excerpt">
            La cadena láctea colombiana enfrenta retos estructurales 
            que requieren adaptación e innovación.
          </p>
          <span class="ncard-meta">4 min · ANALAC</span>
        </div>
      </article>
      <article class="ncard">
        <img src="/images/news-2.jpg" alt="Noticia 2" 
             class="ncard-bg" />
        <div class="ncard-overlay"></div>
        <div class="ncard-content">
          <span class="ncard-tag">Mercados · Nov 2024</span>
          <h3 class="ncard-title">
            Costos de producción: Colombia vs. el mundo
          </h3>
          <span class="ncard-meta">6 min · ANALAC</span>
        </div>
      </article>
      <article class="ncard">
        <img src="/images/news-3.jpg" alt="Noticia 3" 
             class="ncard-bg" />
        <div class="ncard-overlay"></div>
        <div class="ncard-content">
          <span class="ncard-tag">Clima · Oct 2024</span>
          <h3 class="ncard-title">
            Preparación para la temporada del Fenómeno del Niño
          </h3>
          <span class="ncard-meta">5 min · ANALAC</span>
        </div>
      </article>
      <article class="ncard">
        <img src="/images/hero-bg.jpg" alt="Noticia 4" 
             class="ncard-bg" />
        <div class="ncard-overlay"></div>
        <div class="ncard-content">
          <span class="ncard-tag">Política · Sep 2024</span>
          <h3 class="ncard-title">
            Nuevas regulaciones para el sector lácteo colombiano
          </h3>
          <span class="ncard-meta">7 min · ANALAC</span>
        </div>
      </article>
      <article class="ncard">
        <img src="/images/afiliados-bg.jpg" alt="Noticia 5" 
             class="ncard-bg" />
        <div class="ncard-overlay"></div>
        <div class="ncard-content">
          <span class="ncard-tag">Exportaciones · Ago 2024</span>
          <h3 class="ncard-title">
            Colombia aumenta exportaciones de lácteos un 12%
          </h3>
          <span class="ncard-meta">3 min · ANALAC</span>
        </div>
      </article>
    </div>
    <div class="news-dots" id="newsDots">
      <button class="ndot active" data-index="0"></button>
      <button class="ndot" data-index="1"></button>
      <button class="ndot" data-index="2"></button>
      <button class="ndot" data-index="3"></button>
      <button class="ndot" data-index="4"></button>
    </div>
  </div>
</section>

<style>
.news {
  background: #0a1a0c;
  display: flex;
  align-items: center;
  overflow: hidden;
}

.news-wrap {
  width: 100%;
  padding: 48px 0 40px;
  display: flex;
  flex-direction: column;
}

.news-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  padding: 0 48px 32px;
  flex-shrink: 0;
}

.news-h2 {
  font-size: clamp(28px, 3vw, 40px);
  font-weight: 400;
  color: #fff;
  letter-spacing: -0.02em;
  line-height: 1;
  margin-top: 6px;
}

.news-header .overline {
  color: #6db56d;
}

.news-all {
  font-size: 13px;
  color: rgba(255,255,255,0.55);
  text-decoration: none;
  border-bottom: 1px solid rgba(255,255,255,0.2);
  padding-bottom: 2px;
  white-space: nowrap;
  transition: color 0.2s ease;
}
.news-all:hover { color: #fff; }

.news-track {
  display: flex;
  gap: 12px;
  padding: 0 48px 16px;
  overflow-x: scroll;
  scroll-snap-type: x mandatory;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  cursor: grab;
  flex: 1;
  align-items: stretch;
}
.news-track::-webkit-scrollbar { display: none; }
.news-track:active { cursor: grabbing; }

.ncard {
  position: relative;
  min-width: 260px;
  width: 260px;
  height: 420px;
  border-radius: 16px;
  overflow: hidden;
  scroll-snap-align: start;
  flex-shrink: 0;
  cursor: pointer;
  transition: transform 0.3s ease;
}
.ncard:hover { transform: scale(1.02); }

.ncard--featured {
  min-width: 400px;
  width: 400px;
}

.ncard-bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.5s ease;
}
.ncard:hover .ncard-bg { transform: scale(1.06); }

.ncard-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to top,
    rgba(6, 15, 7, 0.92) 0%,
    rgba(6, 15, 7, 0.4) 50%,
    rgba(6, 15, 7, 0.1) 100%
  );
}

.ncard-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24px 20px;
  z-index: 1;
}

.ncard-tag {
  font-size: 10px;
  color: #6db56d;
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  display: block;
  margin-bottom: 8px;
}

.ncard-title {
  font-size: 16px;
  font-weight: 500;
  color: #fff;
  line-height: 1.35;
  letter-spacing: -0.01em;
  margin-bottom: 10px;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.ncard--featured .ncard-title {
  font-size: 20px;
}

.ncard-excerpt {
  font-size: 13px;
  color: rgba(255,255,255,0.65);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 10px;
}

.ncard-meta {
  font-size: 11px;
  color: rgba(255,255,255,0.4);
  display: block;
}

.news-dots {
  display: flex;
  justify-content: center;
  gap: 8px;
  padding-top: 24px;
  flex-shrink: 0;
}

.ndot {
  width: 6px;
  height: 6px;
  border-radius: 3px;
  background: rgba(255,255,255,0.2);
  border: none;
  cursor: pointer;
  transition: all 0.3s ease;
  padding: 0;
}
.ndot.active {
  width: 24px;
  background: #6db56d;
}

@media (max-width: 768px) {
  .news-header { padding: 0 24px 24px; }
  .news-track { padding: 0 24px; gap: 10px; }
  .ncard { min-width: 260px; height: 340px; }
  .ncard--featured { min-width: 300px; }
}
</style>

<script>
  const track = document.querySelector(
    '.news-track') as HTMLElement | null;
  const dots = document.querySelectorAll('.ndot');

  if (track) {
    let isDown = false;
    let startX = 0;
    let scrollLeft = 0;

    track.addEventListener('mousedown', (e) => {
      isDown = true;
      track.style.cursor = 'grabbing';
      startX = e.pageX - track.offsetLeft;
      scrollLeft = track.scrollLeft;
    });
    track.addEventListener('mouseleave', () => {
      isDown = false;
      track.style.cursor = 'grab';
    });
    track.addEventListener('mouseup', () => {
      isDown = false;
      track.style.cursor = 'grab';
    });
    track.addEventListener('mousemove', (e) => {
      if (!isDown) return;
      e.preventDefault();
      const x = e.pageX - track.offsetLeft;
      const walk = (x - startX) * 1.5;
      track.scrollLeft = scrollLeft - walk;
    });

    track.addEventListener('scroll', () => {
      const cardWidth = 260 + 12;
      const index = Math.round(track.scrollLeft / cardWidth);
      const clamped = Math.min(index, dots.length - 1);
      dots.forEach((d, i) => {
        d.classList.toggle('active', i === clamped);
      });
    });

    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => {
        track.scrollTo({
          left: i * (260 + 12),
          behavior: 'smooth'
        });
      });
    });
  }
</script>
