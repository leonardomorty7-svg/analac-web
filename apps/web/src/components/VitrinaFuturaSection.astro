---
// src/components/VitrinaFuturaSection.astro

const features = [
  { 
    icono: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#6db56d" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="m7.5 4.27 9 5.15"/><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>`, 
    titulo: "Productos y soluciones", 
    desc: "Encuentra insumos, equipos, genética, nutrición y tecnología para fortalecer tu operación." 
  },
  { 
    icono: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#6db56d" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3.85 8.62a4 4 0 0 1 4.78-4.77 4 4 0 0 1 6.74 0 4 4 0 0 1 4.78 4.78 4 4 0 0 1 0 6.74 4 4 0 0 1-4.77 4.78 4 4 0 0 1-6.75 0 4 4 0 0 1-4.78-4.77 4 4 0 0 1 0-6.76Z"/><path d="m9 12 2 2 4-4"/></svg>`, 
    titulo: "Empresas verificadas", 
    desc: "Conecta con organizaciones y proveedores que hacen parte del ecosistema ANALAC." 
  },
  { 
    icono: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#6db56d" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/><line x1="11" x2="11" y1="8" y2="14"/><line x1="8" x2="14" y1="11" y2="11"/></svg>`, 
    titulo: "Búsqueda inteligente", 
    desc: "Filtra por categoría, especialidad, región o tipo de solución." 
  },
  { 
    icono: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#6db56d" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>`, 
    titulo: "Mayor visibilidad", 
    desc: "Impulsa tu empresa dentro de la red más importante del sector lácteo colombiano." 
  },
];
---

<section class="vitrina-section">
  <div class="vitrina-header reveal" style="transition-delay: 0ms">
    <div style="display: flex; align-items: center; justify-content: center; gap: 12px; margin-bottom: 24px;">
      <span class="overline">VITRINA DIGITAL ANALAC</span>
    </div>
    <h2 class="vitrina-h2">Conecta con proveedores, productos y servicios del sector lácteo colombiano</h2>
    <p class="vitrina-p">Explora empresas, soluciones, tecnología, genética, nutrición, equipos, servicios especializados y aliados estratégicos que impulsan el crecimiento del ecosistema lácteo nacional.</p>
  </div>

  <div class="vitrina-grid">
    {features.map((feat, idx) => (
      <div class="feature-card reveal" style={`transition-delay: ${(idx + 1) * 150}ms`}>
        <div class="feat-icon" set:html={feat.icono} />
        <h3 class="feat-title">{feat.titulo}</h3>
        <p class="feat-desc">{feat.desc}</p>
      </div>
    ))}
  </div>

  <div class="vitrina-actions reveal" style="transition-delay: 800ms">
    <a href="/vitrina" class="btn-primary">Explorar vitrina digital →</a>
    <a href="/contacto" class="btn-secondary">Publicar mi empresa →</a>
  </div>
</section>

<style>
  .vitrina-section {
    position: relative;
    min-height: 60vh;
    padding: 120px 5vw;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 80px;
    background-color: #040a05;
    overflow: hidden;
  }

  /* Abstract glow and grid to simulate digital ecosystem */
  .vitrina-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 50% 20%, rgba(109, 181, 109, 0.12), transparent 50%),
                radial-gradient(circle at 80% 80%, rgba(109, 181, 109, 0.08), transparent 40%);
    z-index: 1;
  }

  .vitrina-section::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
                      linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse at center, black 10%, transparent 80%);
    -webkit-mask-image: radial-gradient(ellipse at center, black 10%, transparent 80%);
    z-index: 1;
  }

  .vitrina-header, .vitrina-grid, .vitrina-actions {
    position: relative;
    z-index: 2;
  }

  .vitrina-header {
    text-align: center;
    max-width: 1100px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .overline {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #6db56d;
    font-weight: 600;
  }

  .badge-soon {
    background: rgba(109,181,109,0.15);
    color: #6db56d;
    border: 1px solid rgba(109,181,109,0.3);
    border-radius: 100px;
    padding: 6px 16px;
    font-size: 12px;
    letter-spacing: 0.08em;
    font-weight: 500;
  }

  .vitrina-h2 {
    font-size: clamp(32px, 4vw, 48px);
    font-weight: 400;
    color: #ffffff;
    line-height: 1.15;
    margin: 0 0 20px;
    letter-spacing: -0.02em;
    max-width: 980px;
    text-wrap: balance;
  }

  .vitrina-p {
    font-size: 19px;
    color: rgba(255,255,255,0.75);
    line-height: 1.6;
    margin: 0;
    max-width: 820px;
    text-wrap: balance;
  }

  .vitrina-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
    width: 100%;
    max-width: 1200px;
  }

  .feature-card {
    background: transparent;
    border: none;
    border-left: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 0;
    padding: 0 0 0 32px;
    text-align: left;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    height: 100%;
    transition: transform 0.35s ease, border-color 0.35s ease;
  }
  
  .feature-card:hover {
    transform: translateX(4px);
    border-color: rgba(109, 181, 109, 0.5);
  }

  .feat-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
    color: #6db56d;
    background: rgba(109, 181, 109, 0.1);
    width: 56px;
    height: 56px;
    border-radius: 12px;
    border: 1px solid rgba(109, 181, 109, 0.15);
    transition: transform 0.3s ease, filter 0.3s ease, background 0.3s ease;
  }
  .feature-card:hover .feat-icon {
    transform: scale(1.05);
    background: rgba(109, 181, 109, 0.15);
    filter: drop-shadow(0 4px 16px rgba(109,181,109,0.25));
  }

  .feat-title {
    font-size: 18px;
    font-weight: 600;
    color: #ffffff;
    margin: 0 0 16px;
  }

  .feat-desc {
    font-size: 19px;
    color: rgba(255,255,255,0.65);
    line-height: 1.6;
    margin: 0;
  }

  .vitrina-actions {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 16px;
  }

  .btn-primary {
    background: #6db56d;
    color: #fff;
    border: none;
    padding: 14px 32px;
    border-radius: 100px;
    font-size: 15px;
    font-weight: 500;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.3s ease;
  }
  .btn-primary:hover {
    background: #5aa35a;
  }

  .btn-secondary {
    background: transparent;
    color: #060f07;
    border: 1px solid rgba(6,15,7,0.2);
    padding: 14px 32px;
    border-radius: 100px;
    font-size: 15px;
    font-weight: 500;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.3s ease;
  }
  .btn-secondary:hover {
    border-color: rgba(6,15,7,0.8);
  }

  .reveal {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 992px) {
    .vitrina-grid {
      grid-template-columns: repeat(2, 1fr);
      row-gap: 56px;
    }
  }
  @media (max-width: 768px) {
    .vitrina-grid {
      grid-template-columns: 1fr;
    }
    .vitrina-section {
      padding: 80px 24px;
    }
    .feature-card {
      border-left: none;
      border-top: 1px solid rgba(255, 255, 255, 0.08);
      padding: 32px 0 0 0;
    }
    .feature-card:hover {
      transform: translateY(4px);
      border-color: rgba(109, 181, 109, 0.5);
    }
  }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(el => {
      if (el.isIntersecting) {
        el.target.classList.add('visible');
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.vitrina-section .reveal').forEach(el => observer.observe(el));
</script>
