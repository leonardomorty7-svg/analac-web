---
// src/components/HazteAfiliadoSection.astro
---

<section class="hazte-hero">

  <!-- Fondo con crossfade idéntico al Hero principal -->
  <div class="hazte-bg">
    <img src="/images/afiliados-bg.jpg"        alt="Productores lecheros colombianos"      class="hazte-img hazte-img-1" />
    <img src="/images/colombia-dairy-bg-v2.jpg" alt="Ganadería sostenible en Colombia"     class="hazte-img hazte-img-2" />
    <img src="/images/colombia-dairy-bg.jpg"    alt="Campo lácteo colombiano al amanecer"  class="hazte-img hazte-img-3" />
    <div class="hazte-overlay"></div>
  </div>

  <!-- Contenido central fijo -->
  <div class="hazte-content">
    <p class="hazte-overline">HAZTE AFILIADO</p>

    <h2 class="hazte-title">
      <span class="nowrap-desktop">Vincúlese al gremio que lidera</span> <br class="break-desktop" />
      <span class="nowrap-desktop">el desarrollo lechero nacional</span>
    </h2>

    <p class="hazte-desc">
      <span class="nowrap-desktop">En ANALAC trabajamos junto a productores y aliados estratégicos</span> <br class="break-desktop" />
      <span class="nowrap-desktop">garantizando la defensa, la competitividad y el futuro de la lechería en Colombia.</span>
    </p>

    <div class="hazte-actions">
      <a href="/afiliate"  class="btn btn--accent-hazte">Iniciar proceso de afiliación →</a>
      <a href="/contacto" class="btn btn--outline-hazte">Solicitar información</a>
    </div>
  </div>

</section>

<style>
  /* ── Sección ── */
  .hazte-hero {
    position: relative;
    height: 100vh;
    min-height: 640px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  /* ── Fondo ── */
  .hazte-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    background-color: #040a05;
  }

  /* Imágenes con crossfade + kenburns idénticos al Hero */
  .hazte-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    opacity: 0;
    will-change: opacity, transform;
    animation:
      hazte-crossfade 28.5s infinite linear,
      hazte-kenburns  28.5s infinite linear;
  }

  /* Delays idénticos al Hero: 3 imágenes, ciclo de 28.5s, offset de 9.5s cada una */
  .hazte-img-1 { animation-delay:   0s,    0s; }
  .hazte-img-2 { animation-delay: -19s,  -19s; }
  .hazte-img-3 { animation-delay: -9.5s, -9.5s; }

  @keyframes hazte-crossfade {
    0%      { opacity: 1; }
    24.56%  { opacity: 1; }
    33.33%  { opacity: 0; }
    91.22%  { opacity: 0; }
    100%    { opacity: 1; }
  }

  @keyframes hazte-kenburns {
    0%      { transform: scale(1.0104); }
    33.33%  { transform: scale(1.05);   }
    34%     { transform: scale(1.0);    }
    91.22%  { transform: scale(1.0);    }
    100%    { transform: scale(1.0104); }
  }

  /* Overlay con degradado institucional oscuro */
  .hazte-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(4, 10, 5, 0.70) 0%,
      rgba(4, 10, 5, 0.50) 40%,
      rgba(4, 10, 5, 0.65) 100%
    );
    z-index: 1;
  }

  /* ── Contenido centrado ── */
  .hazte-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    width: 100%;
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 40px;
  }

  /* Etiqueta superior */
  .hazte-overline {
    font-size: 12px;
    letter-spacing: 0.15em;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.75);
    text-transform: uppercase;
    margin-bottom: 24px;
  }

  /* Título — mismo peso visual que el Hero (font-weight 300) */
  .hazte-title {
    font-size: clamp(32px, 4.5vw, 62px);
    font-weight: 300;
    color: #ffffff;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin-bottom: 28px;
    max-width: 1100px;
    width: 100%;
    margin-left: auto;
    margin-right: auto;
  }

  /* Párrafo descriptivo */
  .hazte-desc {
    font-size: clamp(16px, 1.5vw, 19px);
    color: rgba(255, 255, 255, 0.68);
    line-height: 1.7;
    margin-bottom: 44px;
    max-width: 800px;
  }

  /* Control de salto de línea (solo Desktop) */
  .break-desktop  { display: none; }
  .nowrap-desktop { white-space: normal; }
  @media (min-width: 769px) {
    .break-desktop  { display: inline; }
    .nowrap-desktop { white-space: nowrap; }
  }

  /* ── Botones ── */
  .hazte-actions {
    display: flex;
    justify-content: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  /* Botón primario — verde institucional */
  .btn--accent-hazte {
    display: inline-flex;
    align-items: center;
    background: #6db56d;
    color: #ffffff;
    padding: 14px 32px;
    border-radius: 100px;
    text-decoration: none;
    font-size: 15px;
    font-weight: 500;
    white-space: nowrap;
    transition: background 0.25s ease, transform 0.25s ease, box-shadow 0.25s ease;
    box-shadow: 0 4px 16px rgba(109, 181, 109, 0.25);
  }
  .btn--accent-hazte:hover {
    background: #5aa35a;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(109, 181, 109, 0.35);
  }

  /* Botón secundario — contorno blanco */
  .btn--outline-hazte {
    display: inline-flex;
    align-items: center;
    background: transparent;
    color: #ffffff;
    padding: 14px 32px;
    border-radius: 100px;
    text-decoration: none;
    font-size: 15px;
    font-weight: 500;
    white-space: nowrap;
    border: 1px solid rgba(255, 255, 255, 0.45);
    transition: background 0.25s ease, border-color 0.25s ease, transform 0.25s ease;
  }
  .btn--outline-hazte:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.75);
    transform: translateY(-2px);
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .hazte-hero {
      padding: 100px 24px 64px;
    }
    .hazte-content {
      padding: 0;
    }
    .hazte-title {
      font-size: clamp(28px, 8vw, 40px);
    }
    .hazte-desc {
      font-size: 16px;
    }
    .hazte-actions {
      flex-direction: column;
      width: 100%;
    }
    .btn--accent-hazte,
    .btn--outline-hazte {
      width: 100%;
      justify-content: center;
      text-align: center;
    }
  }
</style>
