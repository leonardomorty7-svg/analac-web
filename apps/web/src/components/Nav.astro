---
// src/components/Nav.astro
---
<nav class="nav" id="main-nav">
  <div class="nav-container">
    <a href="/" class="nav-logo"><img src="/images/logo-white.svg" alt="ANALAC" class="nav-logo-img" /></a>
    
    <div class="nav-links">
      <a href="/">Inicio</a>
      <a href="/quienes-somos">Quiénes somos</a>
      <a href="/asociados-y-aliados">La Red</a>
      <a href="/informacion-sectorial">Observatorio</a>
      <a href="/noticias">Conocimiento</a>
    </div>

    <div class="nav-actions">
      <div class="nav-cta">
        <a href="/portal" class="nav-btn-discreet">Portal</a>
        <a href="/afiliate" class="nav-btn">Hazte afiliado</a>
      </div>

      <button class="nav-hamburger" id="nav-toggle" aria-label="Menu" aria-expanded="false" aria-controls="mobile-menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</nav>

<!-- MENÚ FULLSCREEN EDITORIAL Y PREMIUM -->
<div class="mobile-menu" id="mobile-menu" role="navigation" aria-modal="true" aria-label="Menú principal ampliado">
  
  <div class="mobile-menu-header container fade-in-up">
    <div class="mobile-menu-brand">
      <img src="/images/logo-white.svg" alt="ANALAC" class="mobile-logo-img" />
    </div>
    <div class="mobile-menu-actions">
      <a href="/portal" class="nav-btn-discreet">Portal</a>
      <a href="/afiliate" class="nav-btn">Hazte afiliado</a>
      <button class="nav-hamburger is-active" id="nav-close" aria-label="Cerrar menú">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <div class="mobile-menu-inner container">
    
    <!-- Franja Superior: Main y Redes Sociales -->
    <div class="menu-top-row fade-in-up" style="animation-delay: 0.05s;">
      <div class="menu-main-nav">
        <a href="/" class="main-link">
          <span class="main-link-title">Inicio</span>
        </a>
        <a href="/quienes-somos" class="main-link">
          <span class="main-link-title">Quiénes somos</span>
        </a>
      </div>
      
      <div class="social-links-row">
        <span class="social-title">Comunidad</span>
        <div class="social-icons">
          <a href="https://facebook.com/analac" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="social-link mock-link">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
          </a>
          <a href="https://twitter.com/analac" target="_blank" rel="noopener noreferrer" aria-label="X (Twitter)" class="social-link mock-link">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4l11.733 16h4.267l-11.733 -16z"></path><path d="M4 20l6.768 -6.768m2.46 -2.46l6.772 -6.772"></path></svg>
          </a>
          <a href="https://instagram.com/analac" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="social-link mock-link">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
          </a>
          <a href="https://youtube.com/analac" target="_blank" rel="noopener noreferrer" aria-label="YouTube" class="social-link mock-link">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"></path><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"></polygon></svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Franja Central: La Red (Destacada Premium) -->
    <div class="menu-network fade-in-up" style="animation-delay: 0.1s;">
      <div class="network-header">
        <h2 class="network-title">La Red</h2>
        <p class="network-desc">Encuentra, comprende, conecta y participa en el ecosistema lácteo.</p>
      </div>
      
      <div class="network-access-grid">
        <a href="/asociados-y-aliados/directorio" class="net-link">
          <div class="net-link-icon-wrapper">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7"></path></svg>
          </div>
          <div class="net-link-content">
            <span class="net-link-title">Directorio de Organizaciones</span>
            <span class="net-link-desc">Actores, empresas e instituciones del ecosistema.</span>
          </div>
        </a>
        <a href="/informacion-sectorial" class="net-link">
          <div class="net-link-icon-wrapper">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 20V10M12 20V4M6 20v-6"></path></svg>
          </div>
          <div class="net-link-content">
            <span class="net-link-title">Observatorio</span>
            <span class="net-link-desc">Datos, indicadores e información sectorial.</span>
          </div>
        </a>
        <a href="/noticias" class="net-link">
          <div class="net-link-icon-wrapper">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg>
          </div>
          <div class="net-link-content">
            <span class="net-link-title">Conocimiento</span>
            <span class="net-link-desc">Actualidad, ciencia, recursos y memorias.</span>
          </div>
        </a>
        <a href="/beneficios" class="net-link mock-link">
          <div class="net-link-icon-wrapper">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
          </div>
          <div class="net-link-content">
            <span class="net-link-title">Beneficios</span>
            <span class="net-link-desc">Servicios disponibles para asociados.</span>
          </div>
        </a>
      </div>
      <div class="network-footer">
        Próximamente: Soluciones y Vitrina · Profesionales · Oportunidades
      </div>
    </div>

    <!-- Franja Inferior: Accesos complementarios y Legal -->
    <div class="menu-bottom-row fade-in-up" style="animation-delay: 0.15s;">
      
      <div class="comp-links-row">
        <a href="/portal" class="comp-link-simple">Portal</a>
        <a href="/academia" class="comp-link-simple mock-link">Academia</a>
        <a href="/ayuda" class="comp-link-simple">Mesa de ayuda</a>
        <a href="/contacto" class="comp-link-simple">Contacto</a>
      </div>

      <div class="menu-legal">
        <a href="/quienes-somos/transparencia-y-gobierno">Transparencia</a>
        <a href="/politica-de-privacidad" class="mock-link">Privacidad</a>
        <a href="/tratamiento-de-datos-personales" class="mock-link">Tratamiento de datos</a>
        <a href="/politica-de-cookies" class="mock-link">Cookies</a>
        <a href="/terminos-y-condiciones" class="mock-link">Términos</a>
        <a href="/accesibilidad" class="mock-link">Accesibilidad</a>
        <a href="/mapa-del-sitio">Mapa del sitio</a>
      </div>

    </div>

  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const toggle = document.getElementById('nav-toggle');
    const closeBtn = document.getElementById('nav-close');
    const menu = document.getElementById('mobile-menu');
    const nav = document.getElementById('main-nav');
    const links = menu?.querySelectorAll('a');
    let isOpen = false;

    const toggleExternalWidgets = (hide: boolean) => {
      const pse = document.getElementById('payment-pill');
      const wa = document.querySelector('.wa-float');
      if (pse) pse.style.display = hide ? 'none' : 'flex';
      if (wa) (wa as HTMLElement).style.display = hide ? 'none' : 'flex';
    };

    const openMenu = () => {
      isOpen = true;
      toggle?.setAttribute('aria-expanded', 'true');
      menu?.classList.add('is-open');
      nav?.classList.add('menu-open');
      document.body.style.overflow = 'hidden';
      toggleExternalWidgets(true);
      
      setTimeout(() => {
        const firstLink = menu?.querySelector('a');
        if(firstLink) (firstLink as HTMLElement).focus();
      }, 300);
    };

    const closeMenu = () => {
      isOpen = false;
      toggle?.setAttribute('aria-expanded', 'false');
      menu?.classList.remove('is-open');
      nav?.classList.remove('menu-open');
      if (window.scrollY < 50) nav?.classList.remove('scrolled');
      document.body.style.overflow = '';
      toggleExternalWidgets(false);
    };

    toggle?.addEventListener('click', () => isOpen ? closeMenu() : openMenu());
    closeBtn?.addEventListener('click', closeMenu);

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen) {
        closeMenu();
        toggle?.focus();
      }
    });

    links?.forEach(link => {
      link.addEventListener('click', () => {
        if (!link.classList.contains('mock-link') && isOpen) closeMenu();
      });
    });

    menu?.addEventListener('click', (e) => {
      if(e.target === menu) closeMenu();
    });

    window.addEventListener('scroll', () => {
      if (window.scrollY > 50 || isOpen) {
        nav?.classList.add('scrolled');
      } else {
        nav?.classList.remove('scrolled');
      }
    });
  });
</script>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 104px;
    z-index: 1000;
    background: linear-gradient(to bottom, rgba(6, 15, 7, 0.85) 0%, transparent 100%);
    transition: all 0.3s ease;
  }

  .nav.scrolled {
    background: rgba(6, 15, 7, 0.95);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  
  .nav.menu-open {
    background: transparent;
    border-bottom: none;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    pointer-events: none;
  }

  .nav-container {
    display: flex;
    align-items: center;
    max-width: 1440px;
    margin: 0 auto;
    height: 100%;
    padding: 0 40px;
    pointer-events: all;
  }

  .nav.menu-open .nav-container {
    opacity: 0;
  }

  .nav-logo { flex-shrink: 0; }
  .nav-logo-img { height: 80px; width: auto; display: block; transition: height 0.3s ease; }

  .nav-links {
    display: flex;
    gap: 24px;
    margin-left: 48px;
  }

  .nav-links a {
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    white-space: nowrap;
    transition: color 0.2s ease;
    padding: 8px 0;
  }

  .nav-links a:hover { color: #fff; }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-left: auto;
  }

  .nav-cta { display: flex; align-items: center; gap: 12px; }

  .nav-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 100px;
    background: #6db56d;
    border: none;
    color: #fff !important;
    padding: 8px 20px;
    font-size: 13px;
    font-weight: 500;
    text-decoration: none;
    transition: background-color 0.2s ease;
  }
  .nav-btn:hover { background-color: #5aa35a; }

  .nav-btn-discreet {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 100px;
    border: 1px solid rgba(255, 255, 255, 0.25);
    background: transparent;
    color: rgba(255, 255, 255, 0.85) !important;
    padding: 6px 16px;
    font-size: 13px;
    text-decoration: none;
    transition: all 0.2s ease;
  }
  .nav-btn-discreet:hover {
    background: rgba(255, 255, 255, 0.1);
    color: #fff !important;
  }

  .nav-hamburger {
    display: flex;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    margin-left: 12px;
  }
  .nav-hamburger span {
    width: 24px;
    height: 2px;
    background: #fff;
    transition: all 0.3s ease;
    border-radius: 2px;
  }
  .nav-hamburger.is-active span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav-hamburger.is-active span:nth-child(2) { opacity: 0; }
  .nav-hamburger.is-active span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* 
    ======================================
    FULLSCREEN EDITORIAL MENU (PREMIUM)
    ====================================== 
  */
  .mobile-menu {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    min-height: 100dvh;
    background: rgba(6, 15, 7, 0.98); /* Premium dark translucent */
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    z-index: 999;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    overflow-y: auto;
    overflow-x: hidden;
    display: flex;
    flex-direction: column;
  }

  .mobile-menu.is-open {
    opacity: 1;
    pointer-events: all;
  }

  .mobile-menu-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 104px;
    padding: 0 40px;
    max-width: 1440px;
    margin: 0 auto;
    width: 100%;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  .mobile-logo-img { height: 80px; width: auto; }
  .mobile-menu-actions { display: flex; align-items: center; gap: 20px; }

  .mobile-menu-inner {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    max-width: 1200px;
    margin: 0 auto;
    padding: clamp(32px, 4vh, 64px) 40px max(40px, env(safe-area-inset-bottom));
    width: 100%;
    gap: clamp(32px, 4vh, 64px);
  }

  /* ROW 1: Main links + Socials */
  .menu-top-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    padding-bottom: clamp(16px, 3vh, 32px);
  }

  .menu-main-nav {
    display: flex;
    gap: 48px;
  }
  .main-link {
    text-decoration: none;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .main-link:hover { transform: translateY(-4px); }
  .main-link-title {
    font-size: clamp(30px, 4vw, 42px);
    color: #fff;
    font-weight: 300;
    letter-spacing: -0.02em;
    position: relative;
    display: inline-block;
    transition: color 0.3s ease;
  }
  .main-link:hover .main-link-title { color: #6db56d; }

  .social-links-row {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 12px;
  }
  .social-title {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(255,255,255,0.4);
    font-weight: 500;
  }
  .social-icons {
    display: flex;
    gap: 12px;
  }
  .social-link {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(255,255,255,0.03);
    color: rgba(255,255,255,0.6);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }
  .social-link svg {
    width: 18px;
    height: 18px;
  }
  .social-link:hover:not(.mock-link) {
    background: #6db56d;
    color: #060f07;
    transform: translateY(-2px);
    box-shadow: 0 8px 16px rgba(109,181,109,0.2);
  }

  /* ROW 2: La Red Grid */
  .menu-network {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 24px;
    padding: clamp(32px, 4vh, 48px);
    position: relative;
    overflow: hidden;
  }
  /* Subtle glow inside the card */
  .menu-network::before {
    content: '';
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    background: radial-gradient(circle at top left, rgba(109,181,109,0.03) 0%, transparent 60%);
    pointer-events: none;
  }

  .network-header {
    margin-bottom: clamp(24px, 3vh, 40px);
  }
  .network-title {
    color: #6db56d;
    font-size: clamp(24px, 3vw, 26px);
    font-weight: 500;
    margin: 0 0 8px 0;
    letter-spacing: -0.01em;
  }
  .network-desc {
    color: rgba(255,255,255,0.6);
    font-size: 16px;
    margin: 0;
  }
  .network-access-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(16px, 2vw, 24px);
    margin-bottom: clamp(24px, 3vh, 32px);
  }
  .net-link {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding: clamp(16px, 2vh, 24px);
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 16px;
    color: #fff;
    text-decoration: none;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .net-link-icon-wrapper {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: rgba(109,181,109,0.1);
    color: #6db56d;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s ease;
  }
  .net-link-icon-wrapper svg {
    width: 24px;
    height: 24px;
  }
  .net-link-content {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .net-link-title {
    font-size: 16px;
    font-weight: 500;
    letter-spacing: -0.01em;
  }
  .net-link-desc {
    font-size: 13px;
    color: rgba(255,255,255,0.4);
    line-height: 1.5;
  }
  .net-link:hover:not(.mock-link) {
    background: rgba(109,181,109,0.05);
    border-color: rgba(109,181,109,0.2);
    transform: translateY(-4px);
    box-shadow: 0 16px 32px rgba(0,0,0,0.2);
  }
  .net-link:hover:not(.mock-link) .net-link-icon-wrapper {
    transform: scale(1.05);
    background: rgba(109,181,109,0.15);
  }

  .network-footer {
    font-size: 12px;
    color: rgba(255,255,255,0.3);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding-top: 24px;
    border-top: 1px solid rgba(255,255,255,0.06);
    text-align: center;
  }

  /* ROW 3: Secondary Links + Legal */
  .menu-bottom-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: auto;
  }
  
  .comp-links-row {
    display: flex;
    align-items: center;
    gap: 32px;
  }
  .comp-link-simple {
    color: rgba(255,255,255,0.8);
    text-decoration: none;
    font-size: 15px;
    font-weight: 500;
    transition: color 0.3s ease;
  }
  .comp-link-simple:hover:not(.mock-link) { color: #6db56d; }
  
  .menu-legal {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 24px;
  }
  .menu-legal a {
    color: rgba(255,255,255,0.4);
    font-size: 13px;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .menu-legal a:hover:not(.mock-link) { color: #fff; }

  .mock-link {
    opacity: 0.3;
    pointer-events: none;
  }

  /* Animations */
  .fade-in-up {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1), transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .mobile-menu.is-open .fade-in-up {
    opacity: 1;
    transform: translateY(0);
  }
  @media (prefers-reduced-motion: reduce) {
    .fade-in-up { transition: opacity 0.3s ease; transform: none; }
    .mobile-menu.is-open .fade-in-up { transform: none; }
  }

  /* Responsive Design */
  @media (max-height: 850px) {
    .mobile-menu-inner { gap: 32px; padding-top: 32px; padding-bottom: max(32px, env(safe-area-inset-bottom)); }
    .menu-network { padding: 32px; }
    .network-header { margin-bottom: 24px; }
    .net-link { padding: 16px; gap: 12px; }
    .network-access-grid { margin-bottom: 24px; }
    .menu-top-row { padding-bottom: 24px; }
  }

  @media (max-height: 760px) {
    .mobile-menu-inner { gap: 24px; padding-top: 24px; padding-bottom: max(24px, env(safe-area-inset-bottom)); }
    .menu-top-row { padding-bottom: 16px; }
    .menu-network { padding: 24px; border-radius: 16px; }
    .network-access-grid { gap: 12px; margin-bottom: 16px; }
    .net-link { padding: 12px; gap: 8px; }
    .net-link-icon-wrapper { width: 40px; height: 40px; }
    .net-link-icon-wrapper svg { width: 20px; height: 20px; }
    .network-title { font-size: 22px; margin-bottom: 4px; }
    .main-link-title { font-size: 28px; }
    .social-icons { gap: 8px; }
    .social-link { width: 36px; height: 36px; }
    .social-link svg { width: 16px; height: 16px; }
  }

  @media (max-width: 1024px) {
    .network-access-grid { grid-template-columns: repeat(2, 1fr); }
    .menu-bottom-row { flex-direction: column; align-items: flex-start; gap: 32px; }
