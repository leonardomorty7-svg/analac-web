---
// src/components/Nav.astro
---
<nav class="nav" id="main-nav">
  <div class="nav-container">
    <a href="/" class="nav-logo"><img src="/images/logo-white.svg" alt="ANALAC" class="nav-logo-img" /></a>
    
    <div class="nav-links">
      <a href="/">Inicio</a>
      <a href="/quienes-somos">Quiénes Somos</a>
      <a href="/informacion-sectorial">Información Sectorial</a>
      <a href="/consumo-lacteo">Consumo Lácteo</a>
      <a href="/noticias">Noticias</a>
    </div>

    <div class="nav-cta">
      <a href="#" class="nav-btn-discreet">Portal Afiliados</a>
      <a href="#" class="nav-btn-discreet">Portal Aliados</a>
      <a href="#" class="nav-btn-discreet">Academia</a>
      <a href="/afiliate" class="nav-btn">Hazte afiliado →</a>
    </div>

    <button class="nav-hamburger" id="nav-toggle" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<div class="mobile-menu" id="mobile-menu">
  <div class="mobile-links">
    <a href="/">Inicio</a>
    <a href="/quienes-somos">Quiénes Somos</a>
    <a href="/informacion-sectorial">Información Sectorial</a>
    <a href="/consumo-lacteo">Consumo Lácteo</a>
    <a href="/noticias">Noticias</a>
  </div>
  <div class="mobile-cta">
    <a href="#" class="nav-btn-discreet">Portal Afiliados</a>
    <a href="#" class="nav-btn-discreet">Portal Aliados</a>
    <a href="#" class="nav-btn-discreet">Academia</a>
    <a href="/afiliate" class="nav-btn">Hazte afiliado →</a>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const toggle = document.getElementById('nav-toggle');
    const menu = document.getElementById('mobile-menu');
    const nav = document.getElementById('main-nav');
    let isOpen = false;

    toggle?.addEventListener('click', () => {
      isOpen = !isOpen;
      if (isOpen) {
        menu?.classList.add('is-open');
        toggle.classList.add('is-active');
        nav?.classList.add('scrolled');
        document.body.style.overflow = 'hidden';
      } else {
        menu?.classList.remove('is-open');
        toggle.classList.remove('is-active');
        if (window.scrollY < 50) nav?.classList.remove('scrolled');
        document.body.style.overflow = '';
      }
    });

    window.addEventListener('scroll', () => {
      if (window.scrollY > 50 || isOpen) {
        nav?.classList.add('scrolled');
      } else {
        nav?.classList.remove('scrolled');
      }
    });
  });
</script>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 104px;
    z-index: 1000;
    background: linear-gradient(to bottom, rgba(6, 15, 7, 0.85) 0%, transparent 100%);
    transition: all 0.3s ease;
  }

  .nav.scrolled {
    background: rgba(6, 15, 7, 0.95);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }

  .nav-container {
    display: flex;
    align-items: center;
    max-width: 1440px;
    margin: 0 auto;
    height: 100%;
    padding: 0 40px 0 60px;
  }

  .nav-logo {
    flex-shrink: 0;
    z-index: 1001;
  }

  .nav-logo-img {
    height: 80px;
    width: auto;
    display: block;
    transition: height 0.3s ease;
  }

  .nav-links {
    display: flex;
    gap: 24px;
    margin-left: 72px;
  }

  .nav-links a {
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
    font-size: 13px;
    font-weight: 500;
    transition: color 0.2s ease;
  }

  .nav-links a:hover {
    color: #fff;
  }

  .nav-cta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-left: auto;
  }

  .nav-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 100px;
    background: #6db56d;
    border: none;
    color: #fff !important;
    padding: 8px 20px;
    font-size: 12px;
    font-weight: 500;
    text-decoration: none;
    transition: background-color 0.2s ease;
  }

  .nav-btn:hover {
    background-color: #5aa35a;
  }

  .nav-btn-discreet {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 100px;
    border: 1px solid rgba(255, 255, 255, 0.25);
    background: transparent;
    color: rgba(255, 255, 255, 0.75) !important;
    padding: 6px 14px;
    font-size: 12px;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .nav-btn-discreet:hover {
    background: rgba(255, 255, 255, 0.1);
    color: #fff !important;
  }

  .nav-hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    z-index: 1001;
    margin-left: auto;
    padding: 8px;
  }

  .nav-hamburger span {
    width: 24px;
    height: 2px;
    background: #fff;
    transition: all 0.3s ease;
    border-radius: 2px;
  }
  
  .nav-hamburger.is-active span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .nav-hamburger.is-active span:nth-child(2) {
    opacity: 0;
  }
  .nav-hamburger.is-active span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .mobile-menu {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    background: rgba(6, 15, 7, 0.98);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    z-index: 999;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s ease;
    padding: 24px;
  }

  .mobile-menu.is-open {
    opacity: 1;
    pointer-events: all;
  }

  .mobile-links {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    margin-bottom: 40px;
    transform: translateY(20px);
    transition: transform 0.4s ease;
  }
  
  .mobile-menu.is-open .mobile-links {
    transform: translateY(0);
  }

  .mobile-links a {
    color: #fff;
    font-size: 24px;
    font-weight: 500;
    text-decoration: none;
  }

  .mobile-cta {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    width: 100%;
    max-width: 300px;
    gap: 16px;
    transform: translateY(20px);
    transition: transform 0.4s ease 0.1s;
  }
  
  .mobile-menu.is-open .mobile-cta {
    transform: translateY(0);
  }

  .mobile-cta .nav-btn, .mobile-cta .nav-btn-discreet {
    font-size: 16px;
    padding: 14px 24px;
  }

  @media (max-width: 900px) {
    .nav { height: 80px; }
    .nav-links { gap: 20px; margin-left: 40px; }
    .nav-logo-img { height: 48px; }
  }

  @media (max-width: 768px) {
    .nav { height: 68px; }
    .nav-links, .nav-cta {
      display: none;
    }
    .nav-hamburger {
      display: flex;
    }
    .nav-container {
      padding: 0 24px;
    }
    .nav-logo-img { height: 42px; }
  }
</style>

