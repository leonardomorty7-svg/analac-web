---
// src/components/AliadosGroup.astro
// Un grupo de logos de aliados (título + descripción opcional + grilla).
// Soporta 3 tipos de grilla: estática, carrusel infinito (marquee) o scroll horizontal (academia).

interface Logo {
  src: string
  alt: string
  scale: number
}

interface Props {
  titulo: string
  desc?: string
  items: Logo[]
  gridType: 'static' | 'marquee' | 'academia'
  tierClass?: string
  gap?: number
  duration?: number
}

const { titulo, desc, items, gridType, tierClass = '', gap = 64, duration = 35 } = Astro.props
const marqueeItems = gridType === 'marquee' ? [...items, ...items] : items
---

<h3 class="section-logo-title">{titulo}</h3>
{desc && <p class="section-logo-desc">{desc}</p>}

{gridType === 'static' && (
  <div class="static-logo-grid" style={`gap:${gap}px`}>
    {items.map(logo => (
      <div class={`logo-item ${tierClass}`} style={`--logo-scale: ${logo.scale};`}>
        <img src={logo.src} alt={logo.alt} loading="lazy" />
      </div>
    ))}
  </div>
)}

{gridType === 'marquee' && (
  <div class="marquee-wrapper">
    <div class="marquee-track" style={`animation-duration: ${duration}s`}>
      {marqueeItems.map(logo => (
        <div class={`logo-item ${tierClass}`} style={`--logo-scale: ${logo.scale};`}>
          <img src={logo.src} alt={logo.alt} loading="lazy" />
        </div>
      ))}
    </div>
  </div>
)}

{gridType === 'academia' && (
  <div class="academia-logo-grid">
    {items.map(logo => (
      <div class={`logo-item ${tierClass}`} style={`--logo-scale: ${logo.scale};`}>
        <img src={logo.src} alt={logo.alt} loading="lazy" />
      </div>
    ))}
  </div>
)}

<style>
  .section-logo-title {
    font-size: clamp(22px, 2.4vw, 28px);
    font-weight: 500;
    margin-bottom: 12px;
    color: #0f2211;
    letter-spacing: -0.01em;
  }
  .section-logo-desc {
    color: rgba(15, 34, 17, 0.6);
    max-width: 620px;
    margin: 0 0 32px;
    line-height: 1.6;
  }
  .logo-item {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .logo-item img {
    height: 60px;
    width: auto;
    object-fit: contain;
    opacity: 0.65;
    filter: grayscale(100%);
    transform: scale(var(--logo-scale, 1));
    transition: opacity 0.4s ease, filter 0.4s ease, transform 0.4s ease;
  }
  .logo-item:hover img {
    opacity: 1;
    filter: none;
    transform: scale(calc(var(--logo-scale, 1) * 1.05));
  }
  .logo-item.tier-1 img { height: 72px; }
  .logo-item.tier-2 img { height: 60px; }
  .logo-item.tier-3 img { height: 50px; }

  .static-logo-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-start;
    align-items: center;
    gap: 64px;
  }
  .academia-logo-grid {
    display: flex;
    flex-wrap: nowrap;
    justify-content: flex-start;
    gap: 64px;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .academia-logo-grid::-webkit-scrollbar { display: none; }

  .marquee-wrapper {
    width: 100%;
    overflow: hidden;
    position: relative;
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 5%, #000 95%, transparent);
    mask-image: linear-gradient(90deg, transparent, #000 5%, #000 95%, transparent);
  }
  .marquee-track {
    display: flex;
    width: max-content;
    gap: 80px;
    padding: 20px 0;
    animation: marquee-scroll 35s linear infinite;
  }
  .marquee-track:hover {
    animation-play-state: paused;
  }
  @keyframes marquee-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(calc(-50% - 40px)); }
  }

  @media (max-width: 768px) {
    .static-logo-grid { gap: 32px; justify-content: center; }
    .academia-logo-grid { gap: 32px; justify-content: flex-start; padding-bottom: 16px; }
    .logo-item.tier-1 img { height: 56px; }
    .logo-item img { height: 48px; }
    .marquee-track { gap: 40px; animation-duration: 25s; }
    @keyframes marquee-scroll {
      0% { transform: translateX(0); }
      100% { transform: translateX(calc(-50% - 20px)); }
    }
    .section-logo-title { text-align: center; }
    .section-logo-desc { text-align: center; margin-left: auto; margin-right: auto; }
  }
</style>
