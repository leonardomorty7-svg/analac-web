---
// src/components/CienciaLacteaSection.astro

import AuthorSignature from './AuthorSignature.astro'

// Color distintivo por categoría (secundario a la paleta de marca, hace juego con el verde de acento).
const categoryColors: Record<string, string> = {
  "Nutrición": "#c08a2e",
  "Producción": "#a15c3e",
  "Consumo": "#3d6ea8",
  "Sostenibilidad": "#2f7d6b",
}

const articles = [
  {
    categoria: "Nutrición",
    titulo: "El calcio de la leche y su absorción en adultos mayores",
    imagen: "/images/ciencia/nutricion.png",
    autorId: "laura-hernandez",
    fecha: "18 jun 2026",
  },
  {
    categoria: "Producción",
    titulo: "Impacto del manejo de ordeño en la calidad composicional de la leche",
    imagen: "/images/ciencia/produccion.png",
    autorId: "andres-ramirez",
    fecha: "24 jun 2026",
  },
  {
    categoria: "Consumo",
    titulo: "Leche entera vs. descremada: evidencia actualizada sobre salud cardiovascular",
    imagen: "/images/ciencia/consumo.png",
    autorId: "felipe-gonzalez",
    fecha: "30 jun 2026",
  },
  {
    categoria: "Producción",
    titulo: "Bienestar animal: su relación con la calidad de la leche",
    imagen: "/images/ciencia/produccion.png",
    autorId: "laura-hernandez",
    fecha: "3 jul 2026",
  },
  {
    categoria: "Nutrición",
    titulo: "Proteína láctea y su rol en la recuperación muscular",
    imagen: "/images/ciencia/nutricion.png",
    autorId: "andres-ramirez",
    fecha: "7 jul 2026",
  },
  {
    categoria: "Sostenibilidad",
    titulo: "Huella hídrica y ambiental de la ganadería lechera colombiana",
    imagen: "/images/ciencia/consumo.png",
    autorId: "felipe-gonzalez",
    fecha: "9 jul 2026",
  },
];
---

<section class="ciencia-section">
  <div class="ciencia-header reveal" style="transition-delay: 0ms">
    <span class="overline">CIENCIA LÁCTEA</span>
    <h2 class="ciencia-h2">
      <span class="nowrap-desktop">Investigación, nutrición y desarrollo productivo</span> <br class="break-desktop" />
      <span class="nowrap-desktop">lácteo con información técnica rigurosa</span>
    </h2>
    <span class="ciencia-rule"></span>
  </div>

  <div class="ciencia-carousel-wrap reveal" style="transition-delay: 150ms">
    <div class="ciencia-track" id="cienciaTrack">
      {[...articles, ...articles].map((art) => (
        <a href="/noticias" class="article-card">
          <div class="article-img-wrapper">
            <img src={art.imagen} alt={art.categoria} class="article-img" />
          </div>
          <div class="article-content">
            <div class="article-meta-row">
              <span class="editorial-tag-side" style={`--tag-color:${categoryColors[art.categoria] ?? '#6db56d'}`}><span class="tag-dot"></span>{art.categoria}</span>
              <span class="article-date">{art.fecha}</span>
            </div>
            <h3 class="article-title">{art.titulo}</h3>
            <div class="byline">
              <AuthorSignature id={art.autorId} variant="byline" />
            </div>
            <span class="article-read">Leer artículo &rarr;</span>
          </div>
        </a>
      ))}
    </div>
  </div>

  <div class="ciencia-actions reveal" style="transition-delay: 300ms">
    <a href="/consumo-lacteo" class="btn-primary">Explorar el Centro de Conocimiento →</a>
  </div>
</section>

<style>
  .ciencia-section {
    min-height: 100vh;
    background-color: #f5f3ee;
    padding: 64px 5vw 120px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 48px;
  }

  .ciencia-header {
    text-align: center;
    max-width: 1000px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .overline {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #6db56d;
    font-weight: 600;
  }

  .ciencia-h2 {
    font-size: clamp(32px, 4vw, 48px);
    font-weight: 400;
    color: #0f2211;
    line-height: 1.15;
    margin: 0;
    letter-spacing: -0.02em;
  }

  .ciencia-rule {
    display: block;
    width: 64px;
    height: 2px;
    background: #6db56d;
    margin-top: 8px;
    border-radius: 2px;
  }

  .break-desktop {
    display: none;
  }

  .nowrap-desktop {
    white-space: normal;
  }

  @media (min-width: 769px) {
    .break-desktop {
      display: inline;
    }
    .nowrap-desktop {
      white-space: nowrap;
    }
  }

  /* Carrusel horizontal con movimiento continuo (mismo mecanismo que el
     marquee de "Organizaciones e instituciones que respaldan..."):
     2 copias del set, animadas con translateX en loop infinito, y en
     pausa mientras el mouse esté encima. */
  .ciencia-carousel-wrap {
    width: 100vw;
    max-width: none;
    align-self: flex-start;
    margin-left: -5vw;
    overflow: hidden;
  }

  .ciencia-track {
    display: flex;
    width: max-content;
    gap: 28px;
    /* Suficiente aire arriba/abajo para que la sombra del hover (que crece
       y la card se levanta) no quede cortada por el overflow:hidden del wrap. */
    padding: 24px 4px 72px;
    animation: ciencia-marquee-scroll 45s linear infinite;
  }
  .ciencia-track:hover {
    animation-play-state: paused;
  }
  @keyframes ciencia-marquee-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(calc(-50% - 14px)); }
  }

  .article-card {
    display: flex;
    flex-direction: column;
    /* En vw (no % del contenedor) para que el ancho no varíe aunque el
       wrap sea full-bleed a 100vw: debe medir igual que las cards de
       "Versatilidad del Lácteo Colombiano" (contenedor de 95vw). */
    flex: 0 0 calc((95vw - 84px) / 3.5);
    width: calc((95vw - 84px) / 3.5);
    background: white;
    border-radius: 20px;
    overflow: hidden;
    text-decoration: none;
    border: 1px solid rgba(0, 0, 0, 0.06);
    box-shadow: 0 4px 20px rgba(15, 34, 17, 0.04);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    cursor: pointer;
  }
  .article-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 28px 48px rgba(15, 34, 17, 0.12);
  }

  .article-img-wrapper {
    width: 100%;
    height: 240px;
    overflow: hidden;
  }

  .article-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s cubic-bezier(0.16, 1, 0.3, 1), filter 0.5s ease;
    filter: brightness(1);
  }
  .article-card:hover .article-img {
    transform: scale(1.06);
    filter: brightness(1.06);
  }

  .article-content {
    padding: 28px;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .article-meta-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    margin-bottom: 14px;
  }

  .editorial-tag-side {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--tag-color, #6db56d);
    font-weight: 600;
  }

  .tag-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--tag-color, #6db56d);
  }

  .article-date {
    font-size: 11px;
    color: #4b5563;
    opacity: 0.6;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .article-title {
    font-size: 19px;
    font-weight: 500;
    color: #0f2211;
    line-height: 1.4;
    margin: 0 0 24px;
    transition: color 0.3s ease;
    text-wrap: balance;
  }
  .article-card:hover .article-title {
    color: #6db56d;
  }

  /* Byline (firma de autor) */
  .byline {
    margin-top: auto;
    padding-top: 16px;
    border-top: 1px solid rgba(15, 34, 17, 0.08);
  }

  .article-read {
    font-size: 13px;
    color: #6db56d;
    font-weight: 500;
    margin-top: 14px;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.35s ease, transform 0.35s ease;
  }
  .article-card:hover .article-read {
    opacity: 1;
    transform: translateY(0);
  }

  /* Editorial CTA */
  .ciencia-actions {
    margin-top: 24px;
  }

  .btn-primary {
    background: #6db56d;
    color: white;
    border-radius: 100px;
    padding: 16px 36px;
    font-size: 15px;
    font-weight: 500;
    text-decoration: none;
    box-shadow: 0 4px 12px rgba(109, 181, 109, 0.2);
    transition: all 0.3s ease;
    display: inline-block;
  }
  .btn-primary:hover {
    background: #5aa35a;
    box-shadow: 0 6px 16px rgba(109, 181, 109, 0.3);
    transform: translateY(-2px);
  }

  /* Reveal Animations */
  .reveal {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Responsive */
  @media (max-width: 640px) {
    .ciencia-section {
      padding: 64px 24px;
    }
    .ciencia-carousel-wrap {
      width: 100vw;
      margin-left: -24px;
    }
    .ciencia-track {
      animation-duration: 30s;
    }
    .article-card {
      flex-basis: 280px;
      width: 280px;
    }
  }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(el => {
      if (el.isIntersecting) {
        el.target.classList.add('visible');
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.ciencia-section .reveal').forEach(el => observer.observe(el));
</script>
