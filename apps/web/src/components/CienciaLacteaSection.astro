---
// src/components/CienciaLacteaSection.astro

const articles = [
  {
    categoria: "Nutrición",
    titulo: "El calcio de la leche y su absorción en adultos mayores",
    imagen: "/images/ciencia/nutricion.png",
    autor: "Equipo Técnico ANALAC",
  },
  {
    categoria: "Producción",
    titulo: "Impacto del manejo de ordeño en la calidad composicional de la leche",
    imagen: "/images/ciencia/produccion.png",
    autor: "Equipo Técnico ANALAC",
  },
  {
    categoria: "Consumo",
    titulo: "Leche entera vs. descremada: evidencia actualizada sobre salud cardiovascular",
    imagen: "/images/ciencia/consumo.png",
    autor: "Equipo Técnico ANALAC",
  },
];
---

<section class="ciencia-section">
  <div class="ciencia-header reveal" style="transition-delay: 0ms">
    <span class="overline">CIENCIA LÁCTEA</span>
    <h2 class="ciencia-h2">
      <span class="nowrap-desktop">Investigación, nutrición y desarrollo productivo</span> <br class="break-desktop" />
      <span class="nowrap-desktop">lácteo con información técnica rigurosa</span>
    </h2>
    <span class="ciencia-rule"></span>
  </div>

  <div class="editorial-grid">
    {articles.map((art, idx) => (
      <a href="/noticias" class="article-card reveal" style={`transition-delay: ${(idx + 1) * 150}ms`}>
        <div class="article-img-wrapper">
          <img src={art.imagen} alt={art.categoria} class="article-img" />
        </div>
        <div class="article-content">
          <span class="editorial-tag-side"><span class="tag-dot"></span>{art.categoria}</span>
          <h3 class="article-title">{art.titulo}</h3>
          <div class="byline">
            <span class="byline-avatar">AN</span>
            <span class="byline-name">{art.autor}</span>
          </div>
          <span class="article-read">Leer artículo &rarr;</span>
        </div>
      </a>
    ))}
  </div>

  <div class="ciencia-actions reveal" style="transition-delay: 600ms">
    <a href="/consumo-lacteo" class="btn-primary">Explorar el Centro de Conocimiento →</a>
  </div>
</section>

<style>
  .ciencia-section {
    min-height: 100vh;
    background-color: #f5f3ee;
    padding: 64px 5vw 120px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 48px;
  }

  .ciencia-header {
    text-align: center;
    max-width: 1000px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .overline {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #6db56d;
    font-weight: 600;
  }

  .ciencia-h2 {
    font-size: clamp(32px, 4vw, 48px);
    font-weight: 400;
    color: #0f2211;
    line-height: 1.15;
    margin: 0;
    letter-spacing: -0.02em;
  }

  .ciencia-rule {
    display: block;
    width: 64px;
    height: 2px;
    background: #6db56d;
    margin-top: 8px;
    border-radius: 2px;
  }

  .break-desktop {
    display: none;
  }

  .nowrap-desktop {
    white-space: normal;
  }

  @media (min-width: 769px) {
    .break-desktop {
      display: inline;
    }
    .nowrap-desktop {
      white-space: nowrap;
    }
  }

  /* Editorial Grid Layout - 3 equal cards */
  .editorial-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    width: 100%;
    max-width: 1240px;
  }

  .article-card {
    display: flex;
    flex-direction: column;
    background: white;
    border-radius: 20px;
    overflow: hidden;
    text-decoration: none;
    height: 100%;
    border: 1px solid rgba(0, 0, 0, 0.06);
    box-shadow: 0 4px 20px rgba(15, 34, 17, 0.04);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    cursor: pointer;
  }
  .article-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 28px 48px rgba(15, 34, 17, 0.12);
  }

  .article-img-wrapper {
    width: 100%;
    height: 240px;
    overflow: hidden;
  }

  .article-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s cubic-bezier(0.16, 1, 0.3, 1), filter 0.5s ease;
    filter: brightness(1);
  }
  .article-card:hover .article-img {
    transform: scale(1.06);
    filter: brightness(1.06);
  }

  .article-content {
    padding: 28px;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .editorial-tag-side {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #6db56d;
    font-weight: 600;
    margin-bottom: 14px;
  }

  .tag-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #6db56d;
  }

  .article-title {
    font-size: 19px;
    font-weight: 500;
    color: #0f2211;
    line-height: 1.4;
    margin: 0 0 24px;
    transition: color 0.3s ease;
    text-wrap: balance;
  }
  .article-card:hover .article-title {
    color: #6db56d;
  }

  /* Byline (author avatar + name) */
  .byline {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: auto;
    padding-top: 16px;
    border-top: 1px solid rgba(15, 34, 17, 0.08);
  }

  .byline-avatar {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.02em;
    background: #6db56d;
    color: #ffffff;
  }

  .byline-name {
    font-size: 13px;
    font-weight: 500;
    color: #0f2211;
    opacity: 0.7;
  }

  .article-read {
    font-size: 13px;
    color: #6db56d;
    font-weight: 500;
    margin-top: 14px;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.35s ease, transform 0.35s ease;
  }
  .article-card:hover .article-read {
    opacity: 1;
    transform: translateY(0);
  }

  /* Editorial CTA */
  .ciencia-actions {
    margin-top: 24px;
  }

  .btn-primary {
    background: #6db56d;
    color: white;
    border-radius: 100px;
    padding: 16px 36px;
    font-size: 15px;
    font-weight: 500;
    text-decoration: none;
    box-shadow: 0 4px 12px rgba(109, 181, 109, 0.2);
    transition: all 0.3s ease;
    display: inline-block;
  }
  .btn-primary:hover {
    background: #5aa35a;
    box-shadow: 0 6px 16px rgba(109, 181, 109, 0.3);
    transform: translateY(-2px);
  }

  /* Reveal Animations */
  .reveal {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Responsive */
  @media (max-width: 992px) {
    .editorial-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .ciencia-section {
      padding: 64px 24px;
    }
    .editorial-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(el => {
      if (el.isIntersecting) {
        el.target.classList.add('visible');
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.ciencia-section .reveal').forEach(el => observer.observe(el));
</script>
