---
// src/components/CienciaLacteaSection.astro

import AuthorSignature from './AuthorSignature.astro'

// Color distintivo por categoría (secundario a la paleta de marca, hace juego con el verde de acento).
const categoryColors: Record<string, string> = {
  "Nutrición": "#c08a2e",
  "Producción": "#a15c3e",
  "Consumo": "#3d6ea8",
  "Sostenibilidad": "#2f7d6b",
}

const articles = [
  {
    categoria: "Nutrición",
    titulo: "El calcio de la leche y su absorción en adultos mayores",
    imagen: "/images/ciencia/nutricion.png",
    autorId: "laura-hernandez",
  },
  {
    categoria: "Producción",
    titulo: "Impacto del manejo de ordeño en la calidad composicional de la leche",
    imagen: "/images/ciencia/produccion.png",
    autorId: "andres-ramirez",
  },
  {
    categoria: "Consumo",
    titulo: "Leche entera vs. descremada: evidencia actualizada sobre salud cardiovascular",
    imagen: "/images/ciencia/consumo.png",
    autorId: "felipe-gonzalez",
  },
  {
    categoria: "Producción",
    titulo: "Bienestar animal: su relación con la calidad de la leche",
    imagen: "/images/ciencia/produccion.png",
    autorId: "laura-hernandez",
  },
  {
    categoria: "Nutrición",
    titulo: "Proteína láctea y su rol en la recuperación muscular",
    imagen: "/images/ciencia/nutricion.png",
    autorId: "andres-ramirez",
  },
  {
    categoria: "Sostenibilidad",
    titulo: "Huella hídrica y ambiental de la ganadería lechera colombiana",
    imagen: "/images/ciencia/consumo.png",
    autorId: "felipe-gonzalez",
  },
];
---

<section class="ciencia-section">
  <div class="ciencia-header reveal" style="transition-delay: 0ms">
    <span class="overline">CIENCIA LÁCTEA</span>
    <h2 class="ciencia-h2">
      <span class="nowrap-desktop">Investigación, nutrición y desarrollo productivo</span> <br class="break-desktop" />
      <span class="nowrap-desktop">lácteo con información técnica rigurosa</span>
    </h2>
    <span class="ciencia-rule"></span>
  </div>

  <div class="ciencia-carousel-wrap reveal" style="transition-delay: 150ms">
    <div class="ciencia-track" id="cienciaTrack">
      {[...articles, ...articles, ...articles].map((art) => (
        <a href="/noticias" class="article-card">
          <div class="article-img-wrapper">
            <img src={art.imagen} alt={art.categoria} class="article-img" />
          </div>
          <div class="article-content">
            <span class="editorial-tag-side" style={`--tag-color:${categoryColors[art.categoria] ?? '#6db56d'}`}><span class="tag-dot"></span>{art.categoria}</span>
            <h3 class="article-title">{art.titulo}</h3>
            <div class="byline">
              <AuthorSignature id={art.autorId} variant="byline" />
            </div>
            <span class="article-read">Leer artículo &rarr;</span>
          </div>
        </a>
      ))}
    </div>

    <div class="ciencia-nav">
      <button type="button" class="ciencia-nav-btn" id="cienciaPrev" aria-label="Artículo anterior">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
      </button>
      <button type="button" class="ciencia-nav-btn ciencia-nav-btn--active" id="cienciaNext" aria-label="Siguiente artículo">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
      </button>
    </div>
  </div>

  <div class="ciencia-actions reveal" style="transition-delay: 300ms">
    <a href="/consumo-lacteo" class="btn-primary">Explorar el Centro de Conocimiento →</a>
  </div>
</section>

<style>
  .ciencia-section {
    min-height: 100vh;
    background-color: #f5f3ee;
    padding: 64px 5vw 120px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 48px;
  }

  .ciencia-header {
    text-align: center;
    max-width: 1000px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .overline {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #6db56d;
    font-weight: 600;
  }

  .ciencia-h2 {
    font-size: clamp(32px, 4vw, 48px);
    font-weight: 400;
    color: #0f2211;
    line-height: 1.15;
    margin: 0;
    letter-spacing: -0.02em;
  }

  .ciencia-rule {
    display: block;
    width: 64px;
    height: 2px;
    background: #6db56d;
    margin-top: 8px;
    border-radius: 2px;
  }

  .break-desktop {
    display: none;
  }

  .nowrap-desktop {
    white-space: normal;
  }

  @media (min-width: 769px) {
    .break-desktop {
      display: inline;
    }
    .nowrap-desktop {
      white-space: nowrap;
    }
  }

  /* Carrusel horizontal con "peek" del siguiente artículo */
  .ciencia-carousel-wrap {
    width: calc(100vw - 5vw);
    max-width: none;
    align-self: flex-start;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .ciencia-track {
    display: flex;
    gap: 28px;
    width: 100%;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding: 4px 4px 8px;
  }
  .ciencia-track::-webkit-scrollbar {
    display: none;
  }

  .ciencia-nav {
    display: flex;
    gap: 12px;
    margin-top: 32px;
  }
  .ciencia-nav-btn {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: 1px solid rgba(15, 34, 17, 0.12);
    background: #ffffff;
    color: #0f2211;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.3s ease, color 0.3s ease, border-color 0.3s ease, transform 0.2s ease;
  }
  .ciencia-nav-btn:hover {
    transform: translateY(-2px);
    border-color: #6db56d;
    color: #6db56d;
  }
  .ciencia-nav-btn--active {
    background: #0f2211;
    color: #ffffff;
    border-color: #0f2211;
  }
  .ciencia-nav-btn--active:hover {
    background: #1a3a1e;
    color: #ffffff;
  }

  .article-card {
    display: flex;
    flex-direction: column;
    flex: 0 0 calc((100% - 112px) / 4.5);
    width: calc((100% - 112px) / 4.5);
    scroll-snap-align: start;
    background: white;
    border-radius: 20px;
    overflow: hidden;
    text-decoration: none;
    border: 1px solid rgba(0, 0, 0, 0.06);
    box-shadow: 0 4px 20px rgba(15, 34, 17, 0.04);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    cursor: pointer;
  }
  .article-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 28px 48px rgba(15, 34, 17, 0.12);
  }

  .article-img-wrapper {
    width: 100%;
    height: 240px;
    overflow: hidden;
  }

  .article-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s cubic-bezier(0.16, 1, 0.3, 1), filter 0.5s ease;
    filter: brightness(1);
  }
  .article-card:hover .article-img {
    transform: scale(1.06);
    filter: brightness(1.06);
  }

  .article-content {
    padding: 28px;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .editorial-tag-side {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--tag-color, #6db56d);
    font-weight: 600;
    margin-bottom: 14px;
  }

  .tag-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--tag-color, #6db56d);
  }

  .article-title {
    font-size: 19px;
    font-weight: 500;
    color: #0f2211;
    line-height: 1.4;
    margin: 0 0 24px;
    transition: color 0.3s ease;
    text-wrap: balance;
  }
  .article-card:hover .article-title {
    color: #6db56d;
  }

  /* Byline (firma de autor) */
  .byline {
    margin-top: auto;
    padding-top: 16px;
    border-top: 1px solid rgba(15, 34, 17, 0.08);
  }

  .article-read {
    font-size: 13px;
    color: #6db56d;
    font-weight: 500;
    margin-top: 14px;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.35s ease, transform 0.35s ease;
  }
  .article-card:hover .article-read {
    opacity: 1;
    transform: translateY(0);
  }

  /* Editorial CTA */
  .ciencia-actions {
    margin-top: 24px;
  }

  .btn-primary {
    background: #6db56d;
    color: white;
    border-radius: 100px;
    padding: 16px 36px;
    font-size: 15px;
    font-weight: 500;
    text-decoration: none;
    box-shadow: 0 4px 12px rgba(109, 181, 109, 0.2);
    transition: all 0.3s ease;
    display: inline-block;
  }
  .btn-primary:hover {
    background: #5aa35a;
    box-shadow: 0 6px 16px rgba(109, 181, 109, 0.3);
    transform: translateY(-2px);
  }

  /* Reveal Animations */
  .reveal {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Responsive */
  @media (max-width: 640px) {
    .ciencia-section {
      padding: 64px 24px;
    }
    .ciencia-carousel-wrap {
      width: calc(100vw - 24px);
    }
    .article-card {
      flex-basis: 260px;
      width: 260px;
    }
  }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(el => {
      if (el.isIntersecting) {
        el.target.classList.add('visible');
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.ciencia-section .reveal').forEach(el => observer.observe(el));

  // Carrusel horizontal de "Ciencia Láctea": auto-rotación infinita + botones
  ;(function () {
    const wrap = document.querySelector('.ciencia-carousel-wrap')
    const track = document.getElementById('cienciaTrack')
    const prev = document.getElementById('cienciaPrev')
    const next = document.getElementById('cienciaNext')
    if (!wrap || !track || !prev || !next) return

    const AUTOPLAY_MS = 3500

    function cardStep() {
      const card = track.querySelector('.article-card')
      if (!card) return 0
      const style = getComputedStyle(track)
      const gap = parseFloat(style.columnGap || style.gap || '0') || 0
      return card.getBoundingClientRect().width + gap
    }

    // El track contiene 3 copias del set de artículos. Mantenemos el
    // scroll siempre dentro de la copia del medio y, cuando se sale de
    // ese rango, saltamos instantáneamente una copia hacia el otro lado
    // (contenido idéntico, así que el salto es invisible) => loop infinito.
    function setWidth() {
      return track.scrollWidth / 3
    }

    function normalize() {
      const width = setWidth()
      if (track.scrollLeft < width * 0.5) {
        track.scrollTo({ left: track.scrollLeft + width, behavior: 'instant' })
      } else if (track.scrollLeft > width * 1.5) {
        track.scrollTo({ left: track.scrollLeft - width, behavior: 'instant' })
      }
    }

    function advance(dir) {
      track.scrollBy({ left: dir * cardStep(), behavior: 'smooth' })
    }

    let normalizeTimeout
    track.addEventListener('scroll', () => {
      clearTimeout(normalizeTimeout)
      normalizeTimeout = setTimeout(normalize, 150)
    })

    let timer = null
    function startAutoplay() {
      stopAutoplay()
      timer = setInterval(() => advance(1), AUTOPLAY_MS)
    }
    function stopAutoplay() {
      if (timer) clearInterval(timer)
      timer = null
    }

    next.addEventListener('click', () => {
      advance(1)
      startAutoplay()
    })
    prev.addEventListener('click', () => {
      advance(-1)
      startAutoplay()
    })

    wrap.addEventListener('mouseenter', stopAutoplay)
    wrap.addEventListener('mouseleave', startAutoplay)

    window.addEventListener('resize', () => {
      normalize()
    })

    // Posiciona el scroll al inicio de la copia del medio antes de arrancar
    // (el layout ya está resuelto de forma síncrona en este punto).
    track.scrollTo({ left: setWidth(), behavior: 'instant' })
    startAutoplay()
  })()
</script>
