<style>
  .footer {
    background: #060f07;
    padding: 80px 5vw 40px;
    color: #fff;
  }

  .footer-top {
    margin-bottom: 64px;
  }

  .footer-logo-col {
    max-width: 400px;
  }

  .footer-logo {
    display: block;
    width: auto;
    margin-bottom: 24px;
  }

  .footer-desc {
    font-size: 14px;
    color: rgba(245,243,238,0.5);
    line-height: 1.7;
    margin-bottom: 24px;
  }

  .footer-social {
    display: flex;
    gap: 16px;
  }

  .footer-social a {
    width: 36px; 
    height: 36px;
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    color: rgba(245,243,238,0.5);
    transition: all 0.2s ease;
  }

  .footer-social a:hover {
    border-color: #6db56d;
    color: #6db56d;
    transform: translateY(-2px);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 40px;
    padding-bottom: 64px;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }

  @media (max-width: 1024px) {
    .footer-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 640px) {
    .footer-grid { grid-template-columns: repeat(2, 1fr); gap: 32px 24px; }
  }
  @media (max-width: 480px) {
    .footer-grid { grid-template-columns: 1fr; }
  }

  .footer-col-title {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #6db56d;
    margin-bottom: 20px;
    font-weight: 500;
  }

  .footer-col a, .footer-col .footer-text {
    display: block;
    font-size: 14px;
    color: rgba(245,243,238,0.55);
    text-decoration: none;
    margin-bottom: 12px;
    transition: color 0.2s ease;
    line-height: 1.4;
  }

  .footer-col a:hover:not(.mock-link) { 
    color: #fff; 
  }

  .mock-link {
    opacity: 0.5;
    pointer-events: none;
    cursor: default;
  }

  /* FOOTER BOTTOM (LEGAL) */
  .footer-bottom {
    padding-top: 32px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .footer-legal-links {
    display: flex;
    flex-wrap: wrap;
    gap: 16px 24px;
  }

  .footer-legal-links a {
    font-size: 12px;
    color: rgba(245,243,238,0.4);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-legal-links a:hover:not(.mock-link) {
    color: rgba(245,243,238,0.8);
  }

  .footer-copyright {
    font-size: 12px;
    color: rgba(245,243,238,0.3);
  }

  @media (min-width: 1024px) {
    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
    .footer-legal-links {
      flex: 1;
      justify-content: flex-start;
    }
    .footer-copyright {
      flex-shrink: 0;
      text-align: right;
    }
  }
</style>
