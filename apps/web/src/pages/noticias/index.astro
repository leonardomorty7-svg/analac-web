---
// src/pages/noticias/index.astro
import BaseLayout from '../../layouts/BaseLayout.astro'
import { news } from '../../data/news'

const categories = ['Todas las publicaciones', ...new Set(news.map((n) => n.category))]
---

<BaseLayout
  title="Conocimiento Institucional | ANALAC"
  description="Actualidad, ciencia, consumo lácteo, investigación, biblioteca y memoria de eventos del sector lácteo colombiano."
>
  <!-- Hero Editorial Premium -->
  <section class="page-hero hero-dark fade-up" style="position: relative; padding: 200px 0 140px; min-height: 60vh; display: flex; align-items: center; background-color: var(--c-green-deep);">
    <div style="position: absolute; inset: 0; background-image: linear-gradient(rgba(10, 26, 12, 0.6), rgba(10, 26, 12, 0.9)), url('/images/hero-noticias-v2.jpg'); background-size: cover; background-position: center; z-index: 0;"></div>
    <div class="container" style="position: relative; z-index: 1; max-width: 900px; text-align: center; margin: 0 auto;">
      <p class="overline" style="color: var(--c-green-light); border-color: rgba(255,255,255,0.2); display: inline-block; margin-bottom: 24px;">Centro de Conocimiento</p>
      <h1 style="font-size: clamp(40px, 6vw, 64px); font-weight: 400; line-height: 1.1; letter-spacing: -0.02em; margin-bottom: 24px; color: #ffffff; text-wrap: balance;">
        Explora el conocimiento <span style="color: var(--c-green-light);">de ANALAC</span>
      </h1>
      <p style="font-size: 19px; color: rgba(255, 255, 255, 0.8); line-height: 1.6; max-width: 700px; margin: 0 auto; text-wrap: balance;">
        Actualidad, ciencia, recursos, biblioteca histórica y memoria de los eventos más relevantes del sector lácteo colombiano.
      </p>
    </div>
  </section>

  <!-- 6 Nodos de Conocimiento -->
  <section class="section fade-up" style="padding: 80px 0; background: #fdfdfc; border-bottom: 1px solid rgba(0,0,0,0.05);">
    <div class="container">
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 24px;">
        
        <!-- 1. Actualidad y análisis -->
        <a href="#actualidad" style="text-decoration: none;">
          <div style="background: #fff; border: 1px solid rgba(0,0,0,0.05); border-radius: 16px; padding: 32px; transition: transform 0.2s, box-shadow 0.2s; cursor: pointer; height: 100%; box-shadow: 0 4px 20px rgba(0,0,0,0.02);">
            <div style="display: flex; justify-content: space-between; margin-bottom: 20px;">
              <div style="width: 48px; height: 48px; border-radius: 12px; background: rgba(109,181,109,0.15); color: var(--c-green-deep); display: flex; align-items: center; justify-content: center;">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
              </div>
              <span style="font-size: 11px; font-weight: 600; padding: 4px 10px; border-radius: 100px; background: rgba(109,181,109,0.1); color: var(--c-green-deep);">Disponible</span>
            </div>
            <h3 style="font-size: 20px; font-weight: 500; color: var(--c-text); margin-bottom: 8px;">Actualidad y análisis</h3>
            <p style="font-size: 15px; color: var(--c-muted); line-height: 1.5; margin-bottom: 24px;">Noticias, comunicados, artículos, análisis y actualidad del sector.</p>
            <span style="font-size: 14px; font-weight: 500; color: var(--c-green-deep);">Leer noticias →</span>
          </div>
        </a>

        <!-- 2. Consumo Lácteo -->
        <a href="/consumo-lacteo" style="text-decoration: none;">
          <div style="background: #fff; border: 1px solid rgba(0,0,0,0.05); border-radius: 16px; padding: 32px; transition: transform 0.2s, box-shadow 0.2s; cursor: pointer; height: 100%; box-shadow: 0 4px 20px rgba(0,0,0,0.02);">
            <div style="display: flex; justify-content: space-between; margin-bottom: 20px;">
              <div style="width: 48px; height: 48px; border-radius: 12px; background: rgba(109,181,109,0.15); color: var(--c-green-deep); display: flex; align-items: center; justify-content: center;">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
              </div>
              <span style="font-size: 11px; font-weight: 600; padding: 4px 10px; border-radius: 100px; background: rgba(109,181,109,0.1); color: var(--c-green-deep);">Página Propia</span>
            </div>
            <h3 style="font-size: 20px; font-weight: 500; color: var(--c-text); margin-bottom: 8px;">Consumo Lácteo</h3>
            <p style="font-size: 15px; color: var(--c-muted); line-height: 1.5; margin-bottom: 24px;">Nutrición, ciencia, bienestar, recetas y recursos educativos.</p>
            <span style="font-size: 14px; font-weight: 500; color: var(--c-green-deep);">Ir a Consumo →</span>
          </div>
        </a>

        <!-- 3. Investigación y Ciencia -->
        <div style="background: #faf9f7; border: 1px solid rgba(0,0,0,0.03); border-radius: 16px; padding: 32px; opacity: 0.8; height: 100%;">
          <div style="display: flex; justify-content: space-between; margin-bottom: 20px;">
            <div style="width: 48px; height: 48px; border-radius: 12px; background: rgba(0,0,0,0.05); color: var(--c-muted); display: flex; align-items: center; justify-content: center;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path><path d="M2 12h20"></path></svg>
            </div>
            <span style="font-size: 11px; font-weight: 600; padding: 4px 10px; border-radius: 100px; background: rgba(0,0,0,0.05); color: var(--c-muted);">Próximamente</span>
          </div>
          <h3 style="font-size: 20px; font-weight: 500; color: var(--c-muted); margin-bottom: 8px;">Investigación y Ciencia</h3>
          <p style="font-size: 15px; color: var(--c-muted); line-height: 1.5;">Estudios, artículos científicos, evidencia y conocimiento técnico.</p>
        </div>

        <!-- 4. Guías y Recursos -->
        <div style="background: #faf9f7; border: 1px solid rgba(0,0,0,0.03); border-radius: 16px; padding: 32px; opacity: 0.8; height: 100%;">
          <div style="display: flex; justify-content: space-between; margin-bottom: 20px;">
            <div style="width: 48px; height: 48px; border-radius: 12px; background: rgba(0,0,0,0.05); color: var(--c-muted); display: flex; align-items: center; justify-content: center;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg>
            </div>
            <span style="font-size: 11px; font-weight: 600; padding: 4px 10px; border-radius: 100px; background: rgba(0,0,0,0.05); color: var(--c-muted);">Próximamente</span>
          </div>
          <h3 style="font-size: 20px; font-weight: 500; color: var(--c-muted); margin-bottom: 8px;">Guías y Recursos</h3>
          <p style="font-size: 15px; color: var(--c-muted); line-height: 1.5;">Manuales, orientaciones, infografías y contenidos prácticos.</p>
        </div>

        <!-- 5. Biblioteca y Publicaciones -->
        <div style="background: #faf9f7; border: 1px solid rgba(0,0,0,0.03); border-radius: 16px; padding: 32px; opacity: 0.8; height: 100%;">
          <div style="display: flex; justify-content: space-between; margin-bottom: 20px;">
            <div style="width: 48px; height: 48px; border-radius: 12px; background: rgba(0,0,0,0.05); color: var(--c-muted); display: flex; align-items: center; justify-content: center;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
            </div>
            <span style="font-size: 11px; font-weight: 600; padding: 4px 10px; border-radius: 100px; background: rgba(0,0,0,0.05); color: var(--c-muted);">Próximamente</span>
          </div>
          <h3 style="font-size: 20px; font-weight: 500; color: var(--c-muted); margin-bottom: 8px;">Biblioteca y Publicaciones</h3>
          <p style="font-size: 15px; color: var(--c-muted); line-height: 1.5;">Informes, boletines, cartillas, memorias y documentos institucionales.</p>
        </div>

        <!-- 6. Eventos y Memorias -->
        <a href="/noticias/eventos" style="text-decoration: none;">
          <div style="background: #fff; border: 1px solid rgba(0,0,0,0.05); border-radius: 16px; padding: 32px; transition: transform 0.2s, box-shadow 0.2s; cursor: pointer; height: 100%; box-shadow: 0 4px 20px rgba(0,0,0,0.02);">
            <div style="display: flex; justify-content: space-between; margin-bottom: 20px;">
              <div style="width: 48px; height: 48px; border-radius: 12px; background: rgba(109,181,109,0.15); color: var(--c-green-deep); display: flex; align-items: center; justify-content: center;">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="23 7 16 12 23 17 23 7"></polygon><rect x="1" y="5" width="15" height="14" rx="2" ry="2"></rect></svg>
              </div>
              <span style="font-size: 11px; font-weight: 600; padding: 4px 10px; border-radius: 100px; background: rgba(109,181,109,0.1); color: var(--c-green-deep);">Disponible</span>
            </div>
            <h3 style="font-size: 20px; font-weight: 500; color: var(--c-text); margin-bottom: 8px;">Eventos y Memorias</h3>
            <p style="font-size: 15px; color: var(--c-muted); line-height: 1.5; margin-bottom: 24px;">Seminarios, encuentros, videos, presentaciones y memorias del sector.</p>
            <span style="font-size: 14px; font-weight: 500; color: var(--c-green-deep);">Explorar memorias →</span>
          </div>
        </a>

      </div>
    </div>
  </section>

  <!-- Actualidad (Noticias existentes) -->
  <section id="actualidad" class="section" style="background: var(--color-bg-white); padding: 80px 0 120px;">
    <div class="container">
      <div class="section-header fade-up" style="margin-bottom: 48px;">
        <p class="overline">Archivo de Prensa</p>
        <h2 class="h2" style="font-size: 32px;">Actualidad y Análisis</h2>
      </div>

      <div style="display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 40px;" role="navigation" aria-label="Filtrar por categoría">
        {categories.map((cat) => (
          <a href={`/noticias${cat !== 'Todas las publicaciones' ? `?categoria=${cat}` : ''}`} class="filter-chip">
            {cat}
          </a>
        ))}
      </div>

      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px;">
        {news.map((item) => (
          <article class="news-card" style="background: var(--color-bg-white); border: 1px solid rgba(0,0,0,0.04); border-radius: 16px; overflow: hidden; box-shadow: 0 4px 20px rgba(0,0,0,0.02); display: flex; flex-direction: column;">
            <a href={`/noticias/${item.slug}`} style="display: flex; flex-direction: column; text-decoration: none; height: 100%;" aria-label={`Leer: ${item.title}`}>
              <div style="height: 220px; overflow: hidden; position: relative;">
                <img
                  src={item.imageUrl}
                  alt={item.imageAlt}
                  style="width: 100%; height: 100%; object-fit: cover;"
                  class="news-img"
                  loading="lazy"
                />
              </div>
              <div style="padding: 28px; display: flex; flex-direction: column; gap: 16px; flex: 1;">
                <div style="display: flex; gap: 12px; align-items: center;">
                  <span class="tag tag--filled" style="font-size: 11px;">{item.category}</span>
                  <time style="font-size: 11px; font-weight: 500; color: var(--color-text-sub); text-transform: uppercase; letter-spacing: 0.05em;" datetime={item.dateISO}>
                    {item.date}
                  </time>
                </div>
                <h3 style="font-size: 20px; font-weight: 500; letter-spacing: -0.01em; color: var(--color-text-main); line-height: 1.35;">
                  {item.title}
                </h3>
                <p style="font-size: 14px; color: var(--color-text-sub); line-height: 1.6;">
                  {item.excerpt}
                </p>
                <div style="margin-top: auto; padding-top: 20px; border-top: 1px solid rgba(0,0,0,0.05);">
                  <span class="link-underline" style="font-size: 13px; font-weight: 500; color: var(--color-green-dark);">Leer artículo →</span>
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .filter-chip {
    padding: 8px 20px;
    background: transparent;
    border: 1px solid rgba(0,0,0,0.1);
    border-radius: 100px;
    font-size: 14px;
    font-weight: 500;
    color: var(--color-text-sub);
    text-decoration: none;
    transition: all 0.2s ease;
  }
  .filter-chip:hover {
    background: var(--color-green-soft);
    border-color: var(--color-green-soft);
    color: var(--color-green-dark);
  }

  .news-card {
    transition: transform 0.4s ease, box-shadow 0.4s ease;
  }
  .news-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 16px 40px rgba(0,0,0,0.06) !important;
  }
  
  .news-img {
    transition: transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .news-card:hover .news-img {
    transform: scale(1.05);
  }

  @media (max-width: 992px) {
    div[style*="grid-template-columns: repeat(3, 1fr)"] { grid-template-columns: repeat(2, 1fr) !important; }
  }
  @media (max-width: 600px) {
    div[style*="grid-template-columns: repeat(2, 1fr)"] { grid-template-columns: 1fr !important; }
  }
</style>
