---
// src/pages/noticias/index.astro
import BaseLayout from '../../layouts/BaseLayout.astro'
import CienciaLacteaSection from '../../components/CienciaLacteaSection.astro'
---

<BaseLayout
  title="Conocimiento Institucional | ANALAC"
  description="Actualidad, ciencia, consumo lácteo, investigación, biblioteca y memoria de eventos del sector lácteo colombiano."
>
  <!-- Hero Editorial Premium -->
  <section class="page-hero hero-dark fade-up" style="position: relative; padding: 200px 0 140px; min-height: 60vh; display: flex; align-items: center; background-color: var(--c-green-deep);">
    <div style="position: absolute; inset: 0; background-image: linear-gradient(rgba(10, 26, 12, 0.6), rgba(10, 26, 12, 0.9)), url('/images/hero-noticias-v2.jpg'); background-size: cover; background-position: center; z-index: 0;"></div>
    <div class="container" style="position: relative; z-index: 1; max-width: 900px; text-align: center; margin: 0 auto;">
      <p class="overline" style="color: var(--c-green-light); border-color: rgba(255,255,255,0.2); display: inline-block; margin-bottom: 24px;">Centro de Conocimiento</p>
      <h1 style="font-size: clamp(40px, 6vw, 64px); font-weight: 400; line-height: 1.1; letter-spacing: -0.02em; margin-bottom: 24px; color: #ffffff; text-wrap: balance;">
        Explora el conocimiento <span style="color: var(--c-green-light);">de ANALAC</span>
      </h1>
      <p style="font-size: 19px; color: rgba(255, 255, 255, 0.8); line-height: 1.6; max-width: 700px; margin: 0 auto; text-wrap: balance;">
        Actualidad, ciencia, recursos, biblioteca histórica y memoria de los eventos más relevantes del sector lácteo colombiano.
      </p>
    </div>
  </section>

  <!-- 6 Nodos de Conocimiento -->
  <section id="conocimientoHub" class="section fade-up conocimiento-hub">
    <div class="container hub-heading">
      <p class="overline" style="color: #6db56d;">Explora por tema</p>
      <h2 class="h2" style="color: #ffffff; margin: 0;">Nodos de Conocimiento</h2>
    </div>

    <div class="hub-carousel" id="hubCarousel">
      <div class="hub-track" id="hubTrack">

        <!-- 1. Actualidad y análisis -->
        <a href="#actualidad" class="hub-card" style="background: #fff; border: 1px solid rgba(0,0,0,0.05); border-radius: 16px; padding: 32px; box-shadow: 0 4px 20px rgba(0,0,0,0.02); text-decoration: none;">
          <div style="display: flex; justify-content: space-between; margin-bottom: 20px;">
            <div style="width: 48px; height: 48px; border-radius: 12px; background: rgba(109,181,109,0.15); color: var(--c-green-deep); display: flex; align-items: center; justify-content: center;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
            </div>
            <span style="display: inline-flex; align-items: center; justify-content: center; line-height: 1; font-size: 11px; font-weight: 600; padding: 4px 10px; border-radius: 100px; background: rgba(109,181,109,0.1); color: var(--c-green-deep);">Disponible</span>
          </div>
          <h3 style="font-size: 20px; font-weight: 500; color: var(--c-text); margin-bottom: 8px;">Actualidad y análisis</h3>
          <p style="font-size: 15px; color: var(--c-muted); line-height: 1.5; margin-bottom: 24px;">Noticias, comunicados, artículos, análisis y actualidad del sector.</p>
          <span style="font-size: 14px; font-weight: 500; color: var(--c-green-deep);">Leer noticias →</span>
        </a>

        <!-- 2. Consumo Lácteo -->
        <a href="/consumo-lacteo" class="hub-card" style="background: #fff; border: 1px solid rgba(0,0,0,0.05); border-radius: 16px; padding: 32px; box-shadow: 0 4px 20px rgba(0,0,0,0.02); text-decoration: none;">
          <div style="display: flex; justify-content: space-between; margin-bottom: 20px;">
            <div style="width: 48px; height: 48px; border-radius: 12px; background: rgba(109,181,109,0.15); color: var(--c-green-deep); display: flex; align-items: center; justify-content: center;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
            </div>
            <span style="display: inline-flex; align-items: center; justify-content: center; line-height: 1; font-size: 11px; font-weight: 600; padding: 4px 10px; border-radius: 100px; background: rgba(109,181,109,0.1); color: var(--c-green-deep);">Página Propia</span>
          </div>
          <h3 style="font-size: 20px; font-weight: 500; color: var(--c-text); margin-bottom: 8px;">Consumo Lácteo</h3>
          <p style="font-size: 15px; color: var(--c-muted); line-height: 1.5; margin-bottom: 24px;">Nutrición, ciencia, bienestar, recetas y recursos educativos.</p>
          <span style="font-size: 14px; font-weight: 500; color: var(--c-green-deep);">Ir a Consumo →</span>
        </a>

        <!-- 3. Investigación y Ciencia -->
        <div class="hub-card" style="background: #faf9f7; border: 1px solid rgba(0,0,0,0.03); border-radius: 16px; padding: 32px;">
          <div style="display: flex; justify-content: space-between; margin-bottom: 20px;">
            <div style="width: 48px; height: 48px; border-radius: 12px; background: rgba(0,0,0,0.05); color: var(--c-muted); display: flex; align-items: center; justify-content: center;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path><path d="M2 12h20"></path></svg>
            </div>
            <span style="display: inline-flex; align-items: center; justify-content: center; line-height: 1; font-size: 11px; font-weight: 600; padding: 4px 10px; border-radius: 100px; background: rgba(0,0,0,0.05); color: var(--c-muted);">Próximamente</span>
          </div>
          <h3 style="font-size: 20px; font-weight: 500; color: var(--c-muted); margin-bottom: 8px;">Investigación y Ciencia</h3>
          <p style="font-size: 15px; color: var(--c-muted); line-height: 1.5;">Estudios, artículos científicos, evidencia y conocimiento técnico.</p>
        </div>

        <!-- 4. Guías y Recursos -->
        <div class="hub-card" style="background: #faf9f7; border: 1px solid rgba(0,0,0,0.03); border-radius: 16px; padding: 32px;">
          <div style="display: flex; justify-content: space-between; margin-bottom: 20px;">
            <div style="width: 48px; height: 48px; border-radius: 12px; background: rgba(0,0,0,0.05); color: var(--c-muted); display: flex; align-items: center; justify-content: center;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg>
            </div>
            <span style="display: inline-flex; align-items: center; justify-content: center; line-height: 1; font-size: 11px; font-weight: 600; padding: 4px 10px; border-radius: 100px; background: rgba(0,0,0,0.05); color: var(--c-muted);">Próximamente</span>
          </div>
          <h3 style="font-size: 20px; font-weight: 500; color: var(--c-muted); margin-bottom: 8px;">Guías y Recursos</h3>
          <p style="font-size: 15px; color: var(--c-muted); line-height: 1.5;">Manuales, orientaciones, infografías y contenidos prácticos.</p>
        </div>

        <!-- 5. Biblioteca y Publicaciones -->
        <div class="hub-card" style="background: #faf9f7; border: 1px solid rgba(0,0,0,0.03); border-radius: 16px; padding: 32px;">
          <div style="display: flex; justify-content: space-between; margin-bottom: 20px;">
            <div style="width: 48px; height: 48px; border-radius: 12px; background: rgba(0,0,0,0.05); color: var(--c-muted); display: flex; align-items: center; justify-content: center;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
            </div>
            <span style="display: inline-flex; align-items: center; justify-content: center; line-height: 1; font-size: 11px; font-weight: 600; padding: 4px 10px; border-radius: 100px; background: rgba(0,0,0,0.05); color: var(--c-muted);">Próximamente</span>
          </div>
          <h3 style="font-size: 20px; font-weight: 500; color: var(--c-muted); margin-bottom: 8px;">Biblioteca y Publicaciones</h3>
          <p style="font-size: 15px; color: var(--c-muted); line-height: 1.5;">Informes, boletines, cartillas, memorias y documentos institucionales.</p>
        </div>

        <!-- 6. Eventos y Memorias -->
        <a href="/noticias/eventos" class="hub-card" style="background: #fff; border: 1px solid rgba(0,0,0,0.05); border-radius: 16px; padding: 32px; box-shadow: 0 4px 20px rgba(0,0,0,0.02); text-decoration: none;">
          <div style="display: flex; justify-content: space-between; margin-bottom: 20px;">
            <div style="width: 48px; height: 48px; border-radius: 12px; background: rgba(109,181,109,0.15); color: var(--c-green-deep); display: flex; align-items: center; justify-content: center;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="23 7 16 12 23 17 23 7"></polygon><rect x="1" y="5" width="15" height="14" rx="2" ry="2"></rect></svg>
            </div>
            <span style="display: inline-flex; align-items: center; justify-content: center; line-height: 1; font-size: 11px; font-weight: 600; padding: 4px 10px; border-radius: 100px; background: rgba(109,181,109,0.1); color: var(--c-green-deep);">Disponible</span>
          </div>
          <h3 style="font-size: 20px; font-weight: 500; color: var(--c-text); margin-bottom: 8px;">Eventos y Memorias</h3>
          <p style="font-size: 15px; color: var(--c-muted); line-height: 1.5; margin-bottom: 24px;">Seminarios, encuentros, videos, presentaciones y memorias del sector.</p>
          <span style="font-size: 14px; font-weight: 500; color: var(--c-green-deep);">Explorar memorias →</span>
        </a>

      </div>
    </div>

    <div class="hub-dots" id="hubDots">
      <button type="button" class="hub-dot" data-index="0" aria-label="Ir a Actualidad y análisis"></button>
      <button type="button" class="hub-dot" data-index="1" aria-label="Ir a Consumo Lácteo"></button>
      <button type="button" class="hub-dot" data-index="2" aria-label="Ir a Investigación y Ciencia"></button>
      <button type="button" class="hub-dot" data-index="3" aria-label="Ir a Guías y Recursos"></button>
      <button type="button" class="hub-dot" data-index="4" aria-label="Ir a Biblioteca y Publicaciones"></button>
      <button type="button" class="hub-dot" data-index="5" aria-label="Ir a Eventos y Memorias"></button>
    </div>
  </section>

  <div id="actualidad">
    <CienciaLacteaSection />
  </div>

</BaseLayout>

<style>
  .conocimiento-hub {
    position: relative;
    padding: 80px 0;
    background-color: #040a05;
    overflow: hidden;
  }
  .conocimiento-hub::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 25% 30%, rgba(109, 181, 109, 0.14), transparent 50%),
                radial-gradient(circle at 80% 75%, rgba(109, 181, 109, 0.1), transparent 45%);
    z-index: 0;
  }
  .conocimiento-hub::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
                      linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse at center, black 10%, transparent 80%);
    -webkit-mask-image: radial-gradient(ellipse at center, black 10%, transparent 80%);
    z-index: 0;
  }

  /* Hub Heading */
  .hub-heading {
    position: relative;
    z-index: 2;
    text-align: center;
    margin-bottom: 48px;
  }

  /* Hub Track (mobile-first: simple grid, same as before) */
  .hub-carousel {
    position: relative;
    z-index: 2;
  }
  .hub-track {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 24px;
    max-width: 1280px;
    margin-inline: auto;
    padding-inline: 24px;
  }
  .hub-dots {
    display: none;
    position: relative;
    z-index: 2;
  }

  /* Desktop scroll-hijack carousel (see script at bottom of file) */
  @media (min-width: 900px) and (prefers-reduced-motion: no-preference) {
    .conocimiento-hub {
      height: 100vh;
      display: flex;
      flex-direction: column;
      padding-top: 148px;
      padding-bottom: 40px;
    }
    .hub-heading {
      flex-shrink: 0;
      margin-bottom: 40px;
    }
    .hub-carousel {
      flex: 1;
      display: flex;
      align-items: center;
      overflow: hidden;
      min-height: 0;
    }
    .hub-track {
      display: flex;
      gap: 32px;
      padding: 0;
      max-width: none;
      margin: 0;
      will-change: transform;
      transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .hub-track .hub-card {
      flex: 0 0 380px;
      width: 380px;
      transform: scale(0.94) rotate(0deg);
      opacity: 0.55;
      transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1),
        box-shadow 0.6s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.6s ease;
    }
    .hub-track .hub-card.is-active {
      transform: scale(1.06) translateY(-10px) rotate(0deg);
      opacity: 1;
      box-shadow: 0 32px 56px rgba(0, 0, 0, 0.14), 0 0 0 1px rgba(109, 181, 109, 0.18),
        0 0 40px rgba(109, 181, 109, 0.12) !important;
      border-color: rgba(109, 181, 109, 0.25) !important;
      z-index: 2;
    }
    .hub-track .hub-card.is-before {
      transform: scale(0.94) rotate(-7deg);
    }
    .hub-track .hub-card.is-after {
      transform: scale(0.94) rotate(7deg);
    }
    .hub-carousel .hub-card.is-active:hover {
      transform: scale(1.06) translateY(-10px) rotate(0deg);
    }
    .hub-carousel .hub-card.is-before:hover {
      transform: scale(0.94) rotate(-7deg);
    }
    .hub-carousel .hub-card.is-after:hover {
      transform: scale(0.94) rotate(7deg);
    }
    .hub-dots {
      display: flex;
      justify-content: center;
      gap: 10px;
      margin-top: 32px;
      flex-shrink: 0;
    }
    .hub-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.2);
      border: none;
      padding: 0;
      cursor: pointer;
      transition: background 0.3s ease, transform 0.3s ease;
    }
    .hub-dot.active {
      background: #6db56d;
      transform: scale(1.3);
    }
  }
</style>

<script>
  // Scroll-hijack carousel for "6 Nodos de Conocimiento".
  // Desktop-only (>=900px) and disabled entirely under prefers-reduced-motion.
  ;(function () {
    const section = document.getElementById('conocimientoHub')
    const carousel = document.getElementById('hubCarousel')
    const track = document.getElementById('hubTrack')
    const dotsWrap = document.getElementById('hubDots')
    if (!section || !carousel || !track || !dotsWrap) return

    const cards = Array.from(track.querySelectorAll('.hub-card'))
    const dots = Array.from(dotsWrap.querySelectorAll('.hub-dot'))
    const total = cards.length
    if (!total) return

    let activeIndex = 0
    let isAnimating = false
    let animTimer: number | undefined

    function isDesktopEnabled() {
      return (
        window.matchMedia('(min-width: 900px)').matches &&
        window.matchMedia('(prefers-reduced-motion: no-preference)').matches
      )
    }

    function layout() {
      const cardWidth = cards[0].getBoundingClientRect().width
      if (!cardWidth) return
      const trackStyle = getComputedStyle(track)
      const gap = parseFloat(trackStyle.columnGap || trackStyle.gap || '0') || 0
      const viewportWidth = carousel.clientWidth
      const offset = (viewportWidth - cardWidth) / 2 - activeIndex * (cardWidth + gap)
      track.style.transform = `translateX(${offset}px)`

      cards.forEach((card, i) => {
        card.classList.toggle('is-active', i === activeIndex)
        card.classList.toggle('is-before', i < activeIndex)
        card.classList.toggle('is-after', i > activeIndex)
      })
      dots.forEach((dot, i) => dot.classList.toggle('active', i === activeIndex))
    }

    function goTo(index: number) {
      const clamped = Math.max(0, Math.min(total - 1, index))
      if (clamped === activeIndex) return
      activeIndex = clamped
      isAnimating = true
      layout()
      window.clearTimeout(animTimer)
      animTimer = window.setTimeout(() => {
        isAnimating = false
      }, 600)
    }

    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => {
        if (!isAnimating) goTo(i)
      })
    })

    function isSectionPinned() {
      const rect = section.getBoundingClientRect()
      return Math.abs(rect.top) <= 100
    }

    function onWheel(e: WheelEvent) {
      if (!isDesktopEnabled()) return
      if (!isSectionPinned()) return

      const atFirst = activeIndex === 0
      const atLast = activeIndex === total - 1
      const goingDown = e.deltaY > 0
      const goingUp = e.deltaY < 0

      if (!goingDown && !goingUp) return
      // At a boundary and trying to go further out: release the hijack
      // so native page scroll continues into the next/previous section.
      if ((atFirst && goingUp) || (atLast && goingDown)) return

      e.preventDefault()
      e.stopImmediatePropagation()

      // Keep the section pixel-aligned to the viewport while hijacked.
      const rect = section.getBoundingClientRect()
      if (Math.abs(rect.top) > 2) {
        window.scrollTo({ top: window.scrollY + rect.top, behavior: 'auto' })
      }

      if (isAnimating) return

      if (goingDown) goTo(activeIndex + 1)
      else if (goingUp) goTo(activeIndex - 1)
    }

    window.addEventListener('wheel', onWheel, { passive: false, capture: true })
    window.addEventListener('resize', layout)
    layout()
  })()
</script>
