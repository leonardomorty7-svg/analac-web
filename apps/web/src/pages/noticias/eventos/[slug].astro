---
// src/pages/noticias/eventos/[slug].astro
import BaseLayout from '../../../layouts/BaseLayout.astro'
import { getSupabaseServer } from '../../../lib/supabase/server'

export async function getStaticPaths() {
  const supabase = getSupabaseServer(new Request('http://localhost'), { get: () => '', set: () => '', delete: () => '', has: () => false } as any)
  const { data } = await supabase.from('eventos').select('slug').eq('is_published', true)
  
  return (data || []).map((evento) => ({
    params: { slug: evento.slug },
  }))
}

const { slug } = Astro.params;
const supabase = getSupabaseServer(Astro.request, Astro.cookies)

const { data: evento, error } = await supabase
  .from('eventos')
  .select('*')
  .eq('slug', slug)
  .eq('is_published', true)
  .single()

if (error || !evento) {
  return Astro.redirect('/404')
}

const isSeminario = evento.type === 'seminario'
const title = evento.title
const year = evento.year
const location = evento.location
const dateStr = evento.event_date

// Optional fields
const videoUrl = evento.video_url
const presentationPdf = evento.presentation_pdf
const contentHtml = evento.content
---

<BaseLayout
  title={`${title} ${year} | Memoria de Evento | ANALAC`}
  description={evento.excerpt}
>
  <Fragment slot="head">
    <!-- Schema Markup AEO/SEO de Evento Pasado y Video -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Event",
      "name": `${title} ${year}`,
      "startDate": `${year}-01-01T08:00:00-05:00`,
      "endDate": `${year}-12-31T18:00:00-05:00`,
      "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
      "eventStatus": "https://schema.org/EventScheduled",
      "location": {
        "@type": "Place",
        "name": location,
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Colombia",
          "addressCountry": "CO"
        }
      },
      "description": evento.excerpt,
      "organizer": {
        "@type": "Organization",
        "name": "ANALAC",
        "url": "https://analac.org"
      }
    })}></script>
  </Fragment>

  <!-- Navegación Breadcrumb -->
  <div style="background: #fdfdfc; padding: 24px 0; border-bottom: 1px solid rgba(0,0,0,0.05); margin-top: 104px;">
    <div class="container" style="font-size: 13px; color: var(--c-muted); display: flex; gap: 8px;">
      <a href="/" style="color: inherit; text-decoration: none;">Inicio</a> /
      <a href="/noticias" style="color: inherit; text-decoration: none;">Conocimiento</a> /
      <a href="/noticias/eventos" style="color: inherit; text-decoration: none;">Eventos y Memorias</a> /
      <span style="color: var(--c-green-deep); font-weight: 500;">{title} {year}</span>
    </div>
  </div>

  <!-- Hero Evento -->
  <section class="section fade-up" style="padding: 64px 0 80px; background: #fff;">
    <div class="container" style="max-width: 1000px; text-align: center;">
      <p class="overline" style="color: var(--c-muted); margin-bottom: 16px;">Edición {year}</p>
      <h1 class="h1" style="font-size: clamp(36px, 5vw, 64px); margin-bottom: 24px; color: var(--color-text-main); line-height: 1.1; letter-spacing: -0.02em;">
        {title} <span style="color: var(--color-green-dark);">{year}</span>
      </h1>
      <p style="font-size: 18px; color: var(--color-text-sub); line-height: 1.6; max-width: 800px; margin: 0 auto 32px;">
        {evento.excerpt}
      </p>
      
      <div style="display: flex; gap: 32px; justify-content: center; align-items: center; font-size: 15px; color: var(--c-text); background: var(--c-cream); padding: 16px 32px; border-radius: 100px; width: fit-content; margin: 0 auto;">
        <span style="display: flex; align-items: center; gap: 8px;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
          {dateStr}
        </span>
        <span style="display: flex; align-items: center; gap: 8px;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
          {location}
        </span>
      </div>
    </div>
  </section>

  <!-- Video Principal Canónico (Solo si existe videoUrl) -->
  {videoUrl && (
    <section class="section" style="padding: 0 0 80px;">
      <div class="container" style="max-width: 1000px;">
        <div class="video-preview-card" id="open-video-btn" role="button" tabindex="0" aria-label="Reproducir video oficial del evento">
          <img src={evento.image_url} style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0.5;" alt="Cover" />
          <button class="video-play-button" tabindex="-1">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor" stroke="none"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
          </button>
        </div>
        <p style="text-align: center; font-size: 13px; color: var(--c-muted); margin-top: 16px;">
          Grabación oficial del evento
        </p>
      </div>
    </section>
  )}

  <!-- Temas, Agenda y Presentaciones -->
  <section class="section" style="padding: 80px 0; background: #faf9f7; border-top: 1px solid rgba(0,0,0,0.05);">
    <div class="container" style="max-width: 1000px;">
      
      <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 64px;">
        <!-- Contenido principal: Agenda y PDFs -->
        <div>
          <h2 class="h2" style="font-size: 28px; margin-bottom: 32px;">Memorias y Presentaciones</h2>
          <p style="font-size: 16px; color: var(--c-muted); line-height: 1.6; margin-bottom: 40px;">Contenido detallado y conclusiones del evento.</p>
          
          <div class="prose" style="max-width: 100%; margin-bottom: 40px;" set:html={contentHtml} />
          
          {presentationPdf && (
            <div style="display: flex; flex-direction: column; gap: 24px; margin-top: 40px; border-top: 1px solid rgba(0,0,0,0.1); padding-top: 40px;">
              <div style="display: flex; justify-content: space-between; align-items: center; padding: 24px; background: #fff; border: 1px solid rgba(0,0,0,0.05); border-radius: 16px;">
                <div>
                  <h4 style="font-size: 16px; font-weight: 500; color: var(--c-text); margin-bottom: 8px;">Presentación Oficial</h4>
                  <p style="font-size: 14px; color: var(--c-muted);">Material de apoyo del evento</p>
                </div>
                <a href={presentationPdf} target="_blank" rel="noopener noreferrer" class="btn btn--primary" style="background: var(--c-cream); color: var(--c-green-deep); border: 1px solid rgba(109,181,109,0.2);">
                  Descargar PDF
                </a>
              </div>
            </div>
          )}
        </div>

        <!-- Sidebar transversal -->
        <div>
          <!-- Relación con Observatorio -->
          <h3 style="font-size: 18px; font-weight: 500; margin-bottom: 24px; padding-bottom: 12px; border-bottom: 1px solid rgba(0,0,0,0.1);">Datos relacionados</h3>
          <a href="/informacion-sectorial" style="display: block; padding: 16px; background: rgba(109,181,109,0.05); border: 1px solid rgba(109,181,109,0.1); border-radius: 12px; text-decoration: none; color: var(--c-text);">
            <h4 style="font-size: 14px; font-weight: 600; color: var(--c-green-deep); margin-bottom: 8px;">Ir al Observatorio</h4>
            <p style="font-size: 13px; color: var(--c-muted); line-height: 1.4;">Consulta nuestros indicadores y panorama sectorial para más información.</p>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Modal de Video Funcional -->
  {videoUrl && (
    <dialog id="video-modal" class="video-modal" aria-labelledby="video-title">
      <div class="video-modal-backdrop" id="video-modal-backdrop"></div>
      <div class="video-modal-content">
        <div class="video-modal-header">
          <h2 id="video-title" class="sr-only">Reproducción del Evento</h2>
          <button id="close-video-btn" class="video-close-btn" aria-label="Cerrar video">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
          </button>
        </div>
        <div class="video-modal-body">
          <div class="iframe-container">
            <iframe 
              id="event-video-iframe"
              width="100%" 
              height="100%" 
              src=""
              data-src={videoUrl}
              title="Grabación Oficial del Evento" 
              frameborder="0" 
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
              allowfullscreen>
            </iframe>
          </div>
        </div>
      </div>
    </dialog>
  )}
</BaseLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const openBtn = document.getElementById('open-video-btn');
    const closeBtn = document.getElementById('close-video-btn');
    const modal = document.getElementById('video-modal') as HTMLDialogElement;
    const backdrop = document.getElementById('video-modal-backdrop');
    const iframe = document.getElementById('event-video-iframe') as HTMLIFrameElement;
    
    if (!modal || !iframe || !openBtn) return;
    
    const videoUrl = iframe.getAttribute('data-src');

    const openModal = () => {
      if (videoUrl) {
        // Automatically start playing if it's youtube (or append autoplay=1 if supported)
        const src = videoUrl.includes('?') ? `${videoUrl}&autoplay=1` : `${videoUrl}?autoplay=1`;
        iframe.src = src;
      }
      modal.showModal();
      document.body.style.overflow = 'hidden';
      const pse = document.getElementById('payment-pill');
      if (pse) pse.style.display = 'none';
    };

    const closeModal = () => {
      modal.close();
      iframe.src = ''; 
      document.body.style.overflow = '';
      const pse = document.getElementById('payment-pill');
      if (pse) pse.style.display = 'flex';
    };

    openBtn?.addEventListener('click', openModal);
    openBtn?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        openModal();
      }
    });

    closeBtn?.addEventListener('click', closeModal);
    backdrop?.addEventListener('click', closeModal);

    modal?.addEventListener('close', () => {
      iframe.src = '';
      document.body.style.overflow = '';
      const pse = document.getElementById('payment-pill');
      if (pse) pse.style.display = 'flex';
    });
  });
</script>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  .video-preview-card {
    aspect-ratio: 16/9; 
    background: #000; 
    border-radius: 24px; 
    overflow: hidden; 
    position: relative; 
    display: flex; 
    align-items: center; 
    justify-content: center;
    cursor: pointer;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  
  .video-preview-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 40px rgba(0,0,0,0.1);
  }

  .video-preview-card:focus-visible {
    outline: 4px solid var(--c-green);
    outline-offset: 4px;
  }

  .video-play-button {
    position: relative; 
    width: 80px; 
    height: 80px; 
    border-radius: 50%; 
    background: var(--c-green-deep); 
    border: none; 
    color: white; 
    display: flex; 
    align-items: center; 
    justify-content: center; 
    cursor: pointer; 
    transition: transform 0.2s;
  }

  .video-preview-card:hover .video-play-button {
    transform: scale(1.1);
    background: var(--c-green);
  }

  /* Modal de Video */
  .video-modal {
    padding: 0;
    border: none;
    border-radius: 16px;
    background: transparent;
    max-width: 100%;
    max-height: 100%;
    width: 100vw;
    height: 100vh;
    margin: 0;
  }

  .video-modal::backdrop {
    background: rgba(0, 0, 0, 0.9);
    backdrop-filter: blur(4px);
  }

  .video-modal-backdrop {
    position: fixed;
    inset: 0;
    z-index: -1;
  }

  .video-modal-content {
    display: flex;
    flex-direction: column;
    width: 100%;
    height: 100%;
    padding: 24px;
  }

  .video-modal-header {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 24px;
  }

  .video-close-btn {
    background: rgba(255,255,255,0.1);
    border: none;
    color: white;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s, transform 0.2s;
  }
  
  .video-close-btn:hover {
    background: rgba(255,255,255,0.2);
    transform: scale(1.05);
  }

  .video-close-btn:focus-visible {
    outline: 2px solid white;
    outline-offset: 2px;
  }

  .video-modal-body {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
  }

  .iframe-container {
    width: 100%;
    aspect-ratio: 16/9;
    background: #000;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 24px 64px rgba(0,0,0,0.5);
  }

  @media (max-width: 992px) {
    div[style*="grid-template-columns: 2fr 1fr"] { grid-template-columns: 1fr !important; }
  }
  @media (max-width: 768px) {
    div[style*="grid-template-columns: repeat(3, 1fr)"] { grid-template-columns: 1fr 1fr !important; }
    .video-modal-content { padding: 12px; }
    .video-close-btn { width: 40px; height: 40px; }
  }

  /* Prose Styles */
  .prose {
    font-size: 17px;
    line-height: 1.7;
    color: var(--c-text);
  }
  .prose p { margin-bottom: 1.5em; }
  .prose h2, .prose h3 {
    margin-top: 2em;
    margin-bottom: 1em;
    color: var(--c-text);
  }
  .prose ul, .prose ol {
    margin-bottom: 1.5em;
    padding-left: 1.5em;
  }
</style>
