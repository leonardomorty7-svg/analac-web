---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Gobernanza Institucional - ANALAC" description="Conoce la estructura de liderazgo y dirección estratégica de la Asociación Nacional de Productores de Leche.">
  
  <!-- Hero -->
  <header class="page-hero hero-dark fade-up">
    <div class="page-hero-bg"></div>
    <div class="container">
      <div class="page-hero-content">
        <h1 class="page-hero-title reveal" style="transition-delay: 150ms">Gobernanza Institucional</h1>
        <p class="page-hero-desc reveal" style="transition-delay: 300ms">Conoce la estructura de liderazgo, dirección y representación que impulsa el desarrollo estratégico de la Asociación Nacional de Productores de Leche.</p>
        <div class="hero-actions reveal" style="margin-top: 40px; display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; transition-delay: 450ms">
          <a href="/afiliate" class="btn btn--accent" style="padding: 14px 32px; font-size: 15px;">Conocer Afiliación</a>
          <a href="/servicios" class="btn btn--outline-white" style="padding: 14px 32px; font-size: 15px;">Servicios en Línea</a>
        </div>
      </div>
    </div>
  </header>

  <!-- Junta Directiva -->
  <section class="section" style="padding: 120px 0; background: var(--color-bg-page);">
    <div class="container">
      <div class="section-header text-center fade-up" style="max-width: 700px; margin: 0 auto 64px;">
        <p class="overline">Máxima Autoridad</p>
        <h2 class="h2">Junta Directiva</h2>
        <p style="font-size: 19px; color: var(--color-text-sub); margin-top: 16px;">Órgano colegiado elegido por la Asamblea General, responsable de establecer las políticas institucionales y velar por los intereses del gremio lechero a nivel nacional.</p>
      </div>

      <div class="equipo-grid fade-up">
        
        <div class="equipo-card-premium">
          <div style="position: relative; background: #eaf3ea;">
            <img src="/images/hero/hero-01.jpg" alt="[Placeholder]" class="equipo-img" style="aspect-ratio: 1; filter: grayscale(100%) opacity(0.2);" />
            <div style="position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 600; text-transform: uppercase; color: rgba(0,0,0,0.5);">[Foto Institucional]</div>
          </div>
          <div class="equipo-info">
            <h3 class="equipo-nombre">[Nombre del Directivo]</h3>
            <p class="equipo-cargo">Presidente</p>
            <p style="font-size: 14px; color: var(--color-text-main); margin-top: 12px; line-height: 1.5;">Representante nacional enfocado en la planeación estratégica y proyección del gremio.</p>
          </div>
        </div>

        <div class="equipo-card-premium">
          <div style="position: relative; background: #eaf3ea;">
            <img src="/images/hero/hero-02.jpg" alt="[Placeholder]" class="equipo-img" style="aspect-ratio: 1; filter: grayscale(100%) opacity(0.2);" />
            <div style="position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 600; text-transform: uppercase; color: rgba(0,0,0,0.5);">[Foto Institucional]</div>
          </div>
          <div class="equipo-info">
            <h3 class="equipo-nombre">[Nombre del Directivo]</h3>
            <p class="equipo-cargo">Vicepresidente</p>
            <p style="font-size: 14px; color: var(--color-text-main); margin-top: 12px; line-height: 1.5;">Acompaña y subroga a la presidencia en comisiones técnicas y gremiales.</p>
          </div>
        </div>

        <div class="equipo-card-premium">
          <div style="position: relative; background: #eaf3ea;">
            <img src="/images/hero/hero-03.jpg" alt="[Placeholder]" class="equipo-img" style="aspect-ratio: 1; filter: grayscale(100%) opacity(0.2);" />
            <div style="position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 600; text-transform: uppercase; color: rgba(0,0,0,0.5);">[Foto Institucional]</div>
          </div>
          <div class="equipo-info">
            <h3 class="equipo-nombre">[Nombre del Directivo]</h3>
            <p class="equipo-cargo">Secretario</p>
            <p style="font-size: 14px; color: var(--color-text-main); margin-top: 12px; line-height: 1.5;">Garante de actas, convocatorias y transparencia de la gestión organizacional.</p>
          </div>
        </div>

        <div class="equipo-card-premium">
          <div style="position: relative; background: #eaf3ea;">
            <img src="/images/hero/hero-01.jpg" alt="[Placeholder]" class="equipo-img" style="aspect-ratio: 1; filter: grayscale(100%) opacity(0.2);" />
            <div style="position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 600; text-transform: uppercase; color: rgba(0,0,0,0.5);">[Foto Institucional]</div>
          </div>
          <div class="equipo-info">
            <h3 class="equipo-nombre">[Nombre del Directivo]</h3>
            <p class="equipo-cargo">Vocal</p>
            <p style="font-size: 14px; color: var(--color-text-main); margin-top: 12px; line-height: 1.5;">Asesor estratégico y vocero de las diferentes regiones lecheras de Colombia.</p>
          </div>
        </div>

        <div class="equipo-card-premium">
          <div style="position: relative; background: #eaf3ea;">
            <img src="/images/hero/hero-02.jpg" alt="[Placeholder]" class="equipo-img" style="aspect-ratio: 1; filter: grayscale(100%) opacity(0.2);" />
            <div style="position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 600; text-transform: uppercase; color: rgba(0,0,0,0.5);">[Foto Institucional]</div>
          </div>
          <div class="equipo-info">
            <h3 class="equipo-nombre">[Nombre del Directivo]</h3>
            <p class="equipo-cargo">Vocal</p>
            <p style="font-size: 14px; color: var(--color-text-main); margin-top: 12px; line-height: 1.5;">Aportante técnico y supervisor del cumplimiento de objetivos gremiales.</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Dirección Ejecutiva -->
  <section class="section" style="padding: 120px 0; background: #ffffff;">
    <div class="container">
      <div class="section-header text-center fade-up" style="max-width: 600px; margin: 0 auto 64px;">
        <h2 class="h2">Dirección Ejecutiva</h2>
      </div>

      <div class="premium-panel fade-up executive-card">
        <div class="executive-image-wrapper">
          <img src="/images/hero/hero-03.jpg" alt="[Placeholder]" class="executive-img" />
          <div class="executive-overlay">[Foto Institucional]</div>
        </div>
        <div class="executive-content">
          <p style="color: var(--color-green-dark); font-weight: 600; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.05em; font-size: 14px;">Director Ejecutivo</p>
          <h3 class="h2" style="font-size: 32px; margin-bottom: 16px;">[Nombre del Director]</h3>
          <p style="font-size: 16px; color: var(--color-text-main); line-height: 1.6;">Lidera la ejecución de la estrategia institucional aprobada por la Junta Directiva. Representa legal y gremialmente a la Asociación ante las instancias gubernamentales, ministerios y empresas de la cadena láctea, asegurando que las políticas públicas beneficien a los productores de leche en todo el país.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Equipo Técnico -->
  <section class="section" style="padding: 120px 0; background: var(--color-bg-page);">
    <div class="container">
      <div class="section-header text-center fade-up" style="max-width: 600px; margin: 0 auto 64px;">
        <h2 class="h2">Equipo Técnico</h2>
        <p style="font-size: 19px; color: var(--color-text-sub); margin-top: 16px;">Profesionales dedicados a la investigación, legalidad y fomento del sector.</p>
      </div>

      <div class="mision-vision fade-up">
        
        <div class="equipo-card-premium" style="display: flex; text-align: left; background: #ffffff;">
          <div style="flex: 0 0 140px; position: relative; background: #eaf3ea;">
            <img src="/images/hero/hero-01.jpg" alt="[Placeholder]" style="width: 100%; height: 100%; object-fit: cover; filter: grayscale(100%) opacity(0.2);" />
            <div style="position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; font-size: 10px; font-weight: 600; text-transform: uppercase; color: rgba(0,0,0,0.4); text-align: center; padding: 10px;">[Foto]</div>
          </div>
          <div class="equipo-info" style="padding: 32px; flex: 1;">
            <div style="color: var(--color-green-dark); margin-bottom: 12px;">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg>
            </div>
            <h3 class="equipo-nombre" style="font-size: 20px; margin-bottom: 8px;">Área Técnica</h3>
            <p style="font-size: 14px; color: var(--color-text-main); line-height: 1.5; margin: 0;">Análisis agronómico, bienestar animal e indicadores de producción primaria para la optimización de fincas.</p>
          </div>
        </div>

        <div class="equipo-card-premium" style="display: flex; text-align: left; background: #ffffff;">
          <div style="flex: 0 0 140px; position: relative; background: #eaf3ea;">
            <img src="/images/hero/hero-02.jpg" alt="[Placeholder]" style="width: 100%; height: 100%; object-fit: cover; filter: grayscale(100%) opacity(0.2);" />
            <div style="position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; font-size: 10px; font-weight: 600; text-transform: uppercase; color: rgba(0,0,0,0.4); text-align: center; padding: 10px;">[Foto]</div>
          </div>
          <div class="equipo-info" style="padding: 32px; flex: 1;">
            <div style="color: var(--color-green-dark); margin-bottom: 12px;">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="12" y1="1" x2="12" y2="23"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
            </div>
            <h3 class="equipo-nombre" style="font-size: 20px; margin-bottom: 8px;">Área Económica</h3>
            <p style="font-size: 14px; color: var(--color-text-main); line-height: 1.5; margin: 0;">Monitoreo de precios, costos de insumos, evaluación de mercados e impacto económico del sector lácteo.</p>
          </div>
        </div>

        <div class="equipo-card-premium" style="display: flex; text-align: left; background: #ffffff;">
          <div style="flex: 0 0 140px; position: relative; background: #eaf3ea;">
            <img src="/images/hero/hero-03.jpg" alt="[Placeholder]" style="width: 100%; height: 100%; object-fit: cover; filter: grayscale(100%) opacity(0.2);" />
            <div style="position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; font-size: 10px; font-weight: 600; text-transform: uppercase; color: rgba(0,0,0,0.4); text-align: center; padding: 10px;">[Foto]</div>
          </div>
          <div class="equipo-info" style="padding: 32px; flex: 1;">
            <div style="color: var(--color-green-dark); margin-bottom: 12px;">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
            </div>
            <h3 class="equipo-nombre" style="font-size: 20px; margin-bottom: 8px;">Área Jurídica</h3>
            <p style="font-size: 14px; color: var(--color-text-main); line-height: 1.5; margin: 0;">Acompañamiento legal, normativas, conceptos regulatorios y revisión de resoluciones del Ministerio.</p>
          </div>
        </div>

        <div class="equipo-card-premium" style="display: flex; text-align: left; background: #ffffff;">
          <div style="flex: 0 0 140px; position: relative; background: #eaf3ea;">
            <img src="/images/hero/hero-01.jpg" alt="[Placeholder]" style="width: 100%; height: 100%; object-fit: cover; filter: grayscale(100%) opacity(0.2);" />
            <div style="position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; font-size: 10px; font-weight: 600; text-transform: uppercase; color: rgba(0,0,0,0.4); text-align: center; padding: 10px;">[Foto]</div>
          </div>
          <div class="equipo-info" style="padding: 32px; flex: 1;">
            <div style="color: var(--color-green-dark); margin-bottom: 12px;">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
            </div>
            <h3 class="equipo-nombre" style="font-size: 20px; margin-bottom: 8px;">Comunicaciones</h3>
            <p style="font-size: 14px; color: var(--color-text-main); line-height: 1.5; margin: 0;">Relacionamiento público, campañas de consumo lácteo, boletines y atención a asociados y aliados.</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Comités Institucionales -->
  <section class="section" style="padding: 120px 0; background: #ffffff;">
    <div class="container">
      <div class="section-header text-center fade-up" style="max-width: 600px; margin: 0 auto 64px;">
        <h2 class="h2">Comités Institucionales</h2>
        <p style="font-size: 19px; color: var(--color-text-sub); margin-top: 16px;">Mesas de trabajo especializadas para fortalecer cada eje del sector.</p>
      </div>

      <div class="mision-vision fade-up">
        
        <div class="mv-card premium-panel">
          <div class="mv-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline></svg>
          </div>
          <h3 class="h2" style="font-size: 24px;">Comité Técnico</h3>
          <p>Evalúa métricas sanitarias, genéticas y reproductivas. Genera lineamientos para la optimización de los hatos lecheros a nivel nacional.</p>
        </div>

        <div class="mv-card premium-panel">
          <div class="mv-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
          </div>
          <h3 class="h2" style="font-size: 24px;">Comité de Comercialización</h3>
          <p>Analiza canales de distribución, dinámicas de acopio, precios internacionales y fomento del consumo local de derivados lácteos.</p>
        </div>

        <div class="mv-card premium-panel">
          <div class="mv-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
          </div>
          <h3 class="h2" style="font-size: 24px;">Comité de Sostenibilidad</h3>
          <p>Impulsa prácticas de ganadería regenerativa, cuidado del agua, reforestación y reducción de emisiones de gases de efecto invernadero.</p>
        </div>

        <div class="mv-card premium-panel">
          <div class="mv-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
          </div>
          <h3 class="h2" style="font-size: 24px;">Comité de Innovación</h3>
          <p>Investiga la adopción de nuevas tecnologías agrotech, automatización de ordeño y digitalización de las unidades de producción primaria.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- Modelo de Gobernanza -->
  <section class="section" style="padding: 120px 0; background: var(--color-bg-page);">
    <div class="container">
      <div class="section-header text-center fade-up" style="max-width: 600px; margin: 0 auto 64px;">
        <h2 class="h2">Modelo de Gobernanza</h2>
        <p style="font-size: 19px; color: var(--color-text-sub); margin-top: 16px;">Flujo estructural representativo del gremio.</p>
      </div>

      <div class="timeline-premium fade-up">
        <div class="timeline-line"></div>
        
        <div class="timeline-item">
          <div class="timeline-dot"></div>
          <h3 class="timeline-year" style="font-size: 28px;">Asamblea General</h3>
          <p class="timeline-desc">Máxima autoridad conformada por todos los productores y miembros afiliados de ANALAC a nivel nacional.</p>
        </div>

        <div class="timeline-item">
          <div class="timeline-dot"></div>
          <h3 class="timeline-year" style="font-size: 28px;">Junta Directiva</h3>
          <p class="timeline-desc">Órgano de administración elegido por la asamblea, encargado de las directrices políticas y estratégicas.</p>
        </div>

        <div class="timeline-item">
          <div class="timeline-dot"></div>
          <h3 class="timeline-year" style="font-size: 28px;">Dirección Ejecutiva</h3>
          <p class="timeline-desc">Representación legal y ejecución del plan de acción gremial frente al Gobierno y la industria.</p>
        </div>

        <div class="timeline-item">
          <div class="timeline-dot"></div>
          <h3 class="timeline-year" style="font-size: 28px;">Equipo Técnico</h3>
          <p class="timeline-desc">Soporte profesional, investigación, estudios económicos y defensa de los intereses técnicos del sector.</p>
        </div>

        <div class="timeline-item">
          <div class="timeline-dot"></div>
          <h3 class="timeline-year" style="font-size: 28px;">Productores y Asociados</h3>
          <p class="timeline-desc">Beneficiarios finales de la representación gremial, base y motor de la producción lechera colombiana.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Final -->
  <section class="section" style="padding: 120px 0; background: #ffffff;">
    <div class="container text-center fade-up">
      <h2 class="h2" style="margin-bottom: 24px;">Construimos una asociación transparente y participativa.</h2>
      <p style="font-size: 19px; color: var(--color-text-main); line-height: 1.6; max-width: 700px; margin: 0 auto 40px;">La fortaleza institucional de ANALAC se fundamenta en una gobernanza sólida, representativa y orientada al desarrollo del sector lácteo colombiano.</p>
      
      <div class="cta-buttons" style="display: flex; gap: 16px; justify-content: center;">
        <a href="/servicios" class="btn btn--accent" style="padding: 14px 32px; font-size: 15px;">Conoce nuestros servicios</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* Hero */
  .page-hero.hero-dark {
    position: relative;
    padding: 200px 0 140px;
    min-height: 70vh;
    display: flex;
    align-items: center;
    background-color: #06150f;
  }
  .page-hero-bg {
    position: absolute;
    inset: 0;
    background-image: linear-gradient(rgba(6, 15, 7, 0.4), rgba(6, 15, 7, 0.8)), url('/images/hero-bg.jpg');
    background-size: cover;
    background-position: center;
    z-index: 0;
  }
  .page-hero-content {
    position: relative;
    z-index: 1;
    max-width: 900px;
    text-align: center;
    margin: 0 auto;
  }
  .page-hero-title {
    font-size: clamp(40px, 6vw, 64px);
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 24px;
    color: #ffffff;
    text-wrap: balance;
  }
  .page-hero-desc {
    font-size: 19px;
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.6;
    max-width: 700px;
    margin: 0 auto;
    text-wrap: balance;
  }
  .overline-light {
    color: var(--color-green-soft);
    border-color: rgba(255, 255, 255, 0.2);
  }

  /* Equipo / Junta Directiva */
  .equipo-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }
  .equipo-card-premium {
    background: #ffffff;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid rgba(0,0,0,0.04);
    box-shadow: 0 4px 20px rgba(0,0,0,0.02);
    transition: transform 0.4s ease;
  }
  .equipo-card-premium:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.04);
  }
  .equipo-img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    display: block;
  }
  .equipo-info {
    padding: 24px;
    text-align: center;
  }
  .equipo-nombre {
    font-size: 20px;
    font-weight: 500;
    color: var(--color-green-dark);
    margin-bottom: 4px;
  }
  .equipo-cargo {
    font-size: 15px;
    color: var(--color-text-sub);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Dirección Ejecutiva (Destacada) */
  .executive-card {
    display: flex;
    gap: 48px;
    align-items: center;
  }
  .executive-image-wrapper {
    flex: 0 0 350px;
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    background: #eaf3ea;
  }
  .executive-img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    filter: grayscale(100%) opacity(0.3);
    display: block;
  }
  .executive-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    color: rgba(0,0,0,0.4);
    pointer-events: none;
  }
  .executive-content {
    flex: 1;
  }

  /* Misión / Visión / Comités (2x2 cols) */
  .mision-vision {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
  }
  .premium-panel {
    background: #fdfaf5;
    padding: 64px;
    border-radius: 16px;
    border: 1px solid rgba(0,0,0,0.04);
    box-shadow: 0 4px 24px rgba(0,0,0,0.02);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s ease;
  }
  .premium-panel:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 48px rgba(0,0,0,0.06);
  }
  .mv-icon {
