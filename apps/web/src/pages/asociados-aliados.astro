---
// src/pages/aliados.astro
import BaseLayout from '../layouts/BaseLayout.astro'
import { allies } from '../data/allies'

const categories = [...new Set(allies.map((a) => a.category))]
---

<BaseLayout
  title="Asociados y aliados | ANALAC"
  description="Conoce el directorio de asociados, productores, empresas, cooperativas y aliados estratégicos del ecosistema lácteo colombiano."
>
  <!-- Hero -->
  <section style="background: var(--color-green-dark); padding-top: calc(72px + 64px); padding-bottom: 72px;">
    <div class="container">
      <p class="overline overline--light">Ecosistema</p>
      <h1 style="font-size: clamp(32px, 4vw, 48px); font-weight: 500; letter-spacing: -0.02em; color: #fff; margin-top: 12px; line-height: 1.15; max-width: 520px;">
        Directorio del<br />ecosistema lácteo
      </h1>
      <p style="color: rgba(255,255,255,0.5); font-size: 14px; max-width: 480px; margin-top: 16px; line-height: 1.7;">
        Trabajamos en alianza con entidades gubernamentales, gremios, organismos 
        internacionales y socios financieros para fortalecer el sector lácteo colombiano.
      </p>
    </div>
  </section>

  <!-- Filtros de categoría -->
  <section style="background: var(--color-bg-white); border-bottom: var(--border-subtle); padding-block: 20px;">
    <div class="container" style="display: flex; align-items: center; gap: 8px; flex-wrap: wrap;">
      <span style="font-size: 12px; color: var(--color-text-light); margin-right: 4px;">Categoría:</span>
      <a href="/aliados" class="tag" style="font-size: 12px;">Todos</a>
      {categories.map((cat) => (
        <a href={`/aliados#${cat.toLowerCase()}`} class="tag" style="font-size: 12px;">{cat}</a>
      ))}
    </div>
  </section>

  <!-- Grid de aliados -->
  <section class="section" style="background: var(--color-bg-page);">
    <div class="container">
      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px;">
        {allies.map((ally) => (
          <article
            id={ally.category.toLowerCase()}
            style="background: var(--color-bg-white); border: var(--border-subtle); border-radius: var(--radius-card); padding: 28px; display: flex; flex-direction: column; gap: 14px;"
          >
            <!-- Logo placeholder -->
            <div style="width: 48px; height: 48px; border-radius: 8px; background: var(--color-green-soft); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
              <span style="font-size: 11px; font-weight: 600; color: var(--color-green-mid); letter-spacing: 0.05em;">
                {ally.name.slice(0, 2).toUpperCase()}
              </span>
            </div>

            <div style="display: flex; flex-direction: column; gap: 6px; flex: 1;">
              <div style="display: flex; align-items: baseline; justify-content: space-between; gap: 8px;">
                <h3 style="font-size: 15px; font-weight: 500; color: var(--color-text-main);">{ally.name}</h3>
                <span class="tag" style="font-size: 10px; flex-shrink: 0;">{ally.category}</span>
              </div>
              <p style="font-size: 13px; color: var(--color-text-sub); line-height: 1.6;">{ally.description}</p>
            </div>

            {ally.url && (
              <a
                href={ally.url}
                class="link-underline"
                style="font-size: 12px;"
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`Visitar sitio web de ${ally.name}`}
              >
                Sitio web →
              </a>
            )}
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section style="background: var(--color-bg-page); border-top: var(--border-subtle); padding-block: 64px; text-align: center;">
    <div class="container" style="max-width: 540px;">
      <p class="overline">¿Tu organización quiere aliarse?</p>
      <h2 class="h2" style="margin-top: 12px; margin-bottom: 16px;">Conviértete en aliado de ANALAC</h2>
      <p style="font-size: 14px; color: var(--color-text-sub); line-height: 1.7; margin-bottom: 32px;">
        Si representas una entidad o empresa que trabaja por el desarrollo 
        del sector lácteo colombiano, escríbenos.
      </p>
      <a href="/contacto" class="btn btn--primary">Contactar ANALAC →</a>
    </div>
  </section>
</BaseLayout>

<style>
  @media (max-width: 768px) {
    div[style*="grid-template-columns: repeat(3, 1fr)"] { grid-template-columns: repeat(2, 1fr) !important; }
  }
  @media (max-width: 500px) {
    div[style*="grid-template-columns: repeat(3, 1fr)"] { grid-template-columns: 1fr !important; }
  }
</style>
