---
import AdminLayout from '../../../layouts/AdminLayout.astro';
export const prerender = false;

const { user, supabase } = Astro.locals;
if (!user) return Astro.redirect('/admin-analac/iniciar-sesion');

const { data: admin } = await supabase.from('admin_users').select('*').eq('id', user.id).single();
if (!admin) return Astro.redirect('/admin-analac/iniciar-sesion');

// Obtener todas las revisiones (podemos añadir paginación después)
// Hacemos un join con organization_profiles para obtener el slug y nombre actual (si existe)
const { data: revisions, error } = await supabase
  .from('profile_revisions')
  .select(`
    id,
    organization_id,
    status,
    completion_score,
    created_at,
    submitted_at,
    organization_profiles (
      name,
      slug
    )
  `)
  .order('submitted_at', { ascending: false });

// Mapeo de estados
const statusMap: Record<string, { label: string, color: string }> = {
  'draft': { label: 'Borrador', color: '#94a3b8' },
  'pending_review': { label: 'En Revisión', color: '#f59e0b' },
  'changes_requested': { label: 'Ajustes Solicitados', color: '#3b82f6' },
  'approved': { label: 'Aprobado', color: '#10b981' },
  'rejected': { label: 'Rechazado', color: '#ef4444' },
  'published': { label: 'Publicado', color: '#6366f1' }
};

---

<AdminLayout title="Bandeja de Moderación" adminName={admin.name} adminRole={admin.role}>
  
  <div style="background: white; border-radius: 12px; border: 1px solid #e2e8f0; overflow: hidden;">
    <div style="padding: 20px; border-bottom: 1px solid #e2e8f0; display: flex; justify-content: space-between; align-items: center;">
      <h2 style="margin: 0; font-size: 16px; font-weight: 600;">Revisiones Recientes</h2>
      <div style="display: flex; gap: 8px;">
        <input type="text" placeholder="Buscar..." style="padding: 8px 12px; border: 1px solid #cbd5e1; border-radius: 6px; outline: none; font-size: 14px;" />
        <select style="padding: 8px 12px; border: 1px solid #cbd5e1; border-radius: 6px; outline: none; font-size: 14px;">
          <option value="">Todos los Estados</option>
          <option value="pending_review">En Revisión</option>
          <option value="approved">Aprobados</option>
        </select>
      </div>
    </div>

    {error ? (
      <div style="padding: 24px; color: #ef4444;">Error cargando revisiones: {error.message}</div>
    ) : revisions && revisions.length > 0 ? (
      <table style="width: 100%; border-collapse: collapse; text-align: left;">
        <thead>
          <tr style="background: #f8fafc; border-bottom: 1px solid #e2e8f0;">
            <th style="padding: 16px 20px; font-size: 13px; font-weight: 600; color: #64748b;">Organización</th>
            <th style="padding: 16px 20px; font-size: 13px; font-weight: 600; color: #64748b;">Enviado el</th>
            <th style="padding: 16px 20px; font-size: 13px; font-weight: 600; color: #64748b;">Completitud</th>
            <th style="padding: 16px 20px; font-size: 13px; font-weight: 600; color: #64748b;">Estado</th>
            <th style="padding: 16px 20px; font-size: 13px; font-weight: 600; color: #64748b;">Acciones</th>
          </tr>
        </thead>
        <tbody>
          {revisions.map((rev: any) => {
            const statusInfo = statusMap[rev.status] || { label: rev.status, color: '#000' };
            const orgName = rev.organization_profiles?.name || 'Organización Desconocida';
            const date = rev.submitted_at ? new Date(rev.submitted_at).toLocaleDateString() : 'N/A';
            
            return (
              <tr style="border-bottom: 1px solid #e2e8f0;">
                <td style="padding: 16px 20px; font-size: 14px; font-weight: 500; color: #0f172a;">{orgName}</td>
                <td style="padding: 16px 20px; font-size: 14px; color: #475569;">{date}</td>
                <td style="padding: 16px 20px; font-size: 14px; color: #475569;">
                  <div style="display: flex; align-items: center; gap: 8px;">
                    <div style="width: 60px; height: 6px; background: #e2e8f0; border-radius: 3px; overflow: hidden;">
                      <div style={`width: ${rev.completion_score}%; height: 100%; background: ${rev.completion_score >= 80 ? '#10b981' : '#f59e0b'};`}></div>
                    </div>
                    <span style="font-size: 12px; font-weight: 600;">{rev.completion_score}%</span>
                  </div>
                </td>
                <td style="padding: 16px 20px;">
                  <span style={`background: ${statusInfo.color}15; color: ${statusInfo.color}; padding: 4px 12px; border-radius: 20px; font-size: 12px; font-weight: 600;`}>
                    {statusInfo.label}
                  </span>
                </td>
                <td style="padding: 16px 20px;">
                  <a href={`/admin-analac/directorio/${rev.id}`} style="color: #38bdf8; text-decoration: none; font-size: 14px; font-weight: 600;">Revisar →</a>
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    ) : (
      <div style="padding: 40px; text-align: center; color: #64748b;">
        No hay revisiones para mostrar.
      </div>
    )}
  </div>

</AdminLayout>
