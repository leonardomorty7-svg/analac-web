---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Afíliate - ANALAC" description="Conoce los beneficios de pertenecer a la Asociación Nacional de Productores de Leche.">
  
  <!-- Hero -->
  <header class="page-hero hero-dark fade-up">
    <div class="page-hero-bg"></div>
    <div class="container">
      <div class="page-hero-content">
        <h1 class="page-hero-title reveal" style="transition-delay: 150ms">Haz parte de ANALAC</h1>
        <p class="page-hero-desc reveal" style="transition-delay: 300ms">Únete a la Asociación Nacional de Productores de Leche y accede a información estratégica, representación gremial, formación especializada y una red nacional de aliados comprometidos con el fortalecimiento del sector lácteo colombiano.</p>
        <div class="hero-actions reveal" style="margin-top: 40px; display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; transition-delay: 450ms">
          <a href="#proceso" class="btn btn--accent" style="padding: 14px 32px; font-size: 15px;">Solicita tu afiliación</a>
          <a href="#beneficios" class="btn btn--outline-white" style="padding: 14px 32px; font-size: 15px;">Conoce nuestros beneficios</a>
        </div>
      </div>
    </div>
  </header>

  <!-- ¿Por qué afiliarse? -->
  <section class="section" id="beneficios" style="padding: 120px 0; background: var(--color-bg-page);">
    <div class="container">
      <div class="section-header text-center fade-up" style="max-width: 600px; margin: 0 auto 64px;">
        <p class="overline">Beneficios</p>
        <h2 class="h2">¿Por qué afiliarse?</h2>
      </div>
      
      <div class="valores-grid fade-up">
        <div class="valor-card">
          <div class="valor-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
          </div>
          <div>
            <h3 class="valor-title">Representación gremial</h3>
            <p style="font-size: 14px; color: var(--color-text-main); margin-top: 8px; line-height: 1.5;">Defensa de los intereses de los productores de leche ante entidades gubernamentales y privadas.</p>
          </div>
        </div>

        <div class="valor-card">
          <div class="valor-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="3" y1="9" x2="21" y2="9"></line><line x1="9" y1="21" x2="9" y2="9"></line></svg>
          </div>
          <div>
            <h3 class="valor-title">Información sectorial exclusiva</h3>
            <p style="font-size: 14px; color: var(--color-text-main); margin-top: 8px; line-height: 1.5;">Acceso prioritario a noticias, reportes y boletines técnicos con información clave para tu negocio.</p>
          </div>
        </div>

        <div class="valor-card">
          <div class="valor-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="18" y1="20" x2="18" y2="10"></line><line x1="12" y1="20" x2="12" y2="4"></line><line x1="6" y1="20" x2="6" y2="14"></line></svg>
          </div>
          <div>
            <h3 class="valor-title">Estudios e indicadores técnicos</h3>
            <p style="font-size: 14px; color: var(--color-text-main); margin-top: 8px; line-height: 1.5;">Análisis de mercados, proyecciones de consumo y métricas para apoyar la toma de decisiones.</p>
          </div>
        </div>

        <div class="valor-card">
          <div class="valor-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg>
          </div>
          <div>
            <h3 class="valor-title">Formación y capacitación</h3>
            <p style="font-size: 14px; color: var(--color-text-main); margin-top: 8px; line-height: 1.5;">Programas académicos, seminarios y talleres de actualización en prácticas lecheras.</p>
          </div>
        </div>

        <div class="valor-card">
          <div class="valor-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
          </div>
          <div>
            <h3 class="valor-title">Eventos y relacionamiento</h3>
            <p style="font-size: 14px; color: var(--color-text-main); margin-top: 8px; line-height: 1.5;">Oportunidades de networking con otros productores, entidades aliadas y proveedores.</p>
          </div>
        </div>

        <div class="valor-card">
          <div class="valor-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
          </div>
          <div>
            <h3 class="valor-title">Fortalecimiento del sector lácteo</h3>
            <p style="font-size: 14px; color: var(--color-text-main); margin-top: 8px; line-height: 1.5;">Aportamos activamente a campañas orientadas a fomentar el consumo nacional de leche y derivados.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ¿Quién puede afiliarse? -->
  <section class="section" style="padding: 120px 0; background: #ffffff;">
    <div class="container">
      <div class="section-header text-center fade-up" style="max-width: 600px; margin: 0 auto 64px;">
        <h2 class="h2">¿Quién puede afiliarse?</h2>
        <p style="font-size: 19px; color: var(--color-text-sub); margin-top: 16px;">El gremio lechero acoge a diversos actores que contribuyen al ecosistema productor de Colombia.</p>
      </div>

      <div class="mision-vision fade-up">
        
        <div class="mv-card premium-panel">
          <div class="mv-icon">
             <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
          </div>
          <h3 class="h2" style="font-size: 24px;">Productores de leche</h3>
          <p>Personas naturales dedicadas a la actividad lechera que buscan respaldo gremial, información técnica y desarrollo sostenible para sus fincas.</p>
        </div>

        <div class="mv-card premium-panel">
          <div class="mv-icon">
             <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 12V7H5a2 2 0 0 1 0-4h14v4"/><path d="M3 5v14a2 2 0 0 0 2 2h16v-5"/><path d="M18 12a2 2 0 0 0 0 4h4v-4Z"/></svg>
          </div>
          <h3 class="h2" style="font-size: 24px;">Empresas del sector</h3>
          <p>Organizaciones ganaderas y sociedades comerciales orientadas a la producción y procesamiento primario de derivados lácteos a gran escala.</p>
        </div>

        <div class="mv-card premium-panel">
          <div class="mv-icon">
             <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3zM7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"></path></svg>
          </div>
          <h3 class="h2" style="font-size: 24px;">Aliados estratégicos</h3>
          <p>Proveedores de insumos, servicios veterinarios, maquinaria e innovación tecnológica que fortalecen la operación de nuestros asociados.</p>
        </div>

        <div class="mv-card premium-panel">
          <div class="mv-icon">
             <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 21h18"></path><path d="M4 21v-4"></path><path d="M20 21v-4"></path><path d="M12 2v10"></path><path d="M12 2l-3 3"></path><path d="M12 2l3 3"></path><path d="M8 17h8"></path></svg>
          </div>
          <h3 class="h2" style="font-size: 24px;">Instituciones relacionadas</h3>
          <p>Entidades académicas, centros de investigación y cooperativas enfocadas en el desarrollo agropecuario y la ciencia láctea nacional.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- Proceso de afiliación -->
  <section class="section" id="proceso" style="padding: 120px 0; background: var(--color-bg-page);">
    <div class="container">
      <div class="section-header text-center fade-up" style="max-width: 600px; margin: 0 auto 64px;">
        <h2 class="h2">Proceso de afiliación</h2>
        <p style="font-size: 19px; color: var(--color-text-sub); margin-top: 16px;">Comienza tu ruta hacia el gremio de manera estructurada y ágil.</p>
      </div>

      <div class="timeline-premium fade-up">
        <div class="timeline-line"></div>
        
        <div class="timeline-item">
          <div class="timeline-dot"></div>
          <h3 class="timeline-year" style="font-size: 28px;">1. Solicitud</h3>
          <p class="timeline-desc">Envío del formulario de afiliación con los datos básicos del productor, la finca y la ubicación.</p>
        </div>

        <div class="timeline-item">
          <div class="timeline-dot"></div>
          <h3 class="timeline-year" style="font-size: 28px;">2. Validación</h3>
          <p class="timeline-desc">Revisión de los documentos anexos (cédula, registro RUT o Cámara de Comercio y certificado ICA) por parte del equipo administrativo.</p>
        </div>

        <div class="timeline-item">
          <div class="timeline-dot"></div>
          <h3 class="timeline-year" style="font-size: 28px;">3. Aprobación</h3>
          <p class="timeline-desc">Validación final de la solicitud por parte del comité gremial de ANALAC y notificación al nuevo afiliado.</p>
        </div>

        <div class="timeline-item">
          <div class="timeline-dot"></div>
          <h3 class="timeline-year" style="font-size: 28px;">4. Activación</h3>
          <p class="timeline-desc">Registro en la base de datos, acceso al portal institucional de beneficios y cobro de la primera cuota de sostenimiento.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Final -->
  <section class="section" style="padding: 120px 0; background: #ffffff;">
    <div class="container text-center fade-up">
      <h2 class="h2" style="margin-bottom: 24px;">Construyamos juntos el futuro del sector lácteo colombiano.</h2>
      <p style="font-size: 19px; color: var(--color-text-main); line-height: 1.6; max-width: 700px; margin: 0 auto 40px;">Nuestro equipo está preparado para acompañarte durante el proceso de afiliación y mostrarte todos los beneficios de pertenecer a ANALAC.</p>
      
      <div class="cta-buttons" style="display: flex; gap: 16px; justify-content: center; margin-bottom: 40px;">
        <a href="mailto:contacto@analac.org" class="btn btn--accent" style="padding: 14px 32px; font-size: 15px;">Quiero afiliarme</a>
      </div>

      <div style="background: #eaf3ea; display: inline-block; padding: 16px 32px; border-radius: 100px;">
        <p style="font-size: 14px; color: var(--color-green-dark); font-weight: 500; margin: 0;">Próximamente este proceso podrá realizarse completamente en línea.</p>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* Hero */
  .page-hero.hero-dark {
    position: relative;
    padding: 200px 0 140px;
    min-height: 70vh;
    display: flex;
    align-items: center;
    background-color: #06150f;
  }
  .page-hero-bg {
    position: absolute;
    inset: 0;
    background-image: linear-gradient(rgba(6, 15, 7, 0.4), rgba(6, 15, 7, 0.8)), url('/images/hero-bg.jpg');
    background-size: cover;
    background-position: center;
    z-index: 0;
  }
  .page-hero-content {
    position: relative;
    z-index: 1;
    max-width: 900px;
    text-align: center;
    margin: 0 auto;
  }
  .page-hero-title {
    font-size: clamp(40px, 6vw, 64px);
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 24px;
    color: #ffffff;
    text-wrap: balance;
  }
  .page-hero-desc {
    font-size: 19px;
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.6;
    max-width: 700px;
    margin: 0 auto;
    text-wrap: balance;
  }
  .overline-light {
    color: var(--color-green-soft);
    border-color: rgba(255, 255, 255, 0.2);
  }

  /* Valores Institucionales (3 cols) */
  .valores-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .valor-card {
    background: #ffffff;
    border: 1px solid rgba(0,0,0,0.05);
    border-radius: 12px;
    padding: 32px;
    display: flex;
    align-items: flex-start;
    gap: 16px;
    transition: background 0.2s ease;
  }
  .valor-card:hover {
    background: #eaf3ea;
  }
  .valor-icon {
    color: var(--color-green-dark);
    flex-shrink: 0;
  }
  .valor-title {
    font-size: 18px;
    font-weight: 500;
    color: var(--color-green-dark);
    margin: 0;
  }

  /* Misión / Visión (2x2 cols) */
  .mision-vision {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
  }
  .premium-panel {
    background: #fdfaf5;
    padding: 64px;
    border-radius: 16px;
    border: 1px solid rgba(0,0,0,0.04);
    box-shadow: 0 4px 24px rgba(0,0,0,0.02);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s ease;
  }
  .premium-panel:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 48px rgba(0,0,0,0.06);
  }
  .mv-icon {
    width: 56px;
    height: 56px;
    border-radius: 12px;
    background: #eaf3ea;
    color: var(--color-green-dark);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 32px;
  }
  .premium-panel p {
    font-size: 19px;
    line-height: 1.6;
    color: var(--color-text-main);
  }

  /* Timeline Premium */
  .timeline-premium {
    position: relative;
    max-width: 800px;
    margin: 0 auto;
  }
  .timeline-line {
    position: absolute;
    left: 24px;
    top: 0;
    bottom: 0;
    width: 1px;
    background: rgba(0,0,0,0.1);
  }
  .timeline-item {
    position: relative;
    padding-left: 80px;
    padding-bottom: 64px;
  }
  .timeline-dot {
    position: absolute;
    left: 17px;
    top: 8px;
    width: 15px;
    height: 15px;
    border-radius: 50%;
    background: var(--color-bg-page);
    border: 2px solid var(--color-green-dark);
    box-shadow: 0 0 0 8px #ffffff;
    transition: all 0.3s ease;
  }
  .timeline-item:hover .timeline-dot {
    background: var(--color-green-dark);
    transform: scale(1.2);
    box-shadow: 0 0 0 8px #eaf3ea;
  }
  .timeline-year {
    font-weight: 300;
    color: var(--color-green-dark);
    margin-bottom: 12px;
    line-height: 1;
  }
  .timeline-desc {
    font-size: 19px;
    color: var(--color-text-main);
    line-height: 1.6;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .mision-vision { grid-template-columns: 1fr; }
    .valores-grid { grid-template-columns: 1fr; }
    .timeline-premium .timeline-item { padding-left: 48px; }
    .timeline-premium .timeline-line { left: 12px; }
    .timeline-premium .timeline-dot { left: 5px; }
  }
</style>
