---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Aviso Legal | ANALAC" description="Aviso Legal de la Asociación Nacional de Productores de Leche de Colombia.">
  <main style="padding: 140px 20px 80px; max-width: 800px; margin: 0 auto; min-height: 80vh;">
    <h1 class="h1">Aviso Legal</h1>
    <p style="margin-top: 20px; color: var(--c-muted); line-height: 1.8; font-size: 18px;">
      El presente documento establece las condiciones de uso de la plataforma digital de ANALAC.
      Esta información se encuentra en proceso de validación institucional y será actualizada próximamente.
    </p>
  </main>
</BaseLayout>
