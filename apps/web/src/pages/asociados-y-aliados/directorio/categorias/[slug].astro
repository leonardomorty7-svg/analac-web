---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import OrganizationCard from '../../../../components/directorio/OrganizationCard';
import { getSupabaseServer } from '../../../../lib/supabase/server';

export const prerender = false;

const { slug } = Astro.params;

const supabase = getSupabaseServer(Astro.request, Astro.cookies);

// Obtener detalles de la categoría
const { data: category, error: catError } = await supabase
  .from('categories')
  .select('*')
  .eq('slug', slug)
  .single();

if (catError || !category) {
  return Astro.redirect('/404');
}

// Obtener perfiles que pertenezcan a la categoría y estén publicados
const { data: orgsData, error: orgsError } = await supabase
  .from('organization_categories')
  .select(`
    organization_id,
    organizations!inner (
      name,
      slug,
      org_type,
      status,
      verified,
      organization_profiles!inner (
        logo_url,
        summary,
        description,
        products_summary ( name ),
        faqs ( question, answer )
      ),
      locations ( city, department )
    )
  `)
  .eq('category_id', category.id);

if (orgsError) {
  console.error("Error fetching orgs for category:", orgsError);
}

const publishedOrgs = orgsData?.map((item: any) => {
  const org = item.organizations;
  const profile = org.organization_profiles[0];
  const loc = org.locations && org.locations.length > 0 ? org.locations[0] : null;
  return {
    id: item.organization_id,
    slug: org.slug,
    name: org.name,
    type: org.org_type,
    category: category.name,
    status: org.status,
    verified: org.verified,
    logo: profile?.logo_url,
    location: loc ? { city: loc.city, department: loc.department } : undefined,
    summary: profile?.summary
  };
}) || [];

// Regla SEO (Thin Content): Evaluar indexabilidad
let shouldNoIndex = false;

if (publishedOrgs.length === 0) {
  return Astro.redirect('/404');
}

const hasRichContext = category.description && category.description.trim().length > 100;

if (publishedOrgs.length === 1 && !hasRichContext) {
  shouldNoIndex = true;
} else if (publishedOrgs.length > 1 && !hasRichContext) {
  // Opcional: si hay varias pero cero contexto, podríamos no indexar.
  // Pero generalmente 2+ tarjetas sí aportan listado válido. Lo dejaremos como indexable pero documentaremos.
  shouldNoIndex = false; 
}

// SEO Props
const title = `Empresas de ${category.name} en Colombia | ANALAC`;
const description = category.description || `Encuentra las mejores empresas y organizaciones del sector lácteo colombiano especializadas en ${category.name.toLowerCase()}. Directorio oficial de ANALAC.`;

const customSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": title,
  "description": description,
  "url": `https://analac.com/asociados-y-aliados/directorio/categorias/${slug}`,
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": publishedOrgs.map((org, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "url": `https://analac.com/asociados-y-aliados/directorio/${org.slug}`,
      "name": org.name
    }))
  }
});
---

<BaseLayout 
  title={title} 
  description={description} 
  customSchema={customSchema}
  customCanonical={`https://analac.com/asociados-y-aliados/directorio/categorias/${slug}`}
  noIndex={shouldNoIndex}
>
  <div style="background: #f8fafc; padding: 40px 20px;">
    <div style="max-width: 1200px; margin: 0 auto;">
      <a href="/asociados-y-aliados/directorio" style="display: inline-block; margin-bottom: 24px; color: #64748b; text-decoration: none; font-size: 14px; font-weight: 500;">
        ← Volver al Directorio
      </a>
      
      <div style="background: white; border-radius: 16px; padding: 40px; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05); margin-bottom: 32px;">
        <h1 style="font-size: 32px; font-weight: 800; color: #0f172a; margin-top: 0; margin-bottom: 16px;">
          {category.name} en Colombia
        </h1>
        <p style="font-size: 18px; color: #475569; line-height: 1.6; max-width: 800px; margin: 0;">
          {description}
        </p>
      </div>

      <div style="margin-bottom: 24px;">
        <h2 style="font-size: 20px; font-weight: 700; color: #0f172a; margin: 0;">
          {publishedOrgs.length} {publishedOrgs.length === 1 ? 'organización encontrada' : 'organizaciones encontradas'}
        </h2>
      </div>

      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 24px;">
        {publishedOrgs.map((org: any) => (
          <OrganizationCard client:load organization={org} />
        ))}
      </div>
    </div>
  </div>
</BaseLayout>
