---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import OrganizationCard from '../../../../components/directorio/OrganizationCard';
import { getSupabaseServer } from '../../../../lib/supabase/server';

export const prerender = false;

const { departamento } = Astro.params;

if (!departamento) {
  return Astro.redirect('/404');
}

const deptoName = departamento.replace(/-/g, ' '); // simple slug to text mapping if we use hyphens

const supabase = getSupabaseServer(Astro.request, Astro.cookies);

// Obtener perfiles que tengan cobertura o sede en el departamento
// Esto es simplificado: idealmente se consulta locations O coverage_areas
const { data: orgsData, error: orgsError } = await supabase
  .from('locations')
  .select(`
    organization_id,
    city,
    department,
    organizations!inner (
      name,
      slug,
      org_type,
      status,
      verified,
      organization_profiles!inner (
        logo_url,
        summary,
        description,
        editorial_status
      ),
      organization_categories ( categories ( name ) )
    )
  `)
  .ilike('department', `%${deptoName}%`);

// Filtramos solo los perfiles publicados en TS (tambien se podría en SQL)
const publishedOrgs = orgsData?.filter((item: any) => item.organizations.organization_profiles[0]?.editorial_status === 'published')
  .map((item: any) => {
    const org = item.organizations;
    const profile = org.organization_profiles[0];
    const category = org.organization_categories?.[0]?.categories?.name || 'Varios';
    
    return {
      id: item.organization_id,
      slug: org.slug,
      name: org.name,
      type: org.org_type,
      category: category,
      status: org.status,
      verified: org.verified,
      logo: profile?.logo_url,
      location: { city: item.city, department: item.department },
      summary: profile?.summary
    };
  }) || [];

// Eliminar duplicados si una organización tiene múltiples sedes en el mismo depto
const uniqueOrgs = publishedOrgs.filter((org, index, self) =>
  index === self.findIndex((t) => (t.id === org.id))
);

// Regla SEO: Si hay menos de 2 empresas, lanzar 404 (Thin Content)
if (uniqueOrgs.length < 2) {
  return Astro.redirect('/404');
}

const capitalizedDepto = deptoName.split(' ').map(word => word.charAt(0).toUpperCase() + word.slice(1).toLowerCase()).join(' ');

// SEO Props
const title = `Empresas Lácteas en ${capitalizedDepto} | Directorio ANALAC`;
const description = `Descubre empresas, proveedores y productores de leche operando en el departamento de ${capitalizedDepto}, Colombia. Directorio oficial de ANALAC.`;

const customSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": title,
  "description": description,
  "url": `https://analac.com/asociados-y-aliados/directorio/ubicaciones/${departamento}`,
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": uniqueOrgs.map((org, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "url": `https://analac.com/asociados-y-aliados/directorio/${org.slug}`,
      "name": org.name
    }))
  }
});
---

<BaseLayout 
  title={title} 
  description={description} 
  customSchema={customSchema}
  customCanonical={`https://analac.com/asociados-y-aliados/directorio/ubicaciones/${departamento}`}
>
  <div style="background: #f8fafc; padding: 40px 20px;">
    <div style="max-width: 1200px; margin: 0 auto;">
      <a href="/asociados-y-aliados/directorio" style="display: inline-block; margin-bottom: 24px; color: #64748b; text-decoration: none; font-size: 14px; font-weight: 500;">
        ← Volver al Directorio
      </a>
      
      <div style="background: white; border-radius: 16px; padding: 40px; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05); margin-bottom: 32px;">
        <h1 style="font-size: 32px; font-weight: 800; color: #0f172a; margin-top: 0; margin-bottom: 16px;">
          Sector Lácteo en {capitalizedDepto}
        </h1>
        <p style="font-size: 18px; color: #475569; line-height: 1.6; max-width: 800px; margin: 0;">
          {description}
        </p>
      </div>

      <div style="margin-bottom: 24px;">
        <h2 style="font-size: 20px; font-weight: 700; color: #0f172a; margin: 0;">
          {uniqueOrgs.length} {uniqueOrgs.length === 1 ? 'organización encontrada' : 'organizaciones encontradas'}
        </h2>
      </div>

      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 24px;">
        {uniqueOrgs.map((org: any) => (
          <OrganizationCard client:load organization={org} />
        ))}
      </div>
    </div>
  </div>
</BaseLayout>
