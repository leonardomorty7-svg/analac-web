---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import DirectorySearchGrid from '../../../components/directorio/DirectorySearchGrid';

// SEO Title & Description
const title = "Directorio del Ecosistema Lácteo Colombiano | ANALAC";
const description = "Encuentra proveedores, empresas transformadoras, aliados y organizaciones del sector lácteo en Colombia. Directorio oficial de ANALAC.";
---

<BaseLayout title={title} description={description}>
  
  <div class="page-ambient-bg"></div>

  <!-- Hero AEO/SEO -->
  <header class="directory-hero">
    <div class="directory-hero-bg"></div>
    <div class="container hero-content">
      <div class="breadcrumb">
        <a href="/">Inicio</a> <span class="separator">/</span> 
        <a href="/asociados-y-aliados">Red ANALAC</a> <span class="separator">/</span> 
        <span>Directorio</span>
      </div>
      
      <span class="hero-eyebrow">Red ANALAC</span>
      
      <h1 class="directory-title">
        Organizaciones del ecosistema lácteo colombiano
      </h1>
      
      <p class="directory-summary">
        Explora empresas, asociados, aliados, cooperativas, instituciones y proveedores que hacen parte de la cadena láctea colombiana. Encuentra capacidades, productos, servicios, cobertura y formas de contacto dentro de Red ANALAC.
      </p>
    </div>
  </header>

  <!-- React Island: Search, Filters & Grid -->
  <section id="buscar" class="directory-search-section">
    <div class="container-fluid">
      <DirectorySearchGrid client:load />
    </div>
  </section>

  <!-- AEO Block: Preguntas Frecuentes del Directorio -->
  <section class="directory-faqs">
    <div class="container" style="max-width: 800px;">
      <div class="text-center mb-12">
        <h2 class="h2">¿Qué encontrarás en este directorio?</h2>
      </div>
      
      <div class="faq-list">
        <div class="faq-item">
          <h3 class="faq-question">¿Qué empresas hacen parte del ecosistema lácteo colombiano?</h3>
          <p class="faq-answer">
            El ecosistema está conformado por miles de actores. En este directorio oficial de ANALAC encontrarás productores, 
            cooperativas, empresas transformadoras, proveedores de maquinaria, laboratorios de sanidad animal y tecnología especializada.
          </p>
        </div>
        
        <div class="faq-item">
          <h3 class="faq-question">¿Cómo encontrar proveedores confiables para el sector lácteo?</h3>
          <p class="faq-answer">
            Utiliza el buscador superior filtrando por <strong>Categoría</strong> (ej. Nutrición Animal, Equipos de Ordeño) 
            y <strong>Región</strong>. Los perfiles con el "Sello de Verificación" han validado su identidad y documentación con ANALAC.
          </p>
        </div>

        <div class="faq-item">
          <h3 class="faq-question">¿Cómo aparecer en el directorio de ANALAC?</h3>
          <p class="faq-answer">
            Si eres una empresa del sector, puedes crear tu perfil a través de la sección "Publicar mi empresa". 
            Los perfiles son revisados y moderados por el equipo de ANALAC antes de ser publicados públicamente para garantizar la integridad del ecosistema.
          </p>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  body {
    background-color: #fcfcfc;
    position: relative;
  }

  .page-ambient-bg {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background: radial-gradient(circle at 50% 0%, rgba(109, 181, 109, 0.03) 0%, transparent 70%);
    pointer-events: none;
    z-index: -1;
  }

  .directory-hero {
    position: relative;
    padding: 120px 20px 140px; /* 140px bottom para alojar el -120px margin del buscador sin espacio vacío */
    color: #fff;
    min-height: auto;
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
  }
  
  .hero-content {
    position: relative;
    z-index: 10;
    text-align: center;
  }
  
  .hero-eyebrow {
    display: block;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: var(--c-green-light, #85cc85);
    text-transform: uppercase;
    margin-bottom: 16px;
  }
  
  .directory-hero-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(6, 20, 10, 0.95) 0%, rgba(26, 74, 42, 0.85) 100%), url('/images/colombia-dairy-bg-v2.jpg');
    background-size: cover;
    background-position: center;
    z-index: 0;
  }

  .breadcrumb {
    font-size: 13px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: 24px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .breadcrumb a {
    color: #fff;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .breadcrumb a:hover {
    color: var(--c-green);
  }
  .breadcrumb .separator {
    margin: 0 10px;
    color: rgba(255,255,255,0.4);
  }

  .directory-title {
    font-size: clamp(40px, 5vw, 64px);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -1.5px;
    margin-bottom: 24px;
    text-wrap: balance;
  }

  .directory-summary {
    max-width: 800px;
    margin: 0 auto 40px;
    color: rgba(255,255,255,0.9);
    font-size: 18px;
    line-height: 1.6;
    font-weight: 400;
    text-wrap: balance;
  }

  .directory-actions {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn {
    padding: 16px 32px;
    border-radius: 100px;
    font-weight: 600;
    font-size: 16px;
    transition: all 0.3s ease;
  }

  /* Secciones Inferiores */
  .directory-search-section {
    position: relative;
    z-index: 20;
    margin-top: -120px;
    padding: 0 0 40px;
  }

  @media (max-width: 768px) {
    .directory-search-section {
      margin-top: 0;
      padding-top: 40px;
    }
    .directory-hero {
      padding-bottom: 60px;
    }
  }

  .directory-faqs {
    padding: 80px 0 120px;
    background-color: transparent;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .faq-item {
    background: #fff;
    padding: 32px;
    border-radius: 20px;
    border: 1px solid rgba(0,0,0,0.05);
    box-shadow: 0 4px 16px rgba(0,0,0,0.02);
  }

  .faq-question {
    font-size: 18px;
    font-weight: 700;
    color: var(--color-text-main);
    margin-bottom: 12px;
  }

  .faq-answer {
    font-size: 16px;
    color: var(--color-text-sub);
    line-height: 1.6;
  }
</style>
