---
// src/pages/asociados-y-aliados/index.astro
import BaseLayout from '../../layouts/BaseLayout.astro'
---

<BaseLayout
  title="Red ANALAC | Ecosistema lácteo colombiano"
  description="Conoce Red ANALAC, el ecosistema digital que conecta organizaciones, profesionales, datos, conocimiento, soluciones y oportunidades del sector lácteo colombiano."
>
  <!-- 1. Hero Premium -->
  <section class="red-hero fade-up">
    <div class="red-hero-bg">
      <img src="/images/hero-bg.jpg" alt="Campo ganadero" class="hero-img" />
      <div class="hero-overlay"></div>
    </div>
    <div class="container relative z-10" style="display: flex; flex-direction: column; align-items: center; text-align: center; justify-content: center; min-height: 80vh;">
      <p class="overline" style="color: var(--c-green-light); letter-spacing: 0.2em; font-size: 13px; margin-bottom: 24px;">Red ANALAC</p>
      <h1 class="h1" style="color: #fff; max-width: 900px; margin-bottom: 24px; font-weight: 300;">
        El punto de encuentro digital del <em style="color: var(--c-green-light); font-style: normal; font-weight: 600;">ecosistema lácteo colombiano</em>
      </h1>
      <p style="color: rgba(255, 255, 255, 0.7); font-size: 18px; max-width: 750px; margin-bottom: 40px; line-height: 1.6;">
        Encuentra organizaciones y profesionales, comprende el sector mediante datos y conocimiento, conecta con soluciones y participa en oportunidades que fortalecen la cadena láctea colombiana.
      </p>
      <div style="display: flex; gap: 16px; flex-wrap: wrap; justify-content: center;">
        <a href="#nodos" class="btn btn--primary" style="padding: 16px 32px; font-size: 16px;">
          Explorar la Red
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-left: 8px;"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="/afiliate" class="btn btn--outline-white" style="padding: 16px 32px; font-size: 16px;">
          Ser parte de ANALAC
        </a>
      </div>
    </div>
  </section>

  <!-- 2. Propuesta de Valor (4 Pilares) -->
  <section class="section fade-up" style="padding-block: 80px; background-color: #fff;">
    <div class="container">
      <div style="text-align: center; margin-bottom: 64px;">
        <h2 class="h2" style="color: var(--c-green-deep);">¿Qué puedes hacer en la Red ANALAC?</h2>
      </div>

      <div class="benefits-grid">
        <div class="bento-card value-pillar">
          <div class="bento-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
          </div>
          <h3>Encontrar</h3>
          <p>Descubre organizaciones, profesionales, soluciones y actores del ecosistema.</p>
        </div>
        <div class="bento-card value-pillar">
          <div class="bento-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg>
          </div>
          <h3>Comprender</h3>
          <p>Consulta información, contenidos, indicadores y análisis del sector.</p>
        </div>
        <div class="bento-card value-pillar">
          <div class="bento-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><line x1="19" y1="8" x2="19" y2="14"></line><line x1="22" y1="11" x2="16" y2="11"></line></svg>
          </div>
          <h3>Conectar</h3>
          <p>Relaciona necesidades con capacidades, conocimiento y oportunidades.</p>
        </div>
        <div class="bento-card value-pillar">
          <div class="bento-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
          </div>
          <h3>Participar</h3>
          <p>Ingresa al portal, publica información, accede a servicios y forma parte de ANALAC.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. Nodos de la Red -->
  <section id="nodos" class="section fade-up" style="padding-block: 80px; background-color: var(--c-cream);">
    <div class="container">
      <div style="text-align: center; margin-bottom: 64px;">
        <p class="overline">ECOSISTEMA CONECTADO</p>
        <h2 class="h2" style="color: var(--c-green-deep);">Nodos de la Red</h2>
      </div>

      <div class="nodes-grid">
        <!-- 1. Organizaciones -->
        <div class="node-card">
          <div class="node-header">
            <div class="node-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg></div>
            <span class="status-badge available">Disponible</span>
          </div>
          <h3>Organizaciones</h3>
          <p>Conoce las empresas, asociados, aliados, cooperativas, instituciones y proveedores que hacen parte del ecosistema lácteo colombiano.</p>
          <div class="node-actions">
            <a href="/asociados-y-aliados/directorio" class="btn btn--primary btn-sm">Explorar el Directorio</a>
          </div>
        </div>

        <!-- 2. Soluciones -->
        <div class="node-card disabled">
          <div class="node-header">
            <div class="node-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path></svg></div>
            <span class="status-badge coming-soon">Próximamente</span>
          </div>
          <h3>Soluciones</h3>
          <p>Descubre productos, servicios, tecnologías y capacidades que pueden contribuir al desarrollo productivo del sector.</p>
          <div class="node-actions">
            <span class="btn btn--outline-dark btn-sm btn-disabled">Conocer la futura Vitrina</span>
          </div>
        </div>

        <!-- 3. Profesionales -->
        <div class="node-card disabled">
          <div class="node-header">
            <div class="node-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><polyline points="16 11 18 13 22 9"></polyline></svg></div>
            <span class="status-badge coming-soon">Próximamente</span>
          </div>
          <h3>Profesionales</h3>
          <p>Conecta con especialistas, técnicos, investigadores, consultores y profesionales que aportan conocimiento y experiencia al ecosistema.</p>
          <div class="node-actions">
            <span class="btn btn--outline-dark btn-sm btn-disabled">Comunidad de Profesionales</span>
          </div>
        </div>

        <!-- 4. Observatorio -->
        <div class="node-card">
          <div class="node-header">
            <div class="node-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"></line><line x1="12" y1="20" x2="12" y2="4"></line><line x1="6" y1="20" x2="6" y2="14"></line></svg></div>
            <span class="status-badge available">Nivel 1 disponible</span>
          </div>
          <h3>Observatorio ANALAC</h3>
          <p style="margin-bottom: 12px;">Comprende el sector mediante información, indicadores, análisis y datos del ecosistema lácteo colombiano.</p>
          <p style="font-size: 13px; color: var(--c-muted); line-height: 1.4; margin-bottom: 24px;">El acceso ampliado estará disponible progresivamente para usuarios de la Red según su afiliación.</p>
          <div class="node-actions" style="margin-top: auto;">
            <a href="/informacion-sectorial" class="btn btn--outline-dark btn-sm">Explorar el Observatorio</a>
          </div>
        </div>

        <!-- 5. Conocimiento -->
        <div class="node-card">
          <div class="node-header">
            <div class="node-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg></div>
            <span class="status-badge available">Disponible</span>
          </div>
          <h3>Conocimiento</h3>
          <p style="margin-bottom: 12px;">Accede a noticias, análisis del sector, evidencia científica sobre el consumo lácteo y recursos de formación.</p>
          <div class="node-actions" style="display: flex; flex-direction: column; gap: 8px; margin-top: auto;">
            <a href="/noticias" class="btn btn--outline-dark btn-sm">Actualidad y Análisis</a>
            <a href="/consumo-lacteo" class="btn btn--outline-dark btn-sm">Consumo y Bienestar</a>
          </div>
        </div>

        <!-- 6. Oportunidades -->
        <div class="node-card disabled">
          <div class="node-header">
            <div class="node-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg></div>
            <span class="status-badge coming-soon">Próximamente</span>
          </div>
          <h3>Oportunidades</h3>
          <p>Conoce convocatorias, eventos, alianzas, necesidades y posibilidades de participación dentro del ecosistema.</p>
          <div class="node-actions">
            <span class="btn btn--outline-dark btn-sm btn-disabled">Ver Oportunidades</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. Bloque de Arquitectura Unificada y Acceso al Portal -->
  <section class="section fade-up" style="padding-block: 80px; background-color: #fff;">
    <div class="container">
      <div class="portal-access-box" style="flex-direction: column; gap: 40px;">
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 40px; text-align: left;">
          <div>
            <div style="width: 48px; height: 48px; border-radius: 12px; background: rgba(0, 169, 79, 0.1); color: var(--c-green); display: flex; align-items: center; justify-content: center; margin-bottom: 16px;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
            </div>
            <h2 class="h3" style="color: var(--c-green-deep); margin-bottom: 16px;">Un solo perfil para toda la Red</h2>
            <p style="font-size: 16px; color: var(--c-muted); line-height: 1.6;">
              Tu información se gestiona desde una única cuenta. Completa los datos de tu organización una sola vez y reutilízalos, según tus permisos, en el Directorio, la Vitrina, la Comunidad, el Observatorio y los futuros servicios de Red ANALAC.
            </p>
          </div>
          <div>
            <div style="width: 48px; height: 48px; border-radius: 12px; background: rgba(0, 169, 79, 0.1); color: var(--c-green); display: flex; align-items: center; justify-content: center; margin-bottom: 16px;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline></svg>
            </div>
            <h2 class="h3" style="color: var(--c-green-deep); margin-bottom: 16px;">Una red alimentada por sus participantes</h2>
            <p style="font-size: 16px; color: var(--c-muted); line-height: 1.6;">
              Las organizaciones, profesionales y asociados actualizan progresivamente la información del ecosistema. ANALAC organiza, modera y verifica los contenidos para convertirlos en conocimiento útil y confiable para el sector.
            </p>
          </div>
        </div>
        
        <div class="portal-actions" style="margin-top: 16px; justify-content: center; padding-top: 32px; border-top: 1px solid rgba(0,0,0,0.05);">
          <a href="/portal-aliados/iniciar-sesion" class="btn btn--primary" style="padding: 14px 32px; font-size: 16px;">Gestionar mi perfil en el portal</a>
          <a href="/afiliate" class="btn btn--outline-dark" style="padding: 14px 32px; font-size: 16px;">Afiliarme a ANALAC</a>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. CTA Final -->
  <section class="section fade-up" style="padding-block: 100px; background: linear-gradient(135deg, var(--c-green-deep) 0%, #16361a 100%); text-align: center;">
    <div class="container" style="max-width: 700px;">
      <h2 class="h1" style="color: #fff; margin-bottom: 24px;">Haz parte de la red que conecta al sector lácteo colombiano</h2>
      <p style="font-size: 18px; color: rgba(255,255,255,0.7); line-height: 1.6; margin-bottom: 40px;">
        Afiliarte a ANALAC te permite aumentar tu visibilidad, acceder a información sectorial, fortalecer relaciones, participar en oportunidades y formar parte de una comunidad especializada.
      </p>
      <div style="display: flex; justify-content: center;">
        <a href="/afiliate" class="btn btn--accent" style="padding: 16px 36px; font-size: 16px;">Conocer beneficios de afiliación</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* Hero Styles */
  .red-hero {
    position: relative;
    overflow: hidden;
  }
  .red-hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(6, 15, 7, 0.8) 0%, rgba(6, 15, 7, 0.85) 100%);
  }
  .relative { position: relative; }
  .z-10 { z-index: 10; }

  /* Bento Box / Pilares */
  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }
  .bento-card {
    background: var(--c-cream);
    border-radius: 20px;
    padding: 32px;
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(0,0,0,0.03);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .value-pillar {
    align-items: center;
    text-align: center;
  }
  .bento-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.05);
  }
  .bento-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
    background: rgba(109, 181, 109, 0.15);
    color: var(--c-green);
  }
  .bento-card h3 {
    font-size: 18px;
    font-weight: 600;
    margin-bottom: 8px;
    color: var(--c-green-deep);
  }
  .bento-card p {
    font-size: 14px;
    line-height: 1.6;
    color: var(--c-muted);
  }

  @media (max-width: 1024px) {
    .benefits-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .benefits-grid { grid-template-columns: 1fr; }
  }

  /* Nodos Grid */
  .nodes-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .node-card {
    background: #fff;
    border-radius: 20px;
    padding: 32px;
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(0,0,0,0.05);
    box-shadow: 0 4px 16px rgba(0,0,0,0.02);
    transition: var(--transition-ui);
  }
  .node-card:not(.disabled):hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.05);
    border-color: var(--c-green-light);
  }
  .node-card.disabled {
    background: #fdfdfd;
    opacity: 0.85;
  }
  .node-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
  }
  .node-icon {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: var(--c-cream);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--c-green-deep);
  }
  .status-badge {
    font-size: 11px;
    font-weight: 600;
    padding: 4px 10px;
    border-radius: 100px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .status-badge.available {
    background: rgba(109, 181, 109, 0.15);
    color: var(--c-green-deep);
  }
  .status-badge.coming-soon {
    background: rgba(0, 0, 0, 0.05);
    color: var(--c-muted);
  }
  .node-card h3 {
    font-size: 20px;
    font-weight: 600;
    margin-bottom: 12px;
    color: var(--c-green-deep);
  }
  .node-card p {
    font-size: 14px;
    line-height: 1.6;
    color: var(--c-muted);
    flex: 1;
    margin-bottom: 24px;
  }
  .node-actions .btn-sm {
    padding: 10px 20px;
    font-size: 13px;
    width: 100%;
    text-align: center;
  }
  .btn-disabled {
    opacity: 0.5;
    cursor: not-allowed;
    background: transparent !important;
  }

  @media (max-width: 1024px) {
    .nodes-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 768px) {
    .nodes-grid { grid-template-columns: 1fr; }
  }

  /* Portal Access Box */
  .portal-access-box {
    background: var(--c-cream);
    border: 1px solid rgba(0,0,0,0.03);
    border-radius: 24px;
    padding: 48px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
  }
  .portal-actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    flex-shrink: 0;
  }
  @media (max-width: 900px) {
    .portal-access-box {
      flex-direction: column;
      align-items: flex-start;
      padding: 32px;
    }
  }
</style>
