---
// src/pages/asociados-y-aliados/index.astro
import BaseLayout from '../../layouts/BaseLayout.astro'
---

<BaseLayout
  title="Red ANALAC | Ecosistema lácteo colombiano"
  description="Conoce Red ANALAC, el ecosistema digital que conecta organizaciones, profesionales, datos, conocimiento, soluciones y oportunidades del sector lácteo colombiano."
>
  <!-- 1. Hero Premium -->
  <section class="red-hero fade-up">
    <div class="red-hero-bg">
      <img src="/images/hero-bg.jpg" alt="Campo ganadero" class="hero-img" />
      <div class="hero-overlay"></div>
    </div>
    <div class="container relative z-10" style="display: flex; flex-direction: column; align-items: center; text-align: center; justify-content: center; min-height: 80vh;">
      <p class="overline" style="color: var(--c-green-light); letter-spacing: 0.2em; font-size: 13px; margin-bottom: 24px;">Red ANALAC</p>
      <h1 class="h1" style="color: #fff; max-width: 1100px; margin-left: auto; margin-right: auto; margin-bottom: 24px; font-weight: 300;">
        El punto de encuentro digital<br>del <em style="color: var(--c-green-light); font-style: normal; font-weight: 600;">ecosistema lácteo colombiano</em>
      </h1>
      <p style="color: rgba(255, 255, 255, 0.7); font-size: 18px; max-width: 900px; margin-left: auto; margin-right: auto; margin-bottom: 40px; line-height: 1.6;">
        Encuentra organizaciones y profesionales, comprende el sector mediante datos y conocimiento,<br>conecta con soluciones y participa en oportunidades que fortalecen la cadena láctea colombiana.
      </p>
      <div style="display: flex; gap: 16px; flex-wrap: wrap; justify-content: center;">
        <a href="#nodos" class="btn btn--accent" style="padding: 14px 32px; font-size: 15px;">
          Explorar la Red
        </a>
        <a href="/afiliate" class="btn btn--outline-white" style="padding: 16px 32px; font-size: 16px;">
          Ser parte de ANALAC
        </a>
      </div>
    </div>
  </section>

  <!-- 2. Propuesta de Valor (4 Pilares) -->
  <section class="section fade-up" style="padding-block: 80px; background-color: #fff;">
    <div class="container">
      <div style="text-align: center; margin-bottom: 64px;">
        <h2 class="h2" style="color: var(--c-green-deep);">¿Qué puedes hacer en la Red ANALAC?</h2>
      </div>

      <div class="benefits-grid">
        <div class="bento-card value-pillar">
          <div class="bento-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
          </div>
          <h3>Encontrar</h3>
          <p>Descubre organizaciones, profesionales, soluciones y actores del ecosistema.</p>
        </div>
        <div class="bento-card value-pillar">
          <div class="bento-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg>
          </div>
          <h3>Comprender</h3>
          <p>Consulta información, contenidos, indicadores y análisis del sector.</p>
        </div>
        <div class="bento-card value-pillar">
          <div class="bento-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><line x1="19" y1="8" x2="19" y2="14"></line><line x1="22" y1="11" x2="16" y2="11"></line></svg>
          </div>
          <h3>Conectar</h3>
          <p>Relaciona necesidades con capacidades, conocimiento y oportunidades.</p>
        </div>
        <div class="bento-card value-pillar">
          <div class="bento-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
          </div>
          <h3>Participar</h3>
          <p>Ingresa al portal, publica información, accede a servicios y forma parte de ANALAC.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. Nodos de la Red -->
  <section id="nodos" class="section fade-up nodos-section">
    <div class="container">
      <div class="nodos-heading">
        <p class="overline" style="color: #6db56d;">ECOSISTEMA CONECTADO</p>
        <h2 class="h2" style="color: #ffffff;">Nodos de la Red</h2>
      </div>
    </div>

    <div class="nodos-carousel" id="nodosCarousel">
      <div class="nodos-track" id="nodosTrack">
        <!-- 1. Organizaciones -->
        <div class="node-card">
          <div class="node-header">
            <div class="node-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg></div>
            <span class="status-badge available">Disponible</span>
          </div>
          <h3>Directorio de Organizaciones</h3>
          <p>Conoce las empresas, asociados, aliados, cooperativas, instituciones y proveedores que hacen parte del ecosistema lácteo colombiano.</p>
          <div class="node-actions">
            <a href="/asociados-y-aliados/directorio" class="btn btn--primary btn-sm">Explorar el Directorio</a>
          </div>
        </div>

        <!-- 2. Soluciones -->
        <div class="node-card disabled">
          <div class="node-header">
            <div class="node-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path></svg></div>
            <span class="status-badge coming-soon">Próximamente</span>
          </div>
          <h3>Soluciones</h3>
          <p>Descubre productos, servicios, tecnologías y capacidades que pueden contribuir al desarrollo productivo del sector.</p>
          <div class="node-actions">
            <span class="btn btn--outline-dark btn-sm btn-disabled">Conocer la futura Vitrina</span>
          </div>
        </div>

        <!-- 3. Profesionales -->
        <div class="node-card disabled">
          <div class="node-header">
            <div class="node-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><polyline points="16 11 18 13 22 9"></polyline></svg></div>
            <span class="status-badge coming-soon">Próximamente</span>
          </div>
          <h3>Profesionales</h3>
          <p>Conecta con especialistas, técnicos, investigadores, consultores y profesionales que aportan conocimiento y experiencia al ecosistema.</p>
          <div class="node-actions">
            <span class="btn btn--outline-dark btn-sm btn-disabled">Comunidad de Profesionales</span>
          </div>
        </div>

        <!-- 4. Observatorio -->
        <div class="node-card">
          <div class="node-header">
            <div class="node-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"></line><line x1="12" y1="20" x2="12" y2="4"></line><line x1="6" y1="20" x2="6" y2="14"></line></svg></div>
            <span class="status-badge available">Nivel 1 disponible</span>
          </div>
          <h3>Observatorio</h3>
          <p style="margin-bottom: 12px;">Información sectorial, indicadores, análisis y datos del ecosistema lácteo colombiano.</p>
          <p style="font-size: 13px; color: var(--c-muted); line-height: 1.4; margin-bottom: 24px;">El acceso ampliado estará disponible progresivamente para usuarios de la Red según su afiliación.</p>
          <div class="node-actions" style="margin-top: auto;">
            <a href="/informacion-sectorial" class="btn btn--outline-dark btn-sm">Explorar el Observatorio</a>
          </div>
        </div>

        <!-- 5. Conocimiento -->
        <div class="node-card">
          <div class="node-header">
            <div class="node-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg></div>
            <span class="status-badge available">Disponible</span>
          </div>
          <h3>Conocimiento</h3>
          <p style="margin-bottom: 12px;">Accede a noticias, análisis del sector, evidencia científica sobre el consumo lácteo y recursos de formación.</p>
          <div class="node-actions" style="display: flex; flex-direction: column; gap: 8px; margin-top: auto;">
            <a href="/noticias" class="btn btn--outline-dark btn-sm">Actualidad y Análisis</a>
            <a href="/consumo-lacteo" class="btn btn--outline-dark btn-sm">Consumo y Bienestar</a>
          </div>
        </div>

        <!-- 6. Oportunidades -->
        <div class="node-card disabled">
          <div class="node-header">
            <div class="node-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg></div>
            <span class="status-badge coming-soon">Próximamente</span>
          </div>
          <h3>Oportunidades</h3>
          <p>Conoce convocatorias, eventos, alianzas, necesidades y posibilidades de participación dentro del ecosistema.</p>
          <div class="node-actions">
            <span class="btn btn--outline-dark btn-sm btn-disabled">Ver Oportunidades</span>
          </div>
        </div>
      </div>
    </div>

    <div class="nodos-dots" id="nodosDots">
      <button type="button" class="nodos-dot" data-index="0" aria-label="Ir a Directorio de Organizaciones"></button>
      <button type="button" class="nodos-dot" data-index="1" aria-label="Ir a Soluciones"></button>
      <button type="button" class="nodos-dot" data-index="2" aria-label="Ir a Profesionales"></button>
      <button type="button" class="nodos-dot" data-index="3" aria-label="Ir a Observatorio"></button>
      <button type="button" class="nodos-dot" data-index="4" aria-label="Ir a Conocimiento"></button>
      <button type="button" class="nodos-dot" data-index="5" aria-label="Ir a Oportunidades"></button>
    </div>
  </section>

  <!-- 5. CTA Final -->
  <section class="fade-up" style="position: relative; display: flex; align-items: center; justify-content: center; text-align: center; min-height: 70vh; padding: 120px 0;">
    <div style="position: absolute; inset: 0; background-image: linear-gradient(rgba(6, 15, 7, 0.4), rgba(6, 15, 7, 0.8)), url('/images/cta-lared-bg.jpg'); background-size: cover; background-position: center; z-index: 0;"></div>
    <div class="container" style="position: relative; z-index: 2;">
      <h2 class="h1" style="color: #ffffff; max-width: 1200px; margin-left: auto; margin-right: auto; margin-bottom: 24px;">
        Haz parte de la red que conecta<br>al sector lácteo colombiano
      </h2>
      <p style="font-size: 19px; color: #ffffff; max-width: 1000px; margin-left: auto; margin-right: auto; line-height: 1.6; margin-bottom: 40px; text-wrap: balance;">
        Afiliarte a ANALAC te permite aumentar tu visibilidad, acceder a información sectorial, fortalecer relaciones,<br>participar en oportunidades y formar parte de una comunidad especializada.
      </p>
      <div style="display: flex; justify-content: center;">
        <a href="/afiliate" class="btn btn--accent" style="padding: 14px 32px; font-size: 15px;">Conocer beneficios de afiliación</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* Hero Styles */
  .red-hero {
    position: relative;
    overflow: hidden;
  }
  .red-hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(6, 15, 7, 0.8) 0%, rgba(6, 15, 7, 0.85) 100%);
  }
  .relative { position: relative; }
  .z-10 { z-index: 10; }

  /* Bento Box / Pilares */
  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }
  .bento-card {
    background: var(--c-cream);
    border-radius: 20px;
    padding: 32px;
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(0,0,0,0.03);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .value-pillar {
    align-items: center;
    text-align: center;
  }
  .bento-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.05);
  }
  .bento-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
    background: rgba(109, 181, 109, 0.15);
    color: var(--c-green);
  }
  .bento-card h3 {
    font-size: 18px;
    font-weight: 600;
    margin-bottom: 8px;
    color: var(--c-green-deep);
  }
  .bento-card p {
    font-size: 14px;
    line-height: 1.6;
    color: var(--c-muted);
  }

  @media (max-width: 1024px) {
    .benefits-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .benefits-grid { grid-template-columns: 1fr; }
  }

  /* Nodos de la Red - dark background, matching Vitrina Digital (home) */
  .nodos-section {
    position: relative;
    background-color: #040a05;
    overflow: hidden;
  }
  .nodos-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 50% 20%, rgba(109, 181, 109, 0.12), transparent 50%),
                radial-gradient(circle at 80% 80%, rgba(109, 181, 109, 0.08), transparent 40%);
    z-index: 0;
  }
  .nodos-section::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
                      linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse at center, black 10%, transparent 80%);
    -webkit-mask-image: radial-gradient(ellipse at center, black 10%, transparent 80%);
    z-index: 0;
  }
  .nodos-section > .container,
  .nodos-section > .nodos-carousel,
  .nodos-section > .nodos-dots {
    position: relative;
    z-index: 2;
  }

  /* Nodos de la Red - heading */
  .nodos-heading {
    text-align: center;
    margin-bottom: 64px;
  }

  /* Nodos Track (mobile-first: simple grid, same as before) */
  .nodos-carousel {
    position: relative;
  }
  .nodos-track {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    max-width: 1280px;
    margin-inline: auto;
    padding-inline: 24px;
  }
  .nodos-dots {
    display: none;
  }
  .node-card {
    background: #fff;
    border-radius: 20px;
    padding: 32px;
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(0,0,0,0.05);
    box-shadow: 0 4px 16px rgba(0,0,0,0.02);
    transition: var(--transition-ui);
  }
  .node-card:not(.disabled):hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.05);
    border-color: var(--c-green-light);
  }
  .node-card.disabled {
    background: #fdfdfd;
    opacity: 0.85;
  }
  .node-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
  }
  .node-icon {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: var(--c-cream);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--c-green-deep);
  }
  .status-badge {
    font-size: 11px;
    font-weight: 600;
    padding: 4px 10px;
    border-radius: 100px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .status-badge.available {
    background: rgba(109, 181, 109, 0.15);
    color: var(--c-green-deep);
  }
  .status-badge.coming-soon {
    background: rgba(0, 0, 0, 0.05);
    color: var(--c-muted);
  }
  .node-card h3 {
    font-size: 20px;
    font-weight: 600;
    margin-bottom: 12px;
    color: var(--c-green-deep);
  }
  .node-card p {
    font-size: 14px;
    line-height: 1.6;
    color: var(--c-muted);
    flex: 1;
    margin-bottom: 24px;
  }
  .node-actions .btn-sm {
    padding: 10px 20px;
    font-size: 13px;
    width: 100%;
    text-align: center;
  }
  .btn-disabled {
    opacity: 0.5;
    cursor: not-allowed;
    background: transparent !important;
  }

  @media (max-width: 1024px) {
    .nodos-track { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 768px) {
    .nodos-track { grid-template-columns: 1fr; }
  }

  /* Desktop scroll-hijack carousel (see script at bottom of file) */
  @media (min-width: 900px) and (prefers-reduced-motion: no-preference) {
    .nodos-section {
      height: 100vh;
      display: flex;
      flex-direction: column;
      padding-top: 148px;
      padding-bottom: 40px;
      overflow: hidden;
    }
    .nodos-heading {
      margin-bottom: 40px;
      flex-shrink: 0;
    }
    .nodos-carousel {
      flex: 1;
      display: flex;
      align-items: center;
      overflow: hidden;
      min-height: 0;
    }
    .nodos-track {
      display: flex;
      gap: 32px;
      padding: 0;
      max-width: none;
      margin: 0;
      will-change: transform;
      transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .nodos-track .node-card {
      flex: 0 0 380px;
      width: 380px;
      transform: scale(0.94) rotate(0deg);
      opacity: 0.55;
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.02);
      transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1),
        box-shadow 0.6s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.6s ease;
    }
    .nodos-track .node-card.is-active {
      transform: scale(1.06) translateY(-10px) rotate(0deg);
      opacity: 1;
      box-shadow: 0 32px 56px rgba(0, 0, 0, 0.14), 0 0 0 1px rgba(0, 169, 79, 0.18),
        0 0 40px rgba(0, 169, 79, 0.12);
      border-color: rgba(0, 169, 79, 0.25);
      z-index: 2;
    }
    .nodos-track .node-card.is-before {
      transform: scale(0.94) rotate(-7deg);
    }
    .nodos-track .node-card.is-after {
      transform: scale(0.94) rotate(7deg);
    }
    .nodos-carousel .node-card:not(.disabled):hover {
      transform: scale(0.94) rotate(0deg);
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.02);
      border-color: rgba(0, 0, 0, 0.05);
    }
    .nodos-carousel .node-card.is-active:not(.disabled):hover {
      transform: scale(1.06) translateY(-10px) rotate(0deg);
      box-shadow: 0 32px 56px rgba(0, 0, 0, 0.14), 0 0 0 1px rgba(0, 169, 79, 0.18),
        0 0 40px rgba(0, 169, 79, 0.12);
      border-color: rgba(0, 169, 79, 0.25);
    }
    .nodos-carousel .node-card.is-before:not(.disabled):hover {
      transform: scale(0.94) rotate(-7deg);
    }
    .nodos-carousel .node-card.is-after:not(.disabled):hover {
      transform: scale(0.94) rotate(7deg);
    }
    .nodos-dots {
      display: flex;
      justify-content: center;
      gap: 10px;
      margin-top: 32px;
      flex-shrink: 0;
    }
    .nodos-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.2);
      border: none;
      padding: 0;
      cursor: pointer;
      transition: background 0.3s ease, transform 0.3s ease;
    }
    .nodos-dot.active {
      background: #6db56d;
      transform: scale(1.3);
    }
  }

</style>

<script>
  // Scroll-hijack carousel for "Nodos de la Red".
  // Desktop-only (>=900px) and disabled entirely under prefers-reduced-motion.
  ;(function () {
    const section = document.getElementById('nodos')
    const carousel = document.getElementById('nodosCarousel')
    const track = document.getElementById('nodosTrack')
    const dotsWrap = document.getElementById('nodosDots')
    if (!section || !carousel || !track || !dotsWrap) return

    const cards = Array.from(track.querySelectorAll('.node-card'))
    const dots = Array.from(dotsWrap.querySelectorAll('.nodos-dot'))
    const total = cards.length
    if (!total) return

    let activeIndex = 0
    let isAnimating = false
    let animTimer: number | undefined

    function isDesktopEnabled() {
      return (
        window.matchMedia('(min-width: 900px)').matches &&
        window.matchMedia('(prefers-reduced-motion: no-preference)').matches
      )
    }

    function layout() {
      const cardWidth = cards[0].getBoundingClientRect().width
      if (!cardWidth) return
      const trackStyle = getComputedStyle(track)
      const gap = parseFloat(trackStyle.columnGap || trackStyle.gap || '0') || 0
      const viewportWidth = carousel.clientWidth
      const offset = (viewportWidth - cardWidth) / 2 - activeIndex * (cardWidth + gap)
      track.style.transform = `translateX(${offset}px)`

      cards.forEach((card, i) => {
        card.classList.toggle('is-active', i === activeIndex)
        card.classList.toggle('is-before', i < activeIndex)
        card.classList.toggle('is-after', i > activeIndex)
      })
      dots.forEach((dot, i) => dot.classList.toggle('active', i === activeIndex))
    }

    function goTo(index: number) {
      const clamped = Math.max(0, Math.min(total - 1, index))
      if (clamped === activeIndex) return
      activeIndex = clamped
      isAnimating = true
      layout()
      window.clearTimeout(animTimer)
      animTimer = window.setTimeout(() => {
        isAnimating = false
      }, 600)
    }

    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => {
        if (!isAnimating) goTo(i)
      })
    })

    function isSectionPinned() {
      const rect = section.getBoundingClientRect()
      return Math.abs(rect.top) <= 100
    }

    function onWheel(e: WheelEvent) {
      if (!isDesktopEnabled()) return
      if (!isSectionPinned()) return

      const atFirst = activeIndex === 0
      const atLast = activeIndex === total - 1
      const goingDown = e.deltaY > 0
      const goingUp = e.deltaY < 0

      if (!goingDown && !goingUp) return
      // At a boundary and trying to go further out: release the hijack
      // so native page scroll continues into the next/previous section.
      if ((atFirst && goingUp) || (atLast && goingDown)) return

      e.preventDefault()
      e.stopImmediatePropagation()

      // Keep the section pixel-aligned to the viewport while hijacked.
      const rect = section.getBoundingClientRect()
      if (Math.abs(rect.top) > 2) {
        window.scrollTo({ top: window.scrollY + rect.top, behavior: 'auto' })
      }

      if (isAnimating) return

      if (goingDown) goTo(activeIndex + 1)
      else if (goingUp) goTo(activeIndex - 1)
    }

    window.addEventListener('wheel', onWheel, { passive: false, capture: true })
    window.addEventListener('resize', layout)
    layout()
  })()
</script>
