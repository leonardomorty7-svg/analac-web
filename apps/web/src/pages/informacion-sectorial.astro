---
// src/pages/informacion-sectorial.astro
import BaseLayout from '../layouts/BaseLayout.astro'
import { bulletins } from '../data/bulletins'
import { sectorIndicators } from '../data/stats'
import mapaColombiaSvg from '../assets/mapa-colombia.svg?raw'

const chartData = [
  { label: 'Producción Nacional (Formal)', value: '82%', color: 'var(--c-green-light)', amount: '3.42B L' },
  { label: 'Acopio Formal Industria', value: '48%', color: 'var(--c-green)', amount: '1.64B L' },
  { label: 'Consumo Per Cápita Objetivo', value: '86%', color: 'var(--c-green-deep)', amount: '155 L/hab' },
  { label: 'Exportaciones Proyectadas', value: '15%', color: '#666666', amount: '12K Ton' }
];
---

<BaseLayout
  title="Observatorio ANALAC | Información del sector lácteo colombiano"
  description="Consulta información, indicadores, análisis y datos del sector lácteo colombiano en el Observatorio de Red ANALAC."
>
  <!-- S1 Hero interior -->
  <section class="page-hero hero-dark fade-up">
    <div class="page-hero-bg"></div>
    <div class="container page-hero-content">
      <p class="overline overline-light">Información Sectorial</p>
      <h1 class="page-hero-title">
        Observatorio
      </h1>
      <p class="page-hero-desc">
        Información, indicadores y análisis del sector lácteo colombiano.
      </p>
    </div>
  </section>

  <!-- Navegación Interna -->
  <div class="page-nav fade-up">
    <div class="container">
      <div class="page-nav-scroll">
        <a href="#que-es" class="page-nav-link">¿Qué es el Observatorio?</a>
        <a href="#indicadores" class="page-nav-link">Indicadores</a>
        <a href="#panorama" class="page-nav-link">Panorama Sectorial</a>
        <a href="#boletines" class="page-nav-link">Informes y Estudios</a>
        <a href="#datos-territoriales" class="page-nav-link">Datos Territoriales</a>
      </div>
    </div>
  </div>

  <style>
    .page-nav {
      background: #ffffff;
      border-bottom: 1px solid rgba(0,0,0,0.05);
      position: sticky;
      top: 104px;
      z-index: 100;
    }
    .page-nav-scroll {
      display: flex;
      justify-content: center;
      gap: 32px;
      overflow-x: auto;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }
    @media (max-width: 640px) {
      .page-nav-scroll {
        justify-content: flex-start;
      }
    }
    .page-nav-scroll::-webkit-scrollbar {
      display: none;
    }
    .page-nav-link {
      padding: 20px 0;
      color: var(--c-muted);
      font-weight: 500;
      font-size: 15px;
      text-decoration: none;
      white-space: nowrap;
      position: relative;
      transition: color 0.2s ease;
    }
    .page-nav-link:hover {
      color: var(--c-green-deep);
    }
    .page-nav-link::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      width: 100%;
      height: 2px;
      background: var(--c-green-deep);
      transform: scaleX(0);
      transition: transform 0.2s ease;
    }
    .page-nav-link:hover::after {
      transform: scaleX(1);
    }
  </style>

  <!-- AEO: ¿Qué es el Observatorio? -->
  <section id="que-es" class="section fade-up" style="padding: 80px 0; background: #ffffff;">
    <div class="container text-center" style="max-width: 800px;">
      <h2 class="h3" style="color: var(--c-green-deep); margin-bottom: 24px;">¿Qué es el Observatorio ANALAC?</h2>
      <p style="font-size: 19px; color: var(--c-muted); line-height: 1.6; margin-bottom: 24px;">
        Es el espacio de Red ANALAC que reúne información, indicadores, análisis, informes y datos del sector lácteo colombiano para facilitar su comprensión y apoyar la toma de decisiones.
      </p>
      <p style="font-size: 16px; color: var(--c-muted); line-height: 1.6;">
        Su contenido público permite conocer cifras y tendencias generales. Los usuarios vinculados a la Red podrán acceder progresivamente a consultas ampliadas, comparaciones, descargas y herramientas especializadas según su afiliación y permisos.
      </p>
    </div>
  </section>

  <!-- S2 Indicadores actuales -->
  <section id="indicadores" class="section" style="padding: 120px 0; background: var(--c-cream);">
    <div class="container">
      <div class="section-header fade-up" style="margin-bottom: 48px; display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: 24px;">
        <div>
          <p class="overline">Noviembre 2025</p>
          <h2 class="h2" style="margin-top: 8px;">Dashboard de Indicadores</h2>
        </div>
        <span style="font-size: 13px; font-weight: 500; color: var(--c-muted); padding: 8px 16px; background: rgba(0,0,0,0.05); border-radius: 100px;">Actualizado: 30 nov. 2025</span>
      </div>

      <div class="indicadores-grid fade-up" id="indicadoresGrid">
        {sectorIndicators.map((ind) => (
          <div class="ind-card premium-panel">
            <div class="ind-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 12V7H5a2 2 0 0 1 0-4h14v4"/><path d="M3 5v14a2 2 0 0 0 2 2h16v-5"/><path d="M18 12a2 2 0 0 0 0 4h4v-4Z"/></svg>
            </div>
            <div class="ind-body">
              <div class="ind-value" data-target={ind.value}>{ind.value}</div>
              <div class="ind-label">{ind.label}</div>
              <div class="ind-sublabel">{ind.sublabel}</div>
            </div>
            <div class="ind-footer">
              <span class={`trend-pill trend-pill--${ind.trend}`}>{ind.trendValue}</span>
            </div>
          </div>
        ))}
      </div>
      
      <!-- Metodología -->
      <div style="margin-top: 48px; padding-top: 32px; border-top: 1px solid rgba(0,0,0,0.05);">
        <p style="font-size: 13px; color: var(--c-muted); line-height: 1.5; max-width: 800px;">
          <strong>Metodología y fuentes:</strong> Los datos de este dashboard son de carácter informativo público (Nivel 1). Son recopilados mensualmente a partir de fuentes consolidadas (DANE, USP, FEDEGÁN, ANALAC). Para detalles metodológicos o acceso a series históricas completas (Nivel 2), los usuarios autorizados deberán iniciar sesión en Mi Red ANALAC.
        </p>
      </div>
    </div>
  </section>

  <!-- S3 Nueva Sección: Panorama del Sector -->
  <section id="panorama" class="section" style="padding: 120px 0; background: #ffffff;">
    <div class="container">
      <div class="panorama-layout fade-up">
        <div class="panorama-text">
          <p class="overline">Contexto Nacional</p>
          <h2 class="h2" style="margin-bottom: 24px;">Panorama del Sector</h2>
          <p style="font-size: 19px; color: var(--c-muted); line-height: 1.6;">
            A través del análisis detallado de la producción y el acopio formal, mapeamos la capacidad de crecimiento e identificamos oportunidades estratégicas para la consolidación láctea en Colombia.
          </p>
        </div>
        <div class="panorama-charts" id="panoramaCharts">
          {chartData.map(chart => (
            <div class="chart-row">
              <div class="chart-header">
                <span class="chart-label">{chart.label}</span>
                <span class="chart-amount">{chart.amount}</span>
              </div>
              <div class="chart-track">
                <div class="chart-fill" data-width={chart.value} style={`background: ${chart.color};`}></div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <script>
    // Animación de conteo para el Dashboard de Indicadores (mismo patrón
    // que el bloque de impacto de "Quiénes somos"), adaptada para parsear
    // valores con formato colombiano ($1.820, 98,4%, 7,2B L, 12).
    ;(function () {
      const grid = document.getElementById('indicadoresGrid')
      if (!grid) return

      const DURATION = 1400
      const STAGGER = 120
      const THRESHOLD = 0.4

      function easeOutCubic(t: number) {
        return 1 - Math.pow(1 - t, 3)
      }

      // Separa un string tipo "$1.820" / "98,4%" / "7,2B L" / "12" en
      // prefijo, valor numérico objetivo, cantidad de decimales y sufijo.
      function parseValue(str: string) {
        const match = str.match(/^([^\d]*)([\d.,]+)(.*)$/)
        if (!match) return null
        const [, prefix, core, suffix] = match
        let decimals = 0
        let target: number
        if (core.includes(',')) {
          const [intPart, decPart] = core.split(',')
          decimals = decPart.length
          target = parseFloat(intPart.replace(/\./g, '') + '.' + decPart)
        } else {
          target = parseInt(core.replace(/\./g, ''), 10)
        }
        return { prefix, suffix, target, decimals }
      }

      // Reconstruye el número formateado al estilo colombiano (punto de
      // miles, coma decimal) para un valor intermedio de la animación.
      function formatNumber(value: number, decimals: number) {
        const fixed = value.toFixed(decimals)
        const [intPart, decPart] = fixed.split('.')
        const withThousands = intPart.replace(/\B(?=(\d{3})+(?!\d))/g, '.')
        return decimals > 0 ? `${withThousands},${decPart}` : withThousands
      }

      function animateValue(el: HTMLElement, delay: number) {
        const parsed = parseValue(el.dataset.target || '')
        if (!parsed) return
        const { prefix, suffix, target, decimals } = parsed

        setTimeout(() => {
          const start = performance.now()
          function tick(now: number) {
            const progress = Math.min((now - start) / DURATION, 1)
            const current = easeOutCubic(progress) * target
            el.textContent = prefix + formatNumber(current, decimals) + suffix
            if (progress < 1) requestAnimationFrame(tick)
          }
          requestAnimationFrame(tick)
        }, delay)
      }

      let fired = false
      const observer = new IntersectionObserver((entries) => {
        if (fired || !entries[0].isIntersecting) return
        fired = true
        observer.disconnect()
        grid.querySelectorAll<HTMLElement>('.ind-value').forEach((el, i) => {
          el.textContent = '0'
          animateValue(el, i * STAGGER)
        })
      }, { threshold: THRESHOLD })

      observer.observe(grid)
    })()
  </script>

  <script>
    // Animación de las barras de "Panorama del Sector": arrancan en 0 y
    // se llenan hasta su ancho real cuando entran en el viewport
    // (la transición CSS de .chart-fill hace la interpolación visual).
    ;(function () {
      const charts = document.getElementById('panoramaCharts')
      if (!charts) return

      const STAGGER = 120
      const THRESHOLD = 0.4

      let fired = false
      const observer = new IntersectionObserver((entries) => {
        if (fired || !entries[0].isIntersecting) return
        fired = true
        observer.disconnect()
        charts.querySelectorAll<HTMLElement>('.chart-fill').forEach((el, i) => {
          setTimeout(() => {
            el.style.width = el.dataset.width || '0'
          }, i * STAGGER)
        })
      }, { threshold: THRESHOLD })

      observer.observe(charts)
    })()
  </script>

  <!-- S4 Boletines descargables -->
  <section class="section" id="boletines" style="padding: 120px 0; background: var(--c-cream);">
    <div class="container">
      <div class="section-header text-center fade-up" style="max-width: 600px; margin: 0 auto 64px;">
        <p class="overline">Publicaciones</p>
        <h2 class="h2">Informes y Estudios</h2>
      </div>

      <div class="boletines-grid fade-up">
        {bulletins.map((b) => (
          <article class="boletin-card premium-panel">
            <div class="boletin-header" style={`border-bottom: 4px solid ${b.coverColor};`}>
              <span class="boletin-tag">Boletín ANALAC</span>
              <h3 class="boletin-date">{b.month} {b.year}</h3>
            </div>
            <div class="boletin-body">
              <ul class="boletin-list">
                {b.highlights.map((h) => (
                  <li>
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="var(--c-green)" stroke-width="3" style="flex-shrink:0; margin-top:4px;"><polyline points="20 6 9 17 4 12"></polyline></svg>
                    <span>{h}</span>
                  </li>
                ))}
              </ul>
              <div style="margin-top: auto; padding-top: 24px; border-top: 1px solid rgba(0,0,0,0.05); display: flex; align-items: center; gap: 8px; color: var(--c-muted); font-size: 14px; font-weight: 500;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                Exclusivo para afiliados
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- S4B Datos Territoriales -->
  <section id="datos-territoriales" class="section fade-up territorial-section">
    <div class="container territorial-grid">
      <div class="territorial-content">
        <p class="overline">Próximamente</p>
        <h2 class="h2" style="margin-bottom: 20px; color: #ffffff;">Datos Territoriales</h2>
        <p style="font-size: 18px; color: rgba(255,255,255,0.7); line-height: 1.6; margin-bottom: 28px;">
          Una vista geográfica interactiva para consultar la presencia de organizaciones, vocación departamental y estadísticas territoriales del ecosistema lácteo.
        </p>
        <a href="/afiliate" class="btn btn--primary territorial-cta">Ver Territorios →</a>
        <div class="territorial-badge">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
          Disponible solo para afiliados
        </div>
      </div>

      <div class="territorial-visual" aria-hidden="true">
        <div class="territorial-glow"></div>
        <div class="colombia-map-wrap">
          <Fragment set:html={mapaColombiaSvg} />
          <span class="map-pin-group" style="left: 57%; top: 55%; animation-delay: 0s;">
            <span class="map-pin-pulse"></span>
            <span class="map-pin"></span>
          </span>
          <span class="map-pin-group" style="left: 44%; top: 36%; animation-delay: 0.4s;">
            <span class="map-pin-pulse"></span>
            <span class="map-pin"></span>
          </span>
          <span class="map-pin-group" style="left: 32%; top: 58%; animation-delay: 0.8s;">
            <span class="map-pin-pulse"></span>
            <span class="map-pin"></span>
          </span>
          <span class="map-pin-group" style="left: 46%; top: 12%; animation-delay: 1.2s;">
            <span class="map-pin-pulse"></span>
            <span class="map-pin"></span>
          </span>
          <span class="map-pin-group" style="left: 67%; top: 62%; animation-delay: 1.6s;">
            <span class="map-pin-pulse"></span>
            <span class="map-pin"></span>
          </span>
        </div>
      </div>
    </div>
  </section>
  
  <!-- S4C Información Comunitaria -->
  <section class="section fade-up comunitaria-section">
    <div class="container comunitaria-statement">
      <p class="overline">Método y transparencia</p>
      <p class="comunitaria-big-text" id="comunitariaText">El Observatorio se construye entre toda la Red. Los afiliados actualizan la información, ANALAC la valida y organiza, y cada dato se presenta protegiendo la privacidad de quienes lo comparten.</p>
    </div>
  </section>

  <script>
    // Efecto "máquina de escribir" para la frase de "Información Comunitaria".
    // Los caracteres ya están todos en el DOM (envueltos en spans invisibles)
    // desde el arranque, para que el párrafo ocupe siempre su alto final y
    // no haya salto de layout mientras se van revelando.
    ;(function () {
      const el = document.getElementById('comunitariaText')
      if (!el) return

      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches
      if (reduceMotion) return

      const fullText = el.textContent || ''
      const CHAR_MS = 18
      const THRESHOLD = 0.5

      // Estilos aplicados en línea por JS (no vía clases CSS): los spans se
      // crean dinámicamente y las reglas con scope de Astro no los alcanzan.
      el.textContent = ''
      const chars = [...fullText].map((char) => {
        const span = document.createElement('span')
        span.textContent = char
        span.style.opacity = '0'
        span.style.transition = 'opacity 150ms ease'
        el.appendChild(span)
        return span
      })
      const cursor = document.createElement('span')
      cursor.style.display = 'inline-block'
      cursor.style.width = '3px'
      cursor.style.height = '0.9em'
      cursor.style.marginLeft = '3px'
      cursor.style.verticalAlign = '-0.1em'
      cursor.style.background = 'var(--c-green)'
      el.appendChild(cursor)
      const blinkTimer = setInterval(() => {
        cursor.style.opacity = cursor.style.opacity === '0' ? '1' : '0'
      }, 450)

      let fired = false
      const observer = new IntersectionObserver((entries) => {
        if (fired || !entries[0].isIntersecting) return
        fired = true
        observer.disconnect()

        let i = 0
        function tick() {
          if (chars[i]) chars[i].style.opacity = '1'
          i++
          if (i < chars.length) {
            setTimeout(tick, CHAR_MS)
          } else {
            clearInterval(blinkTimer)
            cursor.remove()
          }
        }
        tick()
      }, { threshold: THRESHOLD })

      observer.observe(el)
    })()
  </script>

  <!-- S5 CTA Acceso Avanzado -->
  <section class="fade-up" style="position: relative; display: flex; align-items: center; justify-content: center; text-align: center; min-height: 70vh; padding: 120px 0;">
    <div style="position: absolute; inset: 0; background-image: linear-gradient(rgba(6, 15, 7, 0.4), rgba(6, 15, 7, 0.8)), url('/images/cta-observatorio-bg.jpg'); background-size: cover; background-position: center; z-index: 0;"></div>
    <div class="container" style="position: relative; z-index: 2;">
      <p class="overline overline-light" style="color: rgba(255,255,255,0.9); margin-bottom: 24px;">Mi Red ANALAC</p>
      <h2 class="h1" style="color: #ffffff; max-width: 900px; margin-left: auto; margin-right: auto; margin-bottom: 24px; text-wrap: balance;">
        Accede a más información del Observatorio
      </h2>
      <p style="font-size: 19px; color: #ffffff; max-width: 900px; margin-left: auto; margin-right: auto; line-height: 1.6; margin-bottom: 48px; text-wrap: balance;">
        Inicia sesión para consultar progresivamente datos ampliados, análisis, herramientas y contenidos disponibles según tu afiliación dentro de Red ANALAC, o conoce cómo formar parte de la Red.
      </p>
      <div style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;">
        <a href="/portal-aliados/iniciar-sesion" class="btn btn--accent" style="padding: 16px 32px; font-size: 15px;">Iniciar sesión</a>
        <a href="/afiliate" class="btn btn--outline-light" style="padding: 16px 32px; font-size: 15px; border-color: rgba(255,255,255,0.3); color: #fff;">Afiliarme a ANALAC</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .page-hero.hero-dark {
    position: relative;
    padding: 200px 0 140px;
    min-height: 70vh;
    display: flex;
    align-items: center;
    background-color: var(--c-green-deep);
  }
  .page-hero-bg {
    position: absolute;
    inset: 0;
    background-image: linear-gradient(rgba(10, 26, 12, 0.5), rgba(10, 26, 12, 0.85)), url('/images/colombia-dairy-bg-v3.jpg');
    background-size: cover;
    background-position: center;
    z-index: 0;
  }
  .page-hero-content {
    position: relative;
    z-index: 1;
    max-width: 900px;
    text-align: center;
    margin: 0 auto;
  }
  .page-hero-title {
    font-size: clamp(40px, 6vw, 64px);
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 24px;
    color: #ffffff;
    text-wrap: balance;
  }
  .page-hero-desc {
    font-size: 19px;
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.6;
    max-width: 700px;
    margin: 0 auto;
    text-wrap: balance;
  }
  .overline-light {
    color: var(--c-green-light);
    border-color: rgba(255, 255, 255, 0.2);
  }

  /* Premium Panels */
  .premium-panel {
    background: #ffffff;
    border-radius: 16px;
    border: 1px solid rgba(0,0,0,0.04);
    box-shadow: 0 4px 24px rgba(0,0,0,0.02);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s ease;
  }
  .premium-panel:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 48px rgba(0,0,0,0.06);
  }

  /* Dashboard Indicadores */
  .indicadores-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }
  .ind-card {
    padding: 32px 24px;
    display: flex;
    flex-direction: column;
    height: 100%;
  }
  .ind-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: #eaf3ea;
    color: var(--c-green);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
  }
  .ind-value {
    font-size: 40px;
    font-weight: 300;
    letter-spacing: -0.03em;
    color: var(--c-text);
    line-height: 1;
    margin-bottom: 8px;
  }
  .ind-label {
    font-size: 15px;
    font-weight: 600;
    color: var(--c-text);
    margin-bottom: 4px;
  }
  .ind-sublabel {
    font-size: 13px;
    color: var(--c-muted);
  }
  .ind-footer {
    margin-top: auto;
    padding-top: 24px;
  }
  .trend-pill {
    display: inline-flex;
    padding: 4px 12px;
    border-radius: 100px;
    font-size: 12px;
    font-weight: 600;
  }
  .trend-pill--up {
    background-color: #eaf3ea;
    color: var(--c-green);
  }
  .trend-pill--stable {
    background-color: #f5f3ee;
    color: var(--c-muted);
  }
  .trend-pill--down {
    background-color: #fef2f2;
    color: #b91c1c;
  }

  /* Panorama del Sector */
  .panorama-layout {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 64px;
    align-items: center;
  }
  .chart-row {
    margin-bottom: 32px;
  }
  .chart-row:last-child {
    margin-bottom: 0;
  }
  .chart-header {
    display: flex;
    justify-content: space-between;
    margin-bottom: 12px;
    font-size: 15px;
    font-weight: 500;
  }
  .chart-label {
    color: var(--c-text);
  }
  .chart-amount {
