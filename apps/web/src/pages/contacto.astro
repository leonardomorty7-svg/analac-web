---
// src/pages/contacto.astro
import BaseLayout from '../layouts/BaseLayout.astro'

const officeData = {
  city: 'Bogotá D.C., Colombia',
  address: 'Calle 72 No. 6-44, Oficina 302, Bogotá',
  phone: '+57 (601) 317 4500',
  email: 'info@analac.org',
  schedule: 'Lunes a viernes, 8:00 am – 5:30 pm',
}

const topics = [
  'Proceso de afiliación',
  'Información y estadísticas',
  'Prensa y medios',
  'Alianzas estratégicas',
  'Asistencia técnica',
  'Otro',
]
---

<BaseLayout
  title="Contacto | ANALAC"
  description="Comunícate con ANALAC para conocer más sobre afiliación, aliados, información sectorial y representación gremial."
>
  <!-- Hero -->
  <section style="background: var(--color-green-dark); padding-top: calc(72px + 64px); padding-bottom: 72px;">
    <div class="container">
      <p class="overline overline--light">Contacto</p>
      <h1 style="font-size: clamp(32px, 4vw, 48px); font-weight: 500; letter-spacing: -0.02em; color: #fff; margin-top: 12px; line-height: 1.15;">
        Conversemos sobre el sector lácteo colombiano
      </h1>
    </div>
  </section>

  <!-- Formulario + datos -->
  <section class="section" style="background: var(--color-bg-page);">
    <div class="container" style="display: grid; grid-template-columns: 1.2fr 1fr; gap: 80px; align-items: start;">
      <!-- Formulario -->
      <div>
        <h2 class="h2" style="font-size: 22px; margin-bottom: 32px;">Envíanos un mensaje</h2>
        <form
          id="contact-form"
          action="#"
          method="post"
          novalidate
          style="display: flex; flex-direction: column; gap: 20px;"
          aria-label="Formulario de contacto ANALAC"
        >
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
            <div class="form-group">
              <label for="nombre" class="form-label">Nombre *</label>
              <input
                type="text"
                id="nombre"
                name="nombre"
                required
                placeholder="Tu nombre"
                class="form-input"
                autocomplete="name"
              />
            </div>
            <div class="form-group">
              <label for="empresa" class="form-label">Organización</label>
              <input
                type="text"
                id="empresa"
                name="empresa"
                placeholder="Empresa o finca"
                class="form-input"
                autocomplete="organization"
              />
            </div>
          </div>

          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
            <div class="form-group">
              <label for="email" class="form-label">Correo electrónico *</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                placeholder="correo@ejemplo.com"
                class="form-input"
                autocomplete="email"
              />
            </div>
            <div class="form-group">
              <label for="telefono" class="form-label">Teléfono</label>
              <input
                type="tel"
                id="telefono"
                name="telefono"
                placeholder="+57 300 000 0000"
                class="form-input"
                autocomplete="tel"
              />
            </div>
          </div>

          <div class="form-group">
            <label for="tema" class="form-label">Tema *</label>
            <select id="tema" name="tema" required class="form-input" style="cursor: pointer;">
              <option value="" disabled selected>Selecciona un tema</option>
              {topics.map((t) => (
                <option value={t}>{t}</option>
              ))}
            </select>
          </div>

          <div class="form-group">
            <label for="mensaje" class="form-label">Mensaje *</label>
            <textarea
              id="mensaje"
              name="mensaje"
              required
              placeholder="Cuéntanos en qué podemos ayudarte..."
              class="form-input"
              rows="5"
              style="resize: vertical; min-height: 120px;"
            ></textarea>
          </div>

          <div>
            <button type="submit" class="btn btn--primary" id="submit-btn">
              Enviar mensaje →
            </button>
          </div>
        </form>
      </div>

      <!-- Datos de contacto -->
      <div style="display: flex; flex-direction: column; gap: 32px; padding-top: 8px;">
        <div>
          <h2 class="h2" style="font-size: 22px; margin-bottom: 24px;">Información de contacto</h2>
          <div style="display: flex; flex-direction: column; gap: 20px;">
            {[
              { label: 'Dirección', value: officeData.address, icon: '📍' },
              { label: 'Ciudad', value: officeData.city, icon: '🌎' },
              { label: 'Teléfono', value: officeData.phone, icon: '📞' },
              { label: 'Correo', value: officeData.email, icon: '✉️' },
              { label: 'Horario', value: officeData.schedule, icon: '🕐' },
            ].map((item) => (
              <div style="display: flex; gap: 14px; align-items: flex-start;">
                <span style="font-size: 16px; flex-shrink: 0; margin-top: 1px;" aria-hidden="true">{item.icon}</span>
                <div>
                  <p style="font-size: 11px; font-weight: 500; letter-spacing: 0.06em; text-transform: uppercase; color: var(--color-text-light); margin-bottom: 2px;">{item.label}</p>
                  <p style="font-size: 14px; color: var(--color-text-main);">{item.value}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Mapa placeholder -->
        <div
          style="border-radius: var(--radius-img); overflow: hidden; height: 200px; background: var(--color-green-soft); display: flex; align-items: center; justify-content: center; border: var(--border-subtle);"
          aria-label="Mapa de ubicación de ANALAC en Bogotá"
        >
          <div style="text-align: center;">
            <span style="font-size: 32px; display: block; margin-bottom: 8px;" aria-hidden="true">📍</span>
            <p style="font-size: 13px; color: var(--color-green-mid); font-weight: 500;">Bogotá D.C., Colombia</p>
            <p style="font-size: 12px; color: var(--color-text-light);">Calle 72 No. 6-44</p>
          </div>
        </div>

        <!-- Portal afiliados -->
        <div style="padding: 24px; background: var(--color-green-soft); border-radius: var(--radius-card); border: var(--border-subtle);">
          <p class="overline" style="margin-bottom: 8px;">¿Eres afiliado?</p>
          <p style="font-size: 13px; color: var(--color-text-sub); margin-bottom: 16px; line-height: 1.6;">
            Ingresa al portal de afiliados para gestionar tu cuenta y pagos.
          </p>
          <a href="https://portal.analac.com" class="btn btn--primary" style="font-size: 13px; padding: 8px 16px;">
            Portal afiliados →
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .form-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .form-label {
    font-size: 12px;
    font-weight: 500;
    color: var(--color-text-main);
    letter-spacing: 0.02em;
  }

  .form-input {
    height: 42px;
    padding: 0 14px;
    border-radius: 8px;
    border: var(--border-subtle);
    background-color: var(--color-bg-white);
    font-family: inherit;
    font-size: 14px;
    color: var(--color-text-main);
    outline: none;
    transition: border-color var(--transition);
    width: 100%;
  }

  .form-input:focus {
    border-color: var(--color-green-accent);
  }

  .form-input::placeholder {
    color: var(--color-text-light);
  }

  textarea.form-input {
    height: auto;
    padding: 12px 14px;
  }

  @media (max-width: 900px) {
    div[style*="grid-template-columns: 1.2fr 1fr"] { grid-template-columns: 1fr !important; }
    div[style*="grid-template-columns: 1fr 1fr"] { grid-template-columns: 1fr !important; }
  }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null
  const btn = document.getElementById('submit-btn') as HTMLButtonElement | null

  form?.addEventListener('submit', (e) => {
    e.preventDefault()
    if (btn) {
      btn.textContent = '✓ Mensaje enviado'
      btn.disabled = true
      btn.style.opacity = '0.7'
    }
  })
</script>
