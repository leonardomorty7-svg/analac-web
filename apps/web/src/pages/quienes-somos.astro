  <script>
    // Aliados Estratégicos: el panel derecho cambia de grupo según el progreso
    // de scroll dentro de la sección (sin hijackear el scroll nativo).
    ;(function () {
      const wrapper = document.querySelector<HTMLElement>('.aliados-scrollytelling')
      const panels = document.querySelectorAll<HTMLElement>('.aliados-panel')
      const dots = document.querySelectorAll<HTMLElement>('.aliados-progress-dot')
      if (!wrapper || !panels.length) return

      const desktopMq = window.matchMedia('(min-width: 901px)')

      function setActive(index: number) {
        panels.forEach(p => {
          const isActive = Number(p.dataset.index) === index
          p.classList.toggle('active', isActive)
          const track = p.querySelector<HTMLElement>('.marquee-track')
          if (track) track.style.animationPlayState = isActive ? 'running' : 'paused'
        })
        dots.forEach(d => d.classList.toggle('active', Number(d.dataset.index) === index))
      }

      function onScroll() {
        if (!desktopMq.matches || !wrapper) { setActive(0); return }
        const rect = wrapper.getBoundingClientRect()
        const total = rect.height - window.innerHeight
        const progress = total > 0 ? Math.min(1, Math.max(0, -rect.top / total)) : 0
        const index = Math.min(panels.length - 1, Math.floor(progress * panels.length))
        setActive(index)
      }

      window.addEventListener('scroll', onScroll, { passive: true })
      window.addEventListener('resize', onScroll)
      onScroll()

      dots.forEach(dot => {
        dot.addEventListener('click', () => {
          if (!wrapper) return
          const index = Number(dot.dataset.index)
          const rect = wrapper.getBoundingClientRect()
          const total = rect.height - window.innerHeight
          const targetProgress = (index + 0.3) / panels.length
          const targetY = window.scrollY + rect.top + targetProgress * total
          window.scrollTo({ top: targetY, behavior: 'smooth' })
        })
      })
    })()
  </script>

