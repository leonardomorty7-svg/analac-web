---
// src/pages/quienes-somos.astro
import BaseLayout from '../layouts/BaseLayout.astro'
import LogoShowcase from '../components/LogoShowcase.astro'
import CtaFinal from '../components/CtaFinal.astro'
import fs from 'node:fs'
import path from 'node:path'

// Función para leer dinámicamente las carpetas de imágenes
function getLogosFromDir(dirPath: string) {
  try {
    const fullPath = path.join(process.cwd(), 'public', 'images', dirPath);
    if (!fs.existsSync(fullPath)) return [];
    const files = fs.readdirSync(fullPath);
    return files
      .filter(f => !f.startsWith('.')) // Excluir ocultos (.DS_Store)
      .map(f => ({
        src: `/images/${dirPath}/${f}`,
        // Limpiar nombre para el alt (ej: 'grupo-bios.webp' -> 'grupo bios')
        alt: f.replace(/\.[^/.]+$/, '').replace(/-/g, ' ') 
      }));
  } catch (e) {
    console.error(`Error reading ${dirPath}:`, e);
    return [];
  }
}

const tier1 = getLogosFromDir('aliados/tier-1');
const tier2 = getLogosFromDir('aliados/tier-2');
const tier3 = getLogosFromDir('aliados/tier-3');
const gremios = getLogosFromDir('gremios');
const instituciones = getLogosFromDir('instituciones');
const academia = getLogosFromDir('academia');
---

<BaseLayout
  title="Quiénes somos | ANALAC"
  description="Conoce la labor gremial de ANALAC, asociación que representa a productores de leche y fortalece el sector lácteo colombiano."
>
  <!-- S1 Hero interior -->
  <section class="page-hero hero-dark fade-up">
    <div class="page-hero-bg"></div>
    <div class="container page-hero-content">
      <p class="overline overline-light">Sobre ANALAC</p>
      <h1 class="page-hero-title">
        Más de 65 años fortaleciendo la producción lechera colombiana
      </h1>
      <p class="page-hero-desc">
        Somos la voz institucional, el respaldo gremial y el motor de desarrollo de las familias campesinas e industrias dedicadas al sector lácteo en todo el territorio nacional.
      </p>
    </div>
  </section>

  <!-- Navegación Interna -->
  <div class="page-nav fade-up">
    <div class="container">
      <div class="page-nav-scroll">
        <a href="#representacion" class="page-nav-link">Propósito</a>
        <a href="#que-hacemos" class="page-nav-link">Labor Gremial</a>
        <a href="#nuestro-equipo" class="page-nav-link">Equipo</a>
        <a href="#junta" class="page-nav-link">Junta Directiva</a>
        <a href="#ecosistema" class="page-nav-link">Ecosistema Digital</a>
      </div>
    </div>
  </div>

  <style>
    .page-nav {
      background: #ffffff;
      border-bottom: 1px solid rgba(0,0,0,0.05);
      position: sticky;
      top: 104px;
      z-index: 100;
    }
    .page-nav-scroll {
      display: flex;
      gap: 32px;
      overflow-x: auto;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }
    .page-nav-scroll::-webkit-scrollbar {
      display: none;
    }
    .page-nav-link {
      padding: 20px 0;
      color: var(--color-text-sub);
      font-weight: 500;
      font-size: 15px;
      text-decoration: none;
      white-space: nowrap;
      position: relative;
      transition: color 0.2s ease;
    }
    .page-nav-link:hover {
      color: var(--color-green-dark);
    }
    .page-nav-link::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      width: 100%;
      height: 2px;
      background: var(--color-green-dark);
      transform: scaleX(0);
      transition: transform 0.2s ease;
    }
    .page-nav-link:hover::after {
      transform: scaleX(1);
    }
  </style>

  <!-- S2 Bloque de Impacto -->
  <section class="section impact-section" style="background: var(--color-bg-page);">
    <div class="container">
      <div class="impact-grid fade-up">
        <div class="impact-stat">
          <div class="stat-number">65+</div>
          <div class="stat-label">Años de trayectoria</div>
        </div>
        <div class="impact-stat">
          <div class="stat-number">Miles</div>
          <div class="stat-label">Productores representados</div>
        </div>
        <div class="impact-stat">
          <div class="stat-number">100%</div>
          <div class="stat-label">Presencia nacional</div>
        </div>
        <div class="impact-stat">
          <div class="stat-number">365</div>
          <div class="stat-label">Días de gestión gremial</div>
        </div>
      </div>
    </div>
  </section>

  <!-- S3 Timeline -->
  <section class="section" style="padding-bottom: 120px;">
    <div class="container">
      <div class="section-header text-center fade-up" style="max-width: 600px; margin: 0 auto 80px;">
        <h2 class="h2">Nuestra Historia</h2>
      </div>
      <div class="timeline-premium fade-up">
        <div class="timeline-line"></div>
        <div class="timeline-item">
          <div class="timeline-dot"></div>
          <div class="timeline-content">
            <div class="timeline-year">1957</div>
            <div class="timeline-desc">Fundación de ANALAC en Bogotá, agrupando a los primeros líderes lecheros del país.</div>
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-dot"></div>
          <div class="timeline-content">
            <div class="timeline-year">1980</div>
            <div class="timeline-desc">Primera negociación nacional de precio de leche que formaliza las garantías del sector.</div>
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-dot"></div>
          <div class="timeline-content">
            <div class="timeline-year">2000</div>
            <div class="timeline-desc">Consolidación de comités regionales, ampliando la cobertura y representatividad gremial.</div>
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-dot"></div>
          <div class="timeline-content">
            <div class="timeline-year">2024</div>
            <div class="timeline-desc">Modernización gremial y digital, adaptando al productor a los retos globales del futuro.</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- S4 Misión y visión -->
  <section class="section" id="representacion" style="background: var(--color-bg-page);">
    <div class="container">
      <div class="mision-vision fade-up">
        <div class="mv-card premium-panel">
          <div class="mv-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
          </div>
          <h2 class="h2">Misión</h2>
          <p>Representar, defender y fortalecer los intereses del productor lechero colombiano ante el Gobierno, la industria y los organismos internacionales.</p>
        </div>
        <div class="mv-card premium-panel">
          <div class="mv-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/></svg>
          </div>
          <h2 class="h2">Visión</h2>
          <p>Ser el gremio líder en innovación, competitividad y sostenibilidad para el sector lácteo, garantizando el bienestar de las familias productoras.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- S5 Valores Institucionales -->
  <section class="section" style="padding: 120px 0;">
    <div class="container">
      <div class="section-header text-center fade-up" style="max-width: 600px; margin: 0 auto 64px;">
        <p class="overline">Nuestro ADN</p>
        <h2 class="h2">Valores Institucionales</h2>
      </div>
      <div class="valores-grid fade-up">
        <div class="valor-card">
          <div class="valor-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg></div>
          <h3 class="valor-title">Representación</h3>
        </div>
        <div class="valor-card">
          <div class="valor-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"></circle><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path><path d="M2 12h20"></path></svg></div>
          <h3 class="valor-title">Transparencia</h3>
        </div>
        <div class="valor-card">
          <div class="valor-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg></div>
          <h3 class="valor-title">Sostenibilidad</h3>
        </div>
        <div class="valor-card">
          <div class="valor-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"></path></svg></div>
          <h3 class="valor-title">Innovación</h3>
        </div>
        <div class="valor-card">
          <div class="valor-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg></div>
          <h3 class="valor-title">Desarrollo Rural</h3>
        </div>
        <div class="valor-card">
          <div class="valor-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg></div>
          <h3 class="valor-title">Cooperación</h3>
        </div>
      </div>
    </div>
  </section>

  <!-- S5a ¿Qué Hacemos? -->
  <section class="section" id="que-hacemos" style="padding: 120px 0; background: var(--color-bg-page);">
    <div class="container">
      <div class="section-header text-center fade-up" style="max-width: 600px; margin: 0 auto 64px;">
        <p class="overline">Nuestra Labor</p>
        <h2 class="h2">¿Qué hacemos?</h2>
        <p style="font-size: 19px; color: var(--color-text-sub); margin-top: 16px;">ANALAC trabaja en diferentes frentes para fortalecer el sector lácteo colombiano.</p>
      </div>
      <div class="mision-vision fade-up">
        <div class="mv-card premium-panel">
          <div class="mv-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
          </div>
          <h3 class="h2">Representación gremial</h3>
          <p>Defensa de los intereses del sector productor de leche ante entidades públicas y privadas.</p>
        </div>
        <div class="mv-card premium-panel">
          <div class="mv-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="18" y1="20" x2="18" y2="10"></line><line x1="12" y1="20" x2="12" y2="4"></line><line x1="6" y1="20" x2="6" y2="14"></line></svg>
          </div>
          <h3 class="h2">Información sectorial</h3>
          <p>Producción de indicadores, estudios, análisis y reportes para apoyar la toma de decisiones.</p>
        </div>
        <div class="mv-card premium-panel">
          <div class="mv-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg>
          </div>
          <h3 class="h2">Formación y capacitación</h3>
          <p>Programas académicos, talleres y actualización permanente para productores y aliados.</p>
        </div>
        <div class="mv-card premium-panel">
          <div class="mv-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
          </div>
          <h3 class="h2">Promoción del consumo</h3>
          <p>Campañas institucionales orientadas a fortalecer el consumo de leche y sus derivados.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- S5.5 Nuestro Equipo -->
  <section class="section" id="nuestro-equipo" style="padding: 120px 0;">
    <div class="container">
      <div class="section-header text-center fade-up" style="max-width: 600px; margin: 0 auto 64px;">
        <p class="overline">Institucional</p>
        <h2 class="h2">Nuestro Equipo</h2>
        <p style="font-size: 19px; color: var(--color-text-sub); margin-top: 16px;">Conoce al equipo que trabaja diariamente para fortalecer el sector productor de leche en Colombia.</p>
      </div>

      <style>
        @media (min-width: 993px) {
          .grid-4 { grid-template-columns: repeat(4, 1fr) !important; }
        }
        @media (max-width: 992px) and (min-width: 769px) {
          .grid-4 { grid-template-columns: repeat(2, 1fr) !important; }
        }
      </style>
      <div class="equipo-grid grid-4 fade-up">
        
        <!-- Card 1 -->
        <div class="equipo-card-premium">
          <div style="position: relative; overflow: hidden;">
            <img src="/images/equipo/andres_ramirez.png" alt="Andrés Ramírez" class="equipo-img" />
          </div>
          <div class="equipo-info">
            <h3 class="equipo-nombre">Andrés Ramírez</h3>
            <p class="equipo-cargo">Dirección Ejecutiva</p>
            <p class="equipo-desc">Lidera la estrategia institucional y representa a ANALAC ante los diferentes actores del sector.</p>
          </div>
        </div>

        <!-- Card 2 -->
        <div class="equipo-card-premium">
          <div style="position: relative; overflow: hidden;">
            <img src="/images/equipo/laura_hernandez.png" alt="Laura Hernández" class="equipo-img" />
          </div>
          <div class="equipo-info">
            <h3 class="equipo-nombre">Laura Hernández</h3>
            <p class="equipo-cargo">Área Técnica</p>
            <p class="equipo-desc">Desarrolla estudios, indicadores y análisis para apoyar la toma de decisiones del gremio.</p>
          </div>
        </div>

        <!-- Card 3 -->
        <div class="equipo-card-premium">
          <div style="position: relative; overflow: hidden;">
            <img src="/images/equipo/felipe_gonzalez.png" alt="Felipe González" class="equipo-img" />
          </div>
          <div class="equipo-info">
            <h3 class="equipo-nombre">Felipe González</h3>
            <p class="equipo-cargo">Comunicaciones</p>
            <p class="equipo-desc">Gestiona la comunicación institucional, campañas y relacionamiento con productores y aliados.</p>
          </div>
        </div>

        <!-- Card 4 -->
        <div class="equipo-card-premium">
          <div style="position: relative; overflow: hidden;">
            <img src="/images/equipo/sandra_morales.png" alt="Sandra Morales" class="equipo-img" />
          </div>
          <div class="equipo-info">
            <h3 class="equipo-nombre">Sandra Morales</h3>
            <p class="equipo-cargo">Administración</p>
            <p class="equipo-desc">Coordina los procesos administrativos y el soporte operativo de la asociación.</p>
          </div>
        </div>

      </div>

    </div>
  </section>

  <!-- S5b Aliados, Instituciones y Representación -->
  <section class="section" id="organizaciones" style="background: #ffffff; padding: 120px 0; border-top: 1px solid rgba(0,0,0,0.05);">
    <div class="container">
      
      <!-- Estilos locales para las grillas de logos (Plano 007) -->
      <style>
        .section-logo-title {
          font-size: clamp(24px, 3vw, 32px);
          font-weight: 500;
          text-align: center;
          margin-bottom: 16px;
          color: var(--color-text-main);
          letter-spacing: -0.01em;
        }
        .section-logo-desc {
          text-align: center;
          color: var(--color-text-sub);
          max-width: 800px;
          margin: 0 auto 48px;
          line-height: 1.6;
        }
        .logo-item {
          display: flex;
          align-items: center;
          justify-content: center;
        }
        .logo-item img {
          height: 60px; /* height uniforme */
          width: auto;
          object-fit: contain;
          opacity: 0.65;
          filter: grayscale(100%);
          transition: opacity 0.4s ease, filter 0.4s ease, transform 0.4s ease;
        }
        .logo-item:hover img {
          opacity: 1;
          filter: none;
          transform: scale(1.05);
        }
        .logo-item.tier-1 img { height: 72px; }
        .logo-item.tier-2 img { height: 60px; }
        .logo-item.tier-3 img { height: 50px; }

        /* Grillas estáticas */
        .static-logo-grid {
          display: flex;
          flex-wrap: wrap;
          justify-content: center;
          gap: 64px;
        }
        .academia-logo-grid {
          display: flex;
          flex-wrap: nowrap;
          justify-content: center;
          gap: 64px;
          overflow-x: auto;
          scrollbar-width: none;
        }
        .academia-logo-grid::-webkit-scrollbar { display: none; }

        /* Carrusel infinito */
        .marquee-wrapper {
          width: 100%;
          overflow: hidden;
          position: relative;
          -webkit-mask-image: linear-gradient(90deg, transparent, #000 5%, #000 95%, transparent);
          mask-image: linear-gradient(90deg, transparent, #000 5%, #000 95%, transparent);
        }
        .marquee-track {
          display: flex;
          width: max-content;
          gap: 80px;
          padding: 20px 0;
          animation: marquee-scroll 35s linear infinite;
        }
        .marquee-track:hover {
          animation-play-state: paused;
        }
        @keyframes marquee-scroll {
          0% { transform: translateX(0); }
          100% { transform: translateX(calc(-50% - 40px)); } /* Half width + half gap */
        }

        @media (max-width: 768px) {
          .static-logo-grid { gap: 32px; }
          .academia-logo-grid { gap: 32px; justify-content: flex-start; padding-bottom: 16px; }
          .logo-item.tier-1 img { height: 56px; }
          .logo-item img { height: 48px; }
          .marquee-track { gap: 40px; animation-duration: 25s; }
          @keyframes marquee-scroll {
            0% { transform: translateX(0); }
            100% { transform: translateX(calc(-50% - 20px)); }
          }
        }
      </style>

      <!-- 1. Aliados Estratégicos -->
      <div class="section-header text-center fade-up" style="max-width: 800px; margin: 0 auto 64px;">
        <p class="overline">Red de Apoyo</p>
        <h2 class="h2">Aliados Estratégicos</h2>
        <p style="font-size: 19px; color: var(--color-text-sub); margin-top: 16px;">
          Empresas que apoyan económicamente a ANALAC, fortalecen el desarrollo del sector lácteo colombiano y aportan soluciones y tecnología para nuestros productores.
        </p>
      </div>

      <div style="margin-bottom: 96px;" class="fade-up">
        <h3 class="section-logo-title">Aliados Premium</h3>
        <div class="static-logo-grid">
          {tier1.map(logo => (
            <div class="logo-item tier-1">
              <img src={logo.src} alt={logo.alt} loading="lazy" />
            </div>
          ))}
        </div>
      </div>
      
      <div style="margin-bottom: 96px;" class="fade-up">
        <h3 class="section-logo-title">Aliados Estratégicos</h3>
        <div class="static-logo-grid" style="gap: 48px;">
          {tier2.map(logo => (
            <div class="logo-item tier-2">
              <img src={logo.src} alt={logo.alt} loading="lazy" />
            </div>
          ))}
        </div>
      </div>
      
      <div style="margin-bottom: 96px;" class="fade-up">
        <h3 class="section-logo-title">Empresas Aliadas</h3>
        <div class="marquee-wrapper">
          <div class="marquee-track">
            {[...tier3, ...tier3].map((logo) => (
              <div class="logo-item tier-3">
                <img src={logo.src} alt={logo.alt} loading="lazy" />
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- 2. Representación Gremial -->
      <div style="margin-bottom: 96px; padding-top: 64px; border-top: 1px solid rgba(0,0,0,0.05);" class="fade-up">
        <h3 class="section-logo-title">Representación Gremial</h3>
        <p class="section-logo-desc">ANALAC participa activamente en espacios donde se construyen políticas públicas y se defiende la agenda del sector lácteo colombiano, articulando esfuerzos con los gremios más importantes del país.</p>
        <div class="static-logo-grid">
          {gremios.map(logo => (
            <div class="logo-item">
              <img src={logo.src} alt={logo.alt} loading="lazy" />
            </div>
          ))}
        </div>
      </div>

      <!-- 3. Instituciones -->
      <div style="margin-bottom: 96px; padding-top: 64px; border-top: 1px solid rgba(0,0,0,0.05);" class="fade-up">
        <h3 class="section-logo-title">Articulación Institucional</h3>
        <p class="section-logo-desc">Trabajamos de forma constante con entidades gubernamentales, ministerios y organismos técnicos para garantizar la normatividad, sanidad y competitividad de la producción nacional.</p>
        <div class="marquee-wrapper">
          <div class="marquee-track" style="animation-duration: 38s;">
            {[...instituciones, ...instituciones].map(logo => (
              <div class="logo-item">
                <img src={logo.src} alt={logo.alt} loading="lazy" />
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- 4. Academia -->
      <div style="padding-top: 64px; border-top: 1px solid rgba(0,0,0,0.05);" class="fade-up">
        <h3 class="section-logo-title">Academia y Formación</h3>
