---
// src/pages/quienes-somos.astro
import BaseLayout from '../layouts/BaseLayout.astro'
import LogoShowcase from '../components/LogoShowcase.astro'
import AliadosGroup from '../components/AliadosGroup.astro'
import fs from 'node:fs'
import path from 'node:path'
import { equipo } from '../data/equipo'

const equipoStaff = equipo.filter(m => m.grupo === 'equipo')
const equipoJunta = equipo.filter(m => m.grupo === 'junta')

// Diccionario de normalización óptica
// Ajustamos visualmente marcas que naturalmente se ven muy grandes o muy pequeñas
// manteniendo el mismo tamaño de caja. Los logos ya vienen recortados sin
// relleno transparente sobrante, así que la mayoría no necesita ajuste (1).
const opticalScales: Record<string, number> = {
  // Aliados Tier 2
  'delaval': 0.55,      // DeLaval ajustado para no dominar visualmente
  'saenz-fety': 0.95,   // Proporción equivalente a DeLaval
  // Aliados Tier 3
  'biogenesis': 0.85,
  'noga': 0.9,
  'nutryr': 0.9,
  'semex': 0.9,
  // Gremios
  'fedegan': 0.9,
  // Instituciones
  'ica': 0.55,         // Logo muy cuadrado y alto, domina demasiado
  'icontec': 0.75,     // Tiende a verse prominente
  'Logo_Ministerio_de_Agricultura_y_Desarrollo_Rural_Colombia': 0.85,
  'Logo_Ministerio_de_Ambiente_y_Desarrollo_Sostenible_Colombia': 0.85,
  // Academia
  'sena': 1.15,         // Para balancear el peso visual frente a los demás logos de academia
};

// Función para leer dinámicamente las carpetas de imágenes
function getLogosFromDir(dirPath: string) {
  try {
    const fullPath = path.join(process.cwd(), 'public', 'images', dirPath);
    if (!fs.existsSync(fullPath)) return [];
    const files = fs.readdirSync(fullPath);
    return files
      .filter(f => !f.startsWith('.')) // Excluir ocultos (.DS_Store)
      .map(f => {
        // Obtenemos el nombre base sin extensión(es) para buscar en el diccionario
        const baseName = f.replace(/\.svg\.webp$/, '').replace(/\.[^/.]+$/, '');
        const scale = opticalScales[baseName] || 1;
        
        return {
          src: `/images/${dirPath}/${f}`,
          // Limpiar nombre para el alt (ej: 'grupo-bios.webp' -> 'grupo bios')
          alt: f.replace(/\.[^/.]+$/, '').replace(/-/g, ' '),
          scale: scale
        };
      });
  } catch (e) {
    console.error(`Error reading ${dirPath}:`, e);
    return [];
  }
}

const tier1 = getLogosFromDir('aliados/tier-1');
const tier2 = getLogosFromDir('aliados/tier-2');
const tier3 = getLogosFromDir('aliados/tier-3');
const gremios = getLogosFromDir('gremios');
const instituciones = getLogosFromDir('instituciones');
const academia = getLogosFromDir('academia');

// Grupos de "Aliados Estratégicos": alimentan tanto el panel con scroll (desktop)
// como la lista apilada de respaldo (mobile), sin duplicar el markup de cada grilla.
const aliadosGroups = [
  {
    titulo: 'Aliados Premium',
    desc: 'Compañías que respaldan con el mayor nivel de compromiso la gestión gremial de ANALAC, aportando recursos estratégicos para el desarrollo del sector.',
    items: tier1,
    gridType: 'static' as const,
    tierClass: 'tier-1',
    gap: 64,
  },
  {
    titulo: 'Aliados Estratégicos',
    desc: 'Empresas que aportan tecnología, insumos y conocimiento especializado para fortalecer la productividad de los productores de leche afiliados.',
    items: tier2,
    gridType: 'static' as const,
    tierClass: 'tier-2',
    gap: 48,
  },
  {
    titulo: 'Empresas Aliadas',
    desc: 'Un grupo amplio de compañías del sector que suman su respaldo a las iniciativas gremiales y de desarrollo que impulsa ANALAC.',
    items: tier3,
    gridType: 'marquee' as const,
    tierClass: 'tier-3',
    duration: 35,
  },
  {
    titulo: 'Representación Gremial',
    desc: 'ANALAC participa activamente en espacios donde se construyen políticas públicas y se defiende la agenda del sector lácteo colombiano, articulando esfuerzos con los gremios más importantes del país.',
    items: gremios,
    gridType: 'static' as const,
    gap: 64,
  },
  {
    titulo: 'Articulación Institucional',
    desc: 'Trabajamos de forma constante con entidades gubernamentales, ministerios y organismos técnicos para garantizar la normatividad, sanidad y competitividad de la producción nacional.',
    items: instituciones,
    gridType: 'marquee' as const,
    duration: 38,
  },
  {
    titulo: 'Academia y Formación',
    desc: 'Nuestra relación con universidades y entidades formativas nos permite llevar capacitación, ciencia y transferencia tecnológica directamente a las fincas de nuestros afiliados.',
    items: academia,
    gridType: 'academia' as const,
    tierClass: 'tier-academia',
  },
];
---

<BaseLayout
  title="Quiénes somos | ANALAC"
  description="Conoce la labor gremial de ANALAC, asociación que representa a productores de leche y fortalece el sector lácteo colombiano."
>
  <!-- S1 Hero interior -->
  <section class="page-hero hero-dark fade-up">
    <div class="page-hero-bg"></div>
    <div class="container page-hero-content">
      <p class="overline overline-light" style="color: rgba(255, 255, 255, 0.9);">Sobre ANALAC</p>
      <h1 class="page-hero-title" style="max-width: 1100px; margin: 0 auto;">Más de 65 años fortaleciendo<br>la producción lechera colombiana</h1>
      <p class="page-hero-desc" style="max-width: 900px; margin-left: auto; margin-right: auto; text-wrap: balance;">Somos la voz institucional, el respaldo gremial y el motor de desarrollo de las familias <br class="break-desktop" />campesinas e industrias dedicadas al sector lácteo en todo el territorio nacional.</p>
    </div>
  </section>

  <!-- Navegación Interna -->
  <div class="page-nav fade-up">
    <div class="container">
      <div class="page-nav-scroll">
        <a href="#representacion" class="page-nav-link">Propósito</a>
        <a href="#que-hacemos" class="page-nav-link">Labor Gremial</a>
        <a href="#nuestro-equipo" class="page-nav-link">Equipo</a>
        <a href="#junta" class="page-nav-link">Junta Directiva</a>
        <a href="#ecosistema" class="page-nav-link">Ecosistema Digital</a>
      </div>
    </div>
  </div>

  <style>
    .break-desktop { display: none; }
    @media (min-width: 769px) {
      .break-desktop { display: inline; }
    }

    .page-nav {
      background: #ffffff;
      border-bottom: 1px solid rgba(0,0,0,0.05);
      position: sticky;
      top: 104px;
      z-index: 100;
    }
    .page-nav-scroll {
      display: flex;
      justify-content: center;
      gap: 32px;
      overflow-x: auto;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }
    @media (max-width: 640px) {
      .page-nav-scroll {
        justify-content: flex-start;
      }
    }
    .page-nav-scroll::-webkit-scrollbar {
      display: none;
    }
    .page-nav-link {
      padding: 20px 0;
      color: var(--color-text-sub);
      font-weight: 500;
      font-size: 15px;
      text-decoration: none;
      white-space: nowrap;
      position: relative;
      transition: color 0.2s ease;
    }
    .page-nav-link:hover {
      color: var(--color-green-dark);
    }
    .page-nav-link::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      width: 100%;
      height: 2px;
      background: var(--color-green-dark);
      transform: scaleX(0);
      transition: transform 0.2s ease;
    }
    .page-nav-link:hover::after {
      transform: scaleX(1);
    }
  </style>

  <!-- S2 Bloque de Impacto -->
  <section class="section impact-section" style="background: var(--color-bg-page);">
    <div class="container">
      <div class="impact-grid fade-up" id="impact-grid">
        <div class="impact-stat">
          <div class="stat-number" data-count="65" data-suffix="+" data-type="number">65+</div>
          <div class="stat-label">Años de trayectoria</div>
        </div>
        <div class="impact-stat">
          <div class="stat-number" data-type="word">Miles</div>
          <div class="stat-label">Productores representados</div>
        </div>
        <div class="impact-stat">
          <div class="stat-number" data-count="100" data-suffix="%" data-type="number">100%</div>
          <div class="stat-label">Presencia nacional</div>
        </div>
        <div class="impact-stat">
          <div class="stat-number" data-count="365" data-suffix="" data-type="number">365</div>
          <div class="stat-label">Días de gestión gremial</div>
        </div>
      </div>
    </div>
  </section>

  <script>
    (function () {
      const grid = document.getElementById('impact-grid');
      if (!grid) return;

      const DURATION   = 1400; // ms
      const STAGGER    = 120;  // ms entre cada indicador
      const THRESHOLD  = 0.40; // 40% visible

      // easeOutCubic: deceleración natural y premium
      function easeOutCubic(t) {
        return 1 - Math.pow(1 - t, 3);
      }

      // Anima un número desde 0 hasta el valor objetivo
      function animateCount(el, target, suffix, delay) {
        setTimeout(() => {
          const start = performance.now();

          function tick(now) {
            const elapsed = now - start;
            const progress = Math.min(elapsed / DURATION, 1);
            const eased = easeOutCubic(progress);
            const current = Math.round(eased * target);

            el.textContent = current + suffix;

            if (progress < 1) {
              requestAnimationFrame(tick);
            } else {
              // Microinteracción al terminar: pequeña pulsación
              el.style.transition = 'transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.25s ease';
              el.style.transform = 'translateY(-3px) scale(1.03)';
              el.style.opacity = '0.9';
              setTimeout(() => {
                el.style.transform = 'translateY(0) scale(1)';
                el.style.opacity = '1';
              }, 250);
            }
          }

          requestAnimationFrame(tick);
        }, delay);
      }

      // Anima la palabra "Miles" con fade-in + translateY
      function animateWord(el, delay) {
        el.style.opacity = '0';
        el.style.transform = 'translateY(12px) scale(0.98)';
        el.style.transition = 'none';

        setTimeout(() => {
          el.style.transition = 'opacity 0.6s ease, transform 0.6s cubic-bezier(0.16, 1, 0.3, 1)';
          el.style.opacity = '1';
          el.style.transform = 'translateY(0) scale(1)';
        }, delay);
      }

      // IntersectionObserver: dispara una única vez al 40% de visibilidad
      let fired = false;
      const observer = new IntersectionObserver((entries) => {
        if (fired) return;
        const entry = entries[0];
        if (!entry.isIntersecting) return;

        fired = true;
        observer.disconnect();

        const stats = grid.querySelectorAll('.stat-number');
        stats.forEach((el, i) => {
          const delay = i * STAGGER;
          const type  = el.dataset.type;

          if (type === 'word') {
            animateWord(el, delay);
          } else {
            const target = parseInt(el.dataset.count, 10);
            const suffix = el.dataset.suffix || '';
            // Ocultar el valor inicial hasta que arranque la animación
            el.textContent = '0' + suffix;
            animateCount(el, target, suffix, delay);
          }
        });
      }, { threshold: THRESHOLD });

      observer.observe(grid);
    })();
  </script>

  <!-- S3 Timeline -->
  <section class="section" style="padding-bottom: 120px;">
    <div class="container">
      <div class="section-header text-center fade-up" style="max-width: 600px; margin: 0 auto 80px;">
        <h2 class="h2">Nuestra Historia</h2>
      </div>
      <div class="timeline-premium fade-up">
        <div class="timeline-line"></div>
        <div class="timeline-item">
          <div class="timeline-dot"></div>
          <div class="timeline-content">
            <div class="timeline-year">1957</div>
            <div class="timeline-desc">Fundación de ANALAC en Bogotá, agrupando a los primeros líderes lecheros del país.</div>
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-dot"></div>
          <div class="timeline-content">
            <div class="timeline-year">1980</div>
            <div class="timeline-desc">Primera negociación nacional de precio de leche que formaliza las garantías del sector.</div>
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-dot"></div>
          <div class="timeline-content">
            <div class="timeline-year">2000</div>
            <div class="timeline-desc">Consolidación de comités regionales, ampliando la cobertura y representatividad gremial.</div>
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-dot"></div>
          <div class="timeline-content">
            <div class="timeline-year">2024</div>
            <div class="timeline-desc">Modernización gremial y digital, adaptando al productor a los retos globales del futuro.</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- S4 Misión y visión -->
  <section class="section" id="representacion" style="background: var(--color-bg-page);">
    <div class="container">
      <div class="mision-vision fade-up">
        <div class="mv-card premium-panel">
          <div class="mv-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
          </div>
          <h2 class="h2">Misión</h2>
          <p>Representar, defender y fortalecer los intereses del productor lechero colombiano ante el Gobierno, la industria y los organismos internacionales.</p>
        </div>
        <div class="mv-card premium-panel">
          <div class="mv-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/></svg>
          </div>
          <h2 class="h2">Visión</h2>
          <p>Ser el gremio líder en innovación, competitividad y sostenibilidad para el sector lácteo, garantizando el bienestar de las familias productoras.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- S5 Valores Institucionales -->
  <section class="section" style="padding: 120px 0;">
    <div class="container">
      <div class="section-header text-center fade-up" style="max-width: 600px; margin: 0 auto 64px;">
        <p class="overline">Nuestro ADN</p>
        <h2 class="h2">Valores Institucionales</h2>
      </div>
      <div class="valores-grid fade-up">
        <div class="valor-card">
          <div class="valor-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg></div>
          <h3 class="valor-title">Representación</h3>
        </div>
        <div class="valor-card">
          <div class="valor-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"></circle><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path><path d="M2 12h20"></path></svg></div>
          <h3 class="valor-title">Transparencia</h3>
        </div>
        <div class="valor-card">
          <div class="valor-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"></path><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"></path></svg></div>
          <h3 class="valor-title">Sostenibilidad</h3>
        </div>
        <div class="valor-card">
          <div class="valor-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"></path></svg></div>
          <h3 class="valor-title">Innovación</h3>
        </div>
        <div class="valor-card">
          <div class="valor-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg></div>
          <h3 class="valor-title">Desarrollo Rural</h3>
        </div>
        <div class="valor-card">
          <div class="valor-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg></div>
          <h3 class="valor-title">Cooperación</h3>
        </div>
      </div>
    </div>
  </section>

  <!-- S5a ¿Qué Hacemos? -->
  <section class="section" id="que-hacemos" style="padding: 120px 0; background: var(--color-bg-page);">
    <div class="container">
      <div class="section-header text-center fade-up" style="max-width: 600px; margin: 0 auto 64px;">
        <p class="overline">Nuestra Labor</p>
        <h2 class="h2">¿Qué hacemos?</h2>
        <p style="font-size: 19px; color: var(--color-text-sub); margin-top: 16px;">ANALAC trabaja en diferentes frentes para fortalecer el sector lácteo colombiano.</p>
      </div>
      <div class="mision-vision fade-up">
        <div class="mv-card premium-panel">
          <div class="mv-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
          </div>
          <h3 class="h2">Representación gremial</h3>
          <p>Defensa de los intereses del sector productor de leche ante entidades públicas y privadas.</p>
        </div>
        <div class="mv-card premium-panel">
          <div class="mv-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="18" y1="20" x2="18" y2="10"></line><line x1="12" y1="20" x2="12" y2="4"></line><line x1="6" y1="20" x2="6" y2="14"></line></svg>
          </div>
          <h3 class="h2">Información sectorial</h3>
          <p>Producción de indicadores, estudios, análisis y reportes para apoyar la toma de decisiones.</p>
        </div>
        <div class="mv-card premium-panel">
          <div class="mv-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg>
          </div>
          <h3 class="h2">Formación y capacitación</h3>
          <p>Programas académicos, talleres y actualización permanente para productores y aliados.</p>
        </div>
        <div class="mv-card premium-panel">
          <div class="mv-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
          </div>
          <h3 class="h2">Promoción del consumo</h3>
          <p>Campañas institucionales orientadas a fortalecer el consumo de leche y sus derivados.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- S5.5 Nuestro Equipo -->
  <section class="section" id="nuestro-equipo" style="padding: 120px 0;">
    <div class="container">
      <div class="section-header text-center fade-up" style="max-width: 600px; margin: 0 auto 64px;">
        <p class="overline">Institucional</p>
        <h2 class="h2">Nuestro Equipo</h2>
        <p style="font-size: 19px; color: var(--color-text-sub); margin-top: 16px;">Conoce al equipo que trabaja diariamente para fortalecer el sector productor de leche en Colombia.</p>
      </div>

      <div class="equipo-grid fade-up">
        {equipoStaff.map(miembro => (
          <div class="equipo-card-premium" style={miembro.oculto ? "display: none;" : undefined}>
            <div class="equipo-img-wrapper">
              <img src={miembro.imagen} alt={miembro.nombre} class="equipo-img" />
            </div>
            <div class="equipo-info">
              <h3 class="equipo-nombre">{miembro.nombre}</h3>
              <p class="equipo-cargo">{miembro.cargo}</p>
              <p class="equipo-desc">{miembro.descripcion}</p>
            </div>
            <div class="equipo-footer">
              <a href={miembro.linkedin} class="linkedin-icon" aria-label={`LinkedIn de ${miembro.nombre}`} target="_blank" rel="noopener noreferrer">
                <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
              </a>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- S5b Aliados, Instituciones y Representación -->
  <section class="section aliados-section" id="organizaciones" style="background: #ffffff; padding: 120px 0; border-top: 1px solid rgba(0,0,0,0.05);">
    <div class="container">

      <div class="section-header text-center fade-up" style="max-width: 700px; margin: 0 auto 48px;">
        <p class="overline">Red de Apoyo</p>
        <h2 class="h2">Aliados y Colaboradores</h2>
        <p style="font-size: 17px; color: var(--color-text-sub); margin-top: 16px;">
          Empresas, gremios, instituciones y academia que respaldan la gestión de ANALAC en beneficio del sector lácteo colombiano.
        </p>
      </div>

