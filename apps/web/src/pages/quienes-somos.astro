<style>
  /* Hero */
  .page-hero.hero-dark {
    position: relative;
    padding: 200px 0 140px;
    min-height: 70vh;
    display: flex;
    align-items: center;
    background-color: #06150f;
  }
  .page-hero-bg {
    position: absolute;
    inset: 0;
    background-image: linear-gradient(rgba(6, 15, 7, 0.4), rgba(6, 15, 7, 0.8)), url('/images/hero-bg.jpg');
    background-size: cover;
    background-position: center;
    z-index: 0;
  }
  .page-hero-content {
    position: relative;
    z-index: 1;
    max-width: 900px;
    text-align: center;
    margin: 0 auto;
  }
  .page-hero-title {
    font-size: clamp(40px, 6vw, 64px);
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 24px;
    color: #ffffff;
    text-wrap: balance;
  }
  .page-hero-desc {
    font-size: 19px;
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.6;
    max-width: 700px;
    margin: 0 auto;
    text-wrap: balance;
  }
  .overline-light {
    color: var(--color-green-soft);
    border-color: rgba(255, 255, 255, 0.2);
  }

  /* Impact Block */
  .impact-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
    border-top: 1px solid rgba(0,0,0,0.05);
    border-bottom: 1px solid rgba(0,0,0,0.05);
    padding: 64px 0;
  }
  .impact-stat {
    text-align: center;
  }
  .stat-number {
    font-size: 56px;
    font-weight: 300;
    color: var(--color-green-dark);
    line-height: 1;
    margin-bottom: 12px;
    letter-spacing: -0.03em;
  }
  .stat-label {
    font-size: 15px;
    font-weight: 500;
    color: var(--color-text-sub);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Timeline Premium */
  .timeline-premium {
    position: relative;
    max-width: 800px;
    margin: 0 auto;
  }
  .timeline-line {
    position: absolute;
    left: 24px;
    top: 0;
    bottom: 0;
    width: 1px;
    background: rgba(0,0,0,0.1);
  }
  .timeline-item {
    position: relative;
    padding-left: 80px;
    padding-bottom: 64px;
  }
  .timeline-dot {
    position: absolute;
    left: 17px;
    top: 8px;
    width: 15px;
    height: 15px;
    border-radius: 50%;
    background: var(--color-bg-page);
    border: 2px solid var(--color-green-dark);
    box-shadow: 0 0 0 8px #ffffff;
    transition: all 0.3s ease;
  }
  .timeline-item:hover .timeline-dot {
    background: var(--color-green-dark);
    transform: scale(1.2);
    box-shadow: 0 0 0 8px #eaf3ea;
  }
  .timeline-year {
    font-size: 32px;
    font-weight: 300;
    color: var(--color-green-dark);
    margin-bottom: 12px;
    line-height: 1;
  }
  .timeline-desc {
    font-size: 19px;
    color: var(--color-text-main);
    line-height: 1.6;
  }

  /* Misión / Visión */
  .mision-vision {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
  }
  .premium-panel {
    background: #ffffff;
    padding: 64px;
    border-radius: 16px;
    border: 1px solid rgba(0,0,0,0.04);
    box-shadow: 0 4px 24px rgba(0,0,0,0.02);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s ease;
  }
  .premium-panel:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 48px rgba(0,0,0,0.06);
  }
  .mv-icon {
    width: 56px;
    height: 56px;
    border-radius: 12px;
    background: #eaf3ea;
    color: var(--color-green-dark);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 32px;
  }
  .premium-panel .h2 {
    margin-bottom: 20px;
    font-size: 32px;
    color: var(--color-green-dark);
  }
  .premium-panel p {
    font-size: 19px;
    line-height: 1.6;
    color: var(--color-text-main);
  }

  /* Valores Institucionales */
  .valores-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .valor-card {
    background: var(--color-bg-page);
    border: 1px solid rgba(0,0,0,0.05);
    border-radius: 12px;
    padding: 32px;
    display: flex;
    align-items: center;
    gap: 16px;
    transition: background 0.2s ease;
  }
  .valor-card:hover {
    background: #eaf3ea;
  }
  .valor-icon {
    color: var(--color-green-dark);
    flex-shrink: 0;
  }
  .valor-title {
    font-size: 18px;
    font-weight: 500;
    color: var(--color-green-dark);
    margin: 0;
  }

  /* Junta Directiva */
  .equipo-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }
  .equipo-card-premium {
    background: #ffffff;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid rgba(0,0,0,0.04);
    box-shadow: 0 4px 20px rgba(0,0,0,0.02);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s ease;
  }
  .equipo-card-premium:hover {
    transform: translateY(-8px);
    box-shadow: 0 16px 40px rgba(0,0,0,0.08);
  }
  .equipo-img {
    width: 100%;
    aspect-ratio: 3/4;
    object-fit: cover;
    object-position: top;
    display: block;
    background: #e8e4dc;
    transition: transform 0.6s ease;
  }
  .equipo-card-premium:hover .equipo-img {
    transform: scale(1.03);
  }
  .equipo-info {
    padding: 32px 24px;
    text-align: center;
  }
  .equipo-nombre {
    font-size: 22px;
    font-weight: 600;
    color: var(--color-green-dark);
    margin-bottom: 6px;
  }
  .equipo-cargo {
    font-size: 14px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-green-dark);
    margin-bottom: 16px;
    opacity: 0.8;
  }
  .equipo-desc {
    font-size: 15px;
    line-height: 1.6;
    color: var(--color-text-main);
    margin: 0;
  }
  /* Responsive */
  @media (max-width: 768px) {
    .impact-grid { grid-template-columns: 1fr 1fr; }
    .mision-vision { grid-template-columns: 1fr; }
    .valores-grid { grid-template-columns: 1fr; }
    .equipo-grid { grid-template-columns: 1fr; }
    .afiliados-grid { grid-template-columns: repeat(2, 1fr) !important; }
    .timeline-premium .timeline-item { padding-left: 48px; }
    .timeline-premium .timeline-line { left: 12px; }
    .timeline-premium .timeline-dot { left: 5px; }
    .timeline-premium .timeline-dot { left: 5px; }
  }
  @media (max-width: 480px) {
    .afiliados-grid { grid-template-columns: 1fr !important; }
  }
</style>
