---
// src/pages/quienes-somos.astro
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout
  title="Quiénes somos | ANALAC"
  description="Conoce la labor gremial de ANALAC, asociación que representa a productores de leche y fortalece el sector lácteo colombiano."
>
  <!-- S1 Hero interior -->
  <section class="page-hero hero-dark fade-up">
    <div class="page-hero-bg"></div>
    <div class="container page-hero-content">
      <p class="overline overline-light">Sobre ANALAC</p>
      <h1 class="page-hero-title">
        Más de 65 años fortaleciendo la producción lechera colombiana
      </h1>
      <p class="page-hero-desc">
        Somos la voz institucional, el respaldo gremial y el motor de desarrollo de las familias campesinas e industrias dedicadas al sector lácteo en todo el territorio nacional.
      </p>
    </div>
  </section>

  <!-- S2 Bloque de Impacto -->
  <section class="section impact-section" style="background: var(--color-bg-page);">
    <div class="container">
      <div class="impact-grid fade-up">
        <div class="impact-stat">
          <div class="stat-number">65+</div>
          <div class="stat-label">Años de trayectoria</div>
        </div>
        <div class="impact-stat">
          <div class="stat-number">Miles</div>
          <div class="stat-label">Productores representados</div>
        </div>
        <div class="impact-stat">
          <div class="stat-number">100%</div>
          <div class="stat-label">Presencia nacional</div>
        </div>
        <div class="impact-stat">
          <div class="stat-number">365</div>
          <div class="stat-label">Días de gestión gremial</div>
        </div>
      </div>
    </div>
  </section>

  <!-- S3 Timeline -->
  <section class="section" style="padding-bottom: 120px;">
    <div class="container">
      <div class="section-header text-center fade-up" style="max-width: 600px; margin: 0 auto 80px;">
        <h2 class="h2">Nuestra Historia</h2>
      </div>
      <div class="timeline-premium fade-up">
        <div class="timeline-line"></div>
        <div class="timeline-item">
          <div class="timeline-dot"></div>
          <div class="timeline-content">
            <div class="timeline-year">1957</div>
            <div class="timeline-desc">Fundación de ANALAC en Bogotá, agrupando a los primeros líderes lecheros del país.</div>
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-dot"></div>
          <div class="timeline-content">
            <div class="timeline-year">1980</div>
            <div class="timeline-desc">Primera negociación nacional de precio de leche que formaliza las garantías del sector.</div>
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-dot"></div>
          <div class="timeline-content">
            <div class="timeline-year">2000</div>
            <div class="timeline-desc">Consolidación de comités regionales, ampliando la cobertura y representatividad gremial.</div>
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-dot"></div>
          <div class="timeline-content">
            <div class="timeline-year">2024</div>
            <div class="timeline-desc">Modernización gremial y digital, adaptando al productor a los retos globales del futuro.</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- S4 Misión y visión -->
  <section class="section" id="representacion" style="background: var(--color-bg-page);">
    <div class="container">
      <div class="mision-vision fade-up">
        <div class="mv-card premium-panel">
          <div class="mv-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
          </div>
          <h2 class="h2">Misión</h2>
          <p>Representar, defender y fortalecer los intereses del productor lechero colombiano ante el Gobierno, la industria y los organismos internacionales.</p>
        </div>
        <div class="mv-card premium-panel">
          <div class="mv-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/></svg>
          </div>
          <h2 class="h2">Visión</h2>
          <p>Ser el gremio líder en innovación, competitividad y sostenibilidad para el sector lácteo, garantizando el bienestar de las familias productoras.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- S5 Valores Institucionales -->
  <section class="section" style="padding: 120px 0;">
    <div class="container">
      <div class="section-header text-center fade-up" style="max-width: 600px; margin: 0 auto 64px;">
        <p class="overline">Nuestro ADN</p>
        <h2 class="h2">Valores Institucionales</h2>
      </div>
      <div class="valores-grid fade-up">
        <div class="valor-card">
          <div class="valor-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg></div>
          <h3 class="valor-title">Representación</h3>
        </div>
        <div class="valor-card">
          <div class="valor-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"></circle><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path><path d="M2 12h20"></path></svg></div>
          <h3 class="valor-title">Transparencia</h3>
        </div>
        <div class="valor-card">
          <div class="valor-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg></div>
          <h3 class="valor-title">Sostenibilidad</h3>
        </div>
        <div class="valor-card">
          <div class="valor-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"></path></svg></div>
          <h3 class="valor-title">Innovación</h3>
        </div>
        <div class="valor-card">
          <div class="valor-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg></div>
          <h3 class="valor-title">Desarrollo Rural</h3>
        </div>
        <div class="valor-card">
          <div class="valor-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg></div>
          <h3 class="valor-title">Cooperación</h3>
        </div>
      </div>
    </div>
  </section>

  <!-- S6 Equipo -->
  <section class="section" id="junta" style="background: var(--color-bg-page); padding: 120px 0;">
    <div class="container">
      <div class="section-header text-center fade-up" style="max-width: 600px; margin: 0 auto 64px;">
        <h2 class="h2">Nuestra Junta Directiva</h2>
        <p style="font-size: 19px; color: var(--color-text-sub); margin-top: 16px;">El liderazgo que guía las decisiones gremiales de nuestra asociación.</p>
      </div>
      <div class="equipo-grid fade-up">
        <div class="equipo-card-premium">
          <img src="/images/equipo/javier.png" alt="Javier Pérez" class="equipo-img" />
          <div class="equipo-info">
            <h3 class="equipo-nombre">Javier Pérez</h3>
            <p class="equipo-cargo">Presidente Ejecutivo</p>
          </div>
        </div>
        <div class="equipo-card-premium">
          <img src="/images/equipo/maria.png" alt="María López" class="equipo-img" />
          <div class="equipo-info">
            <h3 class="equipo-nombre">María López</h3>
            <p class="equipo-cargo">Directora Gremial</p>
          </div>
        </div>
        <div class="equipo-card-premium">
          <img src="/images/equipo/carlos.png" alt="Carlos Gómez" class="equipo-img" />
          <div class="equipo-info">
            <h3 class="equipo-nombre">Carlos Gómez</h3>
            <p class="equipo-cargo">Secretario General</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- S7 CTA Final -->
  <section class="cta-final section fade-up" style="background: var(--c-green-deep);">
    <div class="container text-center">
      <h2 class="h2 cta-title">Construyamos juntos el futuro del sector lácteo colombiano</h2>
      <div class="cta-buttons">
        <a href="https://portal.analac.com" class="btn btn--accent" style="padding: 12px 28px;">Afíliate</a>
        <a href="/contacto" class="btn btn--outline-white" style="padding: 12px 28px;">Contáctanos</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .page-hero.hero-dark {
    position: relative;
    padding: 200px 0 140px;
    min-height: 70vh;
    display: flex;
    align-items: center;
    background-color: #06150f;
  }
  .page-hero-bg {
    position: absolute;
    inset: 0;
    background-image: linear-gradient(rgba(6, 15, 7, 0.4), rgba(6, 15, 7, 0.8)), url('/images/hero-bg.jpg');
    background-size: cover;
    background-position: center;
    z-index: 0;
  }
  .page-hero-content {
    position: relative;
    z-index: 1;
    max-width: 900px;
    text-align: center;
    margin: 0 auto;
  }
  .page-hero-title {
    font-size: clamp(40px, 6vw, 64px);
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 24px;
    color: #ffffff;
    text-wrap: balance;
  }
  .page-hero-desc {
    font-size: 19px;
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.6;
    max-width: 700px;
    margin: 0 auto;
    text-wrap: balance;
  }
  .overline-light {
    color: var(--color-green-soft);
    border-color: rgba(255, 255, 255, 0.2);
  }

  /* Impact Block */
  .impact-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
    border-top: 1px solid rgba(0,0,0,0.05);
    border-bottom: 1px solid rgba(0,0,0,0.05);
    padding: 64px 0;
  }
  .impact-stat {
    text-align: center;
  }
  .stat-number {
    font-size: 56px;
    font-weight: 300;
    color: var(--color-green-dark);
    line-height: 1;
    margin-bottom: 12px;
    letter-spacing: -0.03em;
  }
  .stat-label {
    font-size: 15px;
    font-weight: 500;
    color: var(--color-text-sub);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Timeline Premium */
  .timeline-premium {
    position: relative;
    max-width: 800px;
    margin: 0 auto;
  }
  .timeline-line {
    position: absolute;
    left: 24px;
    top: 0;
    bottom: 0;
    width: 1px;
    background: rgba(0,0,0,0.1);
  }
  .timeline-item {
    position: relative;
    padding-left: 80px;
    padding-bottom: 64px;
  }
  .timeline-dot {
    position: absolute;
    left: 17px;
    top: 8px;
    width: 15px;
    height: 15px;
    border-radius: 50%;
    background: var(--color-bg-page);
    border: 2px solid var(--color-green-dark);
    box-shadow: 0 0 0 8px #ffffff;
    transition: all 0.3s ease;
  }
  .timeline-item:hover .timeline-dot {
    background: var(--color-green-dark);
    transform: scale(1.2);
    box-shadow: 0 0 0 8px #eaf3ea;
  }
  .timeline-year {
    font-size: 32px;
    font-weight: 300;
    color: var(--color-green-dark);
    margin-bottom: 12px;
    line-height: 1;
  }
  .timeline-desc {
    font-size: 19px;
    color: var(--color-text-main);
    line-height: 1.6;
  }

  /* Misión / Visión */
  .mision-vision {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
  }
  .premium-panel {
    background: #ffffff;
    padding: 64px;
    border-radius: 16px;
    border: 1px solid rgba(0,0,0,0.04);
    box-shadow: 0 4px 24px rgba(0,0,0,0.02);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s ease;
  }
  .premium-panel:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 48px rgba(0,0,0,0.06);
  }
  .mv-icon {
    width: 56px;
    height: 56px;
    border-radius: 12px;
    background: #eaf3ea;
    color: var(--color-green-dark);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 32px;
  }
  .premium-panel .h2 {
    margin-bottom: 20px;
    font-size: 32px;
    color: var(--color-green-dark);
  }
  .premium-panel p {
    font-size: 19px;
    line-height: 1.6;
    color: var(--color-text-main);
  }

  /* Valores Institucionales */
  .valores-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .valor-card {
    background: var(--color-bg-page);
    border: 1px solid rgba(0,0,0,0.05);
    border-radius: 12px;
    padding: 32px;
    display: flex;
    align-items: center;
    gap: 16px;
    transition: background 0.2s ease;
  }
  .valor-card:hover {
    background: #eaf3ea;
  }
  .valor-icon {
    color: var(--color-green-dark);
    flex-shrink: 0;
  }
  .valor-title {
    font-size: 18px;
    font-weight: 500;
    color: var(--color-green-dark);
    margin: 0;
  }

  /* Junta Directiva */
  .equipo-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }
  .equipo-card-premium {
    background: #ffffff;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid rgba(0,0,0,0.04);
    box-shadow: 0 4px 20px rgba(0,0,0,0.02);
  }
  .equipo-img {
    width: 100%;
    aspect-ratio: 3/4;
    object-fit: cover;
    object-position: top;
    display: block;
    background: #e8e4dc;
  }
  .equipo-info {
    padding: 24px;
    text-align: center;
  }
  .equipo-nombre {
    font-size: 20px;
    font-weight: 500;
    color: var(--color-green-dark);
    margin-bottom: 4px;
  }
  .equipo-cargo {
    font-size: 15px;
    color: var(--color-text-sub);
  }

  /* CTA Final */
  .cta-final {
    padding: 120px 0;
  }
  .cta-title {
    color: #ffffff;
    max-width: 700px;
    margin: 0 auto 48px;
    text-wrap: balance;
  }
  .cta-buttons {
    display: flex;
    gap: 16px;
    justify-content: center;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .impact-grid { grid-template-columns: 1fr 1fr; }
    .mision-vision { grid-template-columns: 1fr; }
    .valores-grid { grid-template-columns: 1fr; }
    .equipo-grid { grid-template-columns: 1fr; }
    .timeline-premium .timeline-item { padding-left: 48px; }
    .timeline-premium .timeline-line { left: 12px; }
    .timeline-premium .timeline-dot { left: 5px; }
    .cta-buttons { flex-direction: column; }
  }
</style>
