  <script>
    // Aliados y Colaboradores: pestañas clicables que muestran un grupo de logos a la vez.
    ;(function () {
      const tabs = document.querySelectorAll<HTMLButtonElement>('.aliados-tab')
      const panels = document.querySelectorAll<HTMLElement>('.aliados-panel')
      if (!tabs.length || !panels.length) return

      function setActive(index: number) {
        tabs.forEach(t => {
          const isActive = Number(t.dataset.index) === index
          t.classList.toggle('active', isActive)
          t.setAttribute('aria-selected', isActive ? 'true' : 'false')
        })
        panels.forEach(p => {
          const isActive = Number(p.dataset.index) === index
          p.classList.toggle('active', isActive)
          const track = p.querySelector<HTMLElement>('.marquee-track')
          if (track) track.style.animationPlayState = isActive ? 'running' : 'paused'
        })
      }

      tabs.forEach(tab => {
        tab.addEventListener('click', () => setActive(Number(tab.dataset.index)))
      })

      setActive(0)
    })()
  </script>

