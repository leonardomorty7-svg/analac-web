---
import PortalLayout from '../../layouts/PortalLayout.astro';
import { getActiveRevision, calculateProfileCompletion } from '../../services/portal/revisions';

export const prerender = false;

const user = Astro.locals.user;
const supabase = Astro.locals.supabase;

if (!user) {
  return Astro.redirect('/portal-aliados/iniciar-sesion');
}

// 1. Obtener organización y rol del usuario logueado
const { data: orgUser, error } = await supabase
  .from('organization_users')
  .select(`
    role,
    organization_id,
    organizations ( id, name, slug, status, verified )
  `)
  .eq('user_id', user.id)
  .single();

const hasOrg = !!orgUser && !!orgUser.organizations;
const role = orgUser?.role;
const org = hasOrg ? (Array.isArray(orgUser.organizations) ? orgUser.organizations[0] : orgUser.organizations) : null;

// 2. Obtener Revisión Activa
const activeRevision = await getActiveRevision(supabase, user.id);
const revisionStatus = activeRevision ? activeRevision.status : org?.status || 'draft';
const completeness = calculateProfileCompletion(activeRevision?.revision_data); 
const completenessText = completeness < 40 ? 'Incompleto' : (completeness < 70 ? 'En progreso' : (completeness < 90 ? 'Casi listo' : 'Listo para revisión'));
---

<PortalLayout 
  title="Dashboard" 
  userEmail={user.email} 
  orgName={org?.name || 'Sin Organización'} 
  role={role}
>
  
  {!hasOrg ? (
    <div class="card" style="text-align: center; padding: 64px 24px;">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color: #94a3b8; margin: 0 auto 16px;">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
      </svg>
      <h2 style="font-size: 20px; font-weight: 600; margin-bottom: 8px;">No tienes una organización asignada</h2>
      <p style="color: #64748b; max-width: 400px; margin: 0 auto;">
        Tu cuenta está activa, pero no se ha vinculado a ninguna empresa del ecosistema ANALAC. Por favor, contacta a soporte para solicitar el acceso a tu perfil.
      </p>
    </div>
  ) : (
    <div style="display: flex; flex-direction: column; gap: 24px;">
      
      <!-- Welcome Header -->
      <div style="display: flex; justify-content: space-between; align-items: flex-end;">
        <div>
          <p style="color: var(--p-text-sub); font-size: 14px; margin-bottom: 4px;">Bienvenido de nuevo,</p>
          <h2 style="font-size: 24px; font-weight: 700;">{org.name}</h2>
        </div>
        <div>
          <a href="/portal-aliados/directorio/editar" class="btn-primary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
            Editar Perfil
          </a>
        </div>
      </div>

      <!-- Stats Grid -->
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 24px;">
        
        <!-- Status Card -->
        <div class="card">
          <h3 style="font-size: 14px; color: var(--p-text-sub); font-weight: 500; margin-bottom: 16px;">Estado Editorial</h3>
          <div style="display: flex; align-items: center; gap: 12px;">
            {revisionStatus === 'published' ? (
              <>
                <div style="width: 12px; height: 12px; border-radius: 50%; background: #22c55e;"></div>
                <span style="font-size: 18px; font-weight: 600;">Publicado</span>
              </>
            ) : revisionStatus === 'pending_review' ? (
              <>
                <div style="width: 12px; height: 12px; border-radius: 50%; background: #eab308;"></div>
                <span style="font-size: 18px; font-weight: 600;">En Revisión</span>
              </>
            ) : revisionStatus === 'changes_requested' ? (
              <>
                <div style="width: 12px; height: 12px; border-radius: 50%; background: #f97316;"></div>
                <span style="font-size: 18px; font-weight: 600;">Ajustes Solicitados</span>
              </>
            ) : revisionStatus === 'rejected' ? (
              <>
                <div style="width: 12px; height: 12px; border-radius: 50%; background: #ef4444;"></div>
                <span style="font-size: 18px; font-weight: 600;">Rechazado</span>
              </>
            ) : (
              <>
                <div style="width: 12px; height: 12px; border-radius: 50%; background: #94a3b8;"></div>
                <span style="font-size: 18px; font-weight: 600;">Borrador</span>
              </>
            )}
          </div>
          {revisionStatus === 'published' && (
            <p style="margin-top: 12px; font-size: 13px; color: var(--p-text-sub);">
              Tu perfil es visible públicamente en el Directorio.
            </p>
          )}
        </div>

        <!-- Completeness Card -->
        <div class="card">
          <h3 style="font-size: 14px; color: var(--p-text-sub); font-weight: 500; margin-bottom: 16px;">Completitud del Perfil</h3>
          <div style="display: flex; align-items: baseline; gap: 8px; margin-bottom: 12px;">
            <span style="font-size: 28px; font-weight: 700;">{completeness}%</span>
            <span style="font-size: 14px; color: var(--p-text-sub);">{completenessText}</span>
          </div>
          
          <div style="width: 100%; height: 6px; background: #e2e8f0; border-radius: 3px; overflow: hidden;">
            <div style={`width: ${completeness}%; height: 100%; background: ${completeness > 80 ? '#22c55e' : '#eab308'}; border-radius: 3px;`}></div>
          </div>
        </div>
        
        <!-- Quick Links -->
        <div class="card">
          <h3 style="font-size: 14px; color: var(--p-text-sub); font-weight: 500; margin-bottom: 16px;">Acciones Rápidas</h3>
          <div style="display: flex; flex-direction: column; gap: 12px;">
            <a href="/portal-aliados/directorio/previsualizar" style="display: flex; align-items: center; gap: 8px; color: var(--p-text-main); text-decoration: none; font-size: 14px; font-weight: 500;">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
              Previsualizar perfil
            </a>
            {org.status === 'published' && (
              <a href={`/asociados-y-aliados/directorio/${org.slug}`} target="_blank" style="display: flex; align-items: center; gap: 8px; color: var(--p-primary); text-decoration: none; font-size: 14px; font-weight: 500;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                Ver en el directorio público
              </a>
            )}
          </div>
        </div>

      </div>
      
      <!-- Módulos de Red ANALAC -->
      <div style="margin-top: 16px;">
        <h3 style="font-size: 18px; font-weight: 600; margin-bottom: 24px;">Módulos de Red ANALAC</h3>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 24px;">
          
          <!-- Directorio -->
          <div class="card" style="border-top: 4px solid var(--c-green-deep);">
            <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 16px;">
              <h4 style="font-size: 16px; font-weight: 600;">Directorio</h4>
              <span class="status-badge" style="background: rgba(34, 197, 94, 0.1); color: #166534; padding: 4px 8px; border-radius: 4px; font-size: 12px; font-weight: 500;">Activo</span>
            </div>
            <p style="font-size: 13px; color: var(--p-text-sub); margin-bottom: 16px;">Gestiona tu perfil público, logo, categorías y certificaciones visibles para el sector.</p>
            <a href="/portal-aliados/directorio/editar" style="font-size: 14px; font-weight: 500; color: var(--c-green); text-decoration: none;">Gestionar perfil →</a>
          </div>

          <!-- Vitrina -->
          <div class="card" style="border-top: 4px solid #e2e8f0; opacity: 0.8;">
            <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 16px;">
              <h4 style="font-size: 16px; font-weight: 600;">Vitrina Comercial</h4>
              <span class="status-badge" style="background: #f1f5f9; color: #64748b; padding: 4px 8px; border-radius: 4px; font-size: 12px; font-weight: 500;">Próximamente</span>
            </div>
            <p style="font-size: 13px; color: var(--p-text-sub); margin-bottom: 16px;">Publica tus productos, servicios y precios. Habilitado según tu nivel de membresía.</p>
            <span style="font-size: 14px; font-weight: 500; color: #94a3b8;">Acceso restringido</span>
          </div>

          <!-- Comunidad -->
          <div class="card" style="border-top: 4px solid #e2e8f0; opacity: 0.8;">
            <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 16px;">
              <h4 style="font-size: 16px; font-weight: 600;">Comunidad Profesional</h4>
              <span class="status-badge" style="background: rgba(234, 179, 8, 0.1); color: #a16207; padding: 4px 8px; border-radius: 4px; font-size: 12px; font-weight: 500;">Requiere Afiliación</span>
            </div>
            <p style="font-size: 13px; color: var(--p-text-sub); margin-bottom: 16px;">Conecta con otros profesionales y comparte vacantes o noticias de tu organización.</p>
            <span style="font-size: 14px; font-weight: 500; color: #94a3b8;">Ver opciones de afiliación</span>
          </div>

          <!-- Observatorio -->
          <div class="card" style="border-top: 4px solid var(--c-green-deep);">
            <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 16px;">
              <h4 style="font-size: 16px; font-weight: 600;">Observatorio</h4>
              <span class="status-badge" style="background: rgba(34, 197, 94, 0.1); color: #166534; padding: 4px 8px; border-radius: 4px; font-size: 12px; font-weight: 500;">Nivel 1 Disponible</span>
            </div>
            <p style="font-size: 13px; color: var(--p-text-sub); margin-bottom: 16px;">Consulta información e indicadores generales del sector. Acceso avanzado según afiliación.</p>
            <a href="/informacion-sectorial" style="font-size: 14px; font-weight: 500; color: var(--c-green); text-decoration: none;">Explorar Observatorio →</a>
          </div>

        </div>
      </div>

    </div>
  )}

</PortalLayout>
