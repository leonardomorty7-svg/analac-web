---
import BaseLayout from '../../layouts/BaseLayout.astro';
export const prerender = false;
---

<BaseLayout title="Actualizar Contraseña | Portal de Aliados ANALAC">
  <main style="min-height: 100vh; display: flex; align-items: center; justify-content: center; background: #f8fafc; padding: 24px;">
    <div style="background: white; padding: 40px; border-radius: 16px; box-shadow: 0 10px 40px rgba(0,0,0,0.05); width: 100%; max-width: 400px; text-align: center;">
      
      <h1 style="font-size: 24px; font-weight: 800; color: var(--p-primary); margin-bottom: 8px;">
        Actualizar Contraseña
      </h1>
      <p style="color: #64748b; font-size: 15px; margin-bottom: 32px;">
        Ingresa tu nueva contraseña para el portal.
      </p>

      <div id="alert-container"></div>

      <form id="update-password-form" style="text-align: left; display: none;">
        <div style="margin-bottom: 20px;">
          <label for="password" style="display: block; font-size: 14px; font-weight: 600; margin-bottom: 8px; color: #334155;">
            Nueva Contraseña
          </label>
          <input 
            type="password" 
            id="password" 
            required 
            minlength="8"
            placeholder="Mínimo 8 caracteres"
            style="width: 100%; padding: 12px 16px; border: 1px solid #cbd5e1; border-radius: 8px; font-size: 15px; outline: none; transition: border-color 0.2s;"
          />
        </div>

        <button 
          type="submit" 
          id="submit-btn"
          style="width: 100%; background: var(--p-primary); color: white; border: none; padding: 14px; border-radius: 8px; font-size: 16px; font-weight: 600; cursor: pointer; transition: background 0.2s; margin-bottom: 16px;"
        >
          Actualizar Contraseña
        </button>
      </form>
      
      <div id="loading" style="color: #64748b;">
        Validando enlace seguro...
      </div>

    </div>
  </main>

  <script>
    import { getSupabaseBrowser } from '../../lib/supabase/browser';

    document.addEventListener('DOMContentLoaded', async () => {
      const supabase = getSupabaseBrowser();
      const form = document.getElementById('update-password-form') as HTMLFormElement;
      const alertContainer = document.getElementById('alert-container')!;
      const loading = document.getElementById('loading')!;
      const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

      // Supabase JS takes the #access_token from the URL automatically 
      // and establishes the session if it's a recovery flow.
      const { data: { session }, error: sessionError } = await supabase.auth.getSession();

      loading.style.display = 'none';

      if (sessionError || !session) {
        alertContainer.innerHTML = `
          <div style="background: #fee2e2; color: #b91c1c; padding: 12px; border-radius: 8px; margin-bottom: 24px; font-size: 14px; text-align: left;">
            El enlace es inválido o ha expirado. Por favor, solicita uno nuevo.
            <br/><br/>
            <a href="/portal-aliados/recuperar-password" style="color: #b91c1c; font-weight: bold; text-decoration: underline;">Solicitar nuevo enlace</a>
          </div>
        `;
        return;
      }

      // Si hay sesión, mostrar el form
      form.style.display = 'block';

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const passwordInput = document.getElementById('password') as HTMLInputElement;
        const newPassword = passwordInput.value;

        submitBtn.disabled = true;
        submitBtn.innerText = 'Actualizando...';

        const { error } = await supabase.auth.updateUser({
          password: newPassword
        });

        if (error) {
          submitBtn.disabled = false;
          submitBtn.innerText = 'Actualizar Contraseña';
          alertContainer.innerHTML = `
            <div style="background: #fee2e2; color: #b91c1c; padding: 12px; border-radius: 8px; margin-bottom: 24px; font-size: 14px; text-align: left;">
              ${error.message}
            </div>
          `;
        } else {
          form.style.display = 'none';
          alertContainer.innerHTML = `
            <div style="background: #dcfce3; color: #15803d; padding: 20px; border-radius: 8px; font-size: 15px;">
              <strong>¡Contraseña actualizada!</strong><br/><br/>
              Tu contraseña ha sido cambiada correctamente.
              <br/><br/>
              <a href="/portal-aliados" style="color: var(--p-primary); font-weight: 600; text-decoration: none;">Ir al Panel de Control</a>
            </div>
          `;
        }
      });
    });
  </script>
</BaseLayout>
