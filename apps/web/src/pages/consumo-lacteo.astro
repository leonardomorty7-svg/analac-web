---
// src/pages/consumo-lacteo.astro
import BaseLayout from '../layouts/BaseLayout.astro'
import CtaFinal from '../components/CtaFinal.astro'

const recipes = [
  { title: 'Changua bogotana', time: '20 min', difficulty: 'Fácil', ingredient: 'Leche entera', img: '/images/recetas/changua.jpg' },
  { title: 'Natillas navideñas', time: '45 min', difficulty: 'Media', ingredient: 'Leche + panela', img: '/images/recetas/natilla.jpg' },
  { title: 'Kumis casero', time: '24 h', difficulty: 'Fácil', ingredient: 'Leche entera', img: '/images/recetas/kumis.jpg' },
  { title: 'Arequipe artesanal', time: '2 h', difficulty: 'Media', ingredient: 'Leche + azúcar', img: '/images/recetas/arequipe.jpg' },
]
---

<BaseLayout
  title="Consumo lácteo, nutrición y bienestar | ANALAC"
  description="Consulta información, evidencia, recetas y recursos educativos sobre leche, productos lácteos, nutrición y bienestar."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": "Consumo lácteo, nutrición y bienestar",
      "description": "Consulta información, evidencia, recetas y recursos educativos sobre leche, productos lácteos, nutrición y bienestar.",
      "author": {
        "@type": "Organization",
        "name": "ANALAC"
      },
      "publisher": {
        "@type": "Organization",
        "name": "ANALAC"
      }
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "¿Cuántas porciones de lácteos se recomiendan al día?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Los especialistas recomiendan entre 2 y 3 porciones diarias (vaso de leche, trozo de queso o un yogurt) para asegurar el aporte necesario de calcio y proteínas."
          }
        },
        {
          "@type": "Question",
          "name": "¿La leche entera engorda?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No de forma aislada. Su consumo dentro de una dieta balanceada no está asociado al aumento de peso perjudicial."
          }
        }
      ]
    })} />
  </Fragment>
  <!-- 1. Hero institucional -->
  <section class="page-hero hero-dark fade-up" style="position: relative; padding: 200px 0 140px; min-height: 70vh; display: flex; align-items: center; background-color: var(--c-green-deep);">
    <div style="position: absolute; inset: 0; background-image: linear-gradient(rgba(10, 26, 12, 0.5), rgba(10, 26, 12, 0.85)), url('/images/hero-gastronomia.jpg'); background-size: cover; background-position: center; z-index: 0;"></div>
    <div class="container" style="position: relative; z-index: 1; max-width: 900px; text-align: center; margin: 0 auto;">
      <p class="overline" style="color: var(--c-green-light); border-color: rgba(255,255,255,0.2); display: inline-block; margin-bottom: 24px;">Nutrición y Bienestar</p>
      <h1 style="font-size: clamp(40px, 6vw, 64px); font-weight: 400; line-height: 1.1; letter-spacing: -0.02em; margin-bottom: 24px; color: #ffffff; text-wrap: balance;">
        Consumo lácteo, <span style="color: var(--c-green-light);">nutrición y bienestar</span>
      </h1>
      <p style="font-size: 19px; color: rgba(255, 255, 255, 0.8); line-height: 1.6; max-width: 700px; margin: 0 auto; text-wrap: balance;">
        Descubre cómo la leche y sus derivados impulsan el desarrollo integral en todas las etapas de la vida, apoyando al mismo tiempo a las familias productoras colombianas.
      </p>
      
      <div style="display: flex; flex-wrap: wrap; justify-content: center; gap: 16px; margin-top: 48px;">
        <a href="#nutricion" class="btn btn--outline-white" style="padding: 12px 24px; font-size: 16px;">Nutrición y salud</a>
        <a href="#bienestar" class="btn btn--outline-white" style="padding: 12px 24px; font-size: 16px;">Bienestar</a>
        <a href="#recetas" class="btn btn--outline-white" style="padding: 12px 24px; font-size: 16px;">Recetas</a>
        <a href="#campanas" class="btn btn--outline-white" style="padding: 12px 24px; font-size: 16px;">Campañas de promoción</a>
        <a href="#educativo" class="btn btn--outline-white" style="padding: 12px 24px; font-size: 16px;">Contenido educativo</a>
      </div>
    </div>
  </section>

  <!-- 2. Introducción al consumo de lácteos -->
  <section class="section" style="background: var(--color-bg-page); padding: 120px 0 64px;">
    <div class="container">
      <div class="fade-up" style="max-width: 760px; margin: 0 auto; text-align: center; display: flex; flex-direction: column; align-items: center;">
        <p class="overline" style="text-align: center;">Estrategia de Bienestar</p>
        <h2 class="h2" style="margin-bottom: 32px; text-align: center;">Fomentando la salud desde el origen</h2>
        <p style="font-size: 20px; color: var(--color-text-sub); line-height: 1.85; text-align: center; margin: 0;">
          ANALAC promueve el consumo consciente de leche 100% colombiana, un superalimento con una matriz nutricional única que garantiza la óptima absorción de sus componentes, convirtiéndola en un pilar insustituible para la salud pública y el bienestar humano.
        </p>
      </div>
    </div>
  </section>

  <!-- 3. Beneficios nutricionales -->
  <section id="nutricion" class="section" style="padding: 64px 0 120px;">
    <div class="container" style="max-width: 1200px; margin: 0 auto;">
      <div class="section-header text-center fade-up" style="max-width: 600px; margin: 0 auto 80px;">
        <h2 class="h2">Beneficios Nutricionales</h2>
        <p style="font-size: 19px; color: var(--color-text-sub); margin-top: 16px;">El poder de una nutrición balanceada respaldada por los productores nacionales.</p>
      </div>
      
      <div class="fade-up" style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 80px 120px;">
        <!-- Columna Izquierda, Fila 1 -->
        <div style="display: flex; flex-direction: column;">
          <div style="color: var(--color-green-dark); margin-bottom: 24px;">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
          </div>
          <h3 class="h3" style="margin-bottom: 16px; font-weight: 400;">Proteína de alta calidad</h3>
          <p style="color: var(--color-text-sub); font-size: 17px; line-height: 1.7;">Contribuye al mantenimiento y construcción muscular gracias a su aporte de aminoácidos esenciales.</p>
          <div style="margin-top: 40px; border-bottom: 1px solid rgba(0,0,0,0.06);"></div>
        </div>

        <!-- Columna Derecha, Fila 1 -->
        <div style="display: flex; flex-direction: column;">
          <div style="color: var(--color-green-dark); margin-bottom: 24px;">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 12h-4l-3 9L9 3l-3 9H2"></path></svg>
          </div>
          <h3 class="h3" style="margin-bottom: 16px; font-weight: 400;">Energía Sostenida</h3>
          <p style="color: var(--color-text-sub); font-size: 17px; line-height: 1.7;">Aporta nutrientes y carbohidratos que apoyan la vitalidad y el rendimiento físico dentro de una dieta equilibrada.</p>
          <div style="margin-top: 40px; border-bottom: 1px solid rgba(0,0,0,0.06);"></div>
        </div>
        
        <!-- Columna Izquierda, Fila 2 -->
        <div style="display: flex; flex-direction: column;">
          <div style="color: var(--color-green-dark); margin-bottom: 24px;">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
          </div>
          <h3 class="h3" style="margin-bottom: 16px; font-weight: 400;">Fortaleza Ósea</h3>
          <p style="color: var(--color-text-sub); font-size: 17px; line-height: 1.7;">El calcio, la proteína y la vitamina D contribuyen al mantenimiento de los huesos dentro de una alimentación equilibrada.</p>
        </div>

        <!-- Columna Derecha, Fila 2 -->
        <div style="display: flex; flex-direction: column;">
          <div style="color: var(--color-green-dark); margin-bottom: 24px;">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"></circle><path d="M12 8v8M8 12h8"></path></svg>
          </div>
          <h3 class="h3" style="margin-bottom: 16px; font-weight: 400;">Apoyo Inmunitario</h3>
          <p style="color: var(--color-text-sub); font-size: 17px; line-height: 1.7;">Contiene vitaminas A, D y Zinc, nutrientes que contribuyen al funcionamiento normal del sistema inmunitario.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. Vitaminas y minerales -->
  <section class="section" style="position: relative; padding: 160px 0; min-height: 760px; display: flex; align-items: center; color: white;">
    <div style="position: absolute; inset: 0; background-image: linear-gradient(rgba(10, 26, 12, 0.65), rgba(10, 26, 12, 0.65)), url('/images/micronutrientes_ciencia.png'); background-size: cover; background-position: center; background-repeat: no-repeat; background-attachment: fixed; z-index: 0;"></div>
    <div class="container" style="position: relative; z-index: 1;">
      <div class="grid-2 fade-up" style="display: grid; grid-template-columns: 1fr 1fr; gap: 64px;">
        <!-- Columna Izquierda: Contenido -->
        <div style="max-width: 600px;">
          <p class="overline" style="color: var(--c-green-light); border-color: rgba(255,255,255,0.2); display: inline-block; margin-bottom: 24px;">Ciencia y Evidencia</p>
          <h2 class="h2" style="color: white; margin-bottom: 24px;">Perfil de Micronutrientes</h2>
          <p style="font-size: 19px; color: rgba(255,255,255,0.8); margin-bottom: 32px; line-height: 1.6;">
            El consumo regular de lácteos aporta una sinergia perfecta de vitaminas y minerales. Los estudios demuestran que su matriz biológica asegura la máxima eficiencia en la absorción de cada nutriente.
          </p>
          <a href="/informacion-sectorial" style="display: inline-flex; align-items: center; gap: 8px; color: var(--c-green-light); font-weight: 500; font-size: 15px; margin-bottom: 64px; text-decoration: none;">
            Ver estadísticas de acopio en el Observatorio <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"></path></svg>
          </a>
          
          <div class="grid-2" style="display: grid; grid-template-columns: 1fr 1fr; gap: 40px 64px;">
            <div class="micro-indicator" style="display: flex; align-items: center; gap: 20px; cursor: pointer;">
              <div style="font-size: 32px; font-weight: 300; color: var(--c-green-light); min-width: 48px; text-align: right; letter-spacing: -0.02em;">CA</div>
              <div style="width: 1px; height: 36px; background: rgba(255,255,255,0.2);"></div>
              <div style="color: rgba(255,255,255,0.9); font-size: 15px; font-weight: 400;">Calcio Biodisponible</div>
            </div>
            
            <div class="micro-indicator" style="display: flex; align-items: center; gap: 20px; cursor: pointer;">
              <div style="font-size: 32px; font-weight: 300; color: var(--c-green-light); min-width: 48px; text-align: right; letter-spacing: -0.02em;">D3</div>
              <div style="width: 1px; height: 36px; background: rgba(255,255,255,0.2);"></div>
              <div style="color: rgba(255,255,255,0.9); font-size: 15px; font-weight: 400;">Vitamina D</div>
            </div>
            
            <div class="micro-indicator" style="display: flex; align-items: center; gap: 20px; cursor: pointer;">
              <div style="font-size: 32px; font-weight: 300; color: var(--c-green-light); min-width: 48px; text-align: right; letter-spacing: -0.02em;">B12</div>
              <div style="width: 1px; height: 36px; background: rgba(255,255,255,0.2);"></div>
              <div style="color: rgba(255,255,255,0.9); font-size: 15px; font-weight: 400;">Complejo B</div>
            </div>
            
            <div class="micro-indicator" style="display: flex; align-items: center; gap: 20px; cursor: pointer;">
              <div style="font-size: 32px; font-weight: 300; color: var(--c-green-light); min-width: 48px; text-align: right; letter-spacing: -0.02em;">P</div>
              <div style="width: 1px; height: 36px; background: rgba(255,255,255,0.2);"></div>
              <div style="color: rgba(255,255,255,0.9); font-size: 15px; font-weight: 400;">Fósforo Natural</div>
            </div>

            <div class="micro-indicator" style="display: flex; align-items: center; gap: 20px; cursor: pointer;">
              <div style="font-size: 32px; font-weight: 300; color: var(--c-green-light); min-width: 48px; text-align: right; letter-spacing: -0.02em;">ZN</div>
              <div style="width: 1px; height: 36px; background: rgba(255,255,255,0.2);"></div>
              <div style="color: rgba(255,255,255,0.9); font-size: 15px; font-weight: 400;">Zinc Esencial</div>
            </div>

            <div class="micro-indicator" style="display: flex; align-items: center; gap: 20px; cursor: pointer;">
              <div style="font-size: 32px; font-weight: 300; color: var(--c-green-light); min-width: 48px; text-align: right; letter-spacing: -0.02em;">K2</div>
              <div style="width: 1px; height: 36px; background: rgba(255,255,255,0.2);"></div>
              <div style="color: rgba(255,255,255,0.9); font-size: 15px; font-weight: 400;">Vitamina K2</div>
            </div>
          </div>
        </div>
        <!-- Columna Derecha: Vacía para que la imagen respire -->
        <div></div>
      </div>
    </div>
  </section>

  <!-- 5. Beneficios según etapa de vida -->
  <section id="bienestar" class="section" style="padding: 120px 0;">
    <div class="container">
      <div class="section-header text-center fade-up" style="max-width: 600px; margin: 0 auto 64px;">
        <h2 class="h2">Beneficios en cada etapa</h2>
        <p style="font-size: 19px; color: var(--color-text-sub); margin-top: 16px;">El consumo lácteo como acompañante nutricional para toda la vida.</p>
      </div>
      
      <div style="display: flex; flex-direction: column; gap: 48px;">
        <!-- Infancia -->
        <article class="premium-panel fade-up" style="display: grid; grid-template-columns: 1fr 1fr; gap: 0; padding: 0; overflow: hidden; align-items: stretch;">
          <div style="padding: 64px 48px; display: flex; flex-direction: column; justify-content: center;">
            <p class="overline" style="margin-bottom: 16px;">Desarrollo temprano</p>
            <h3 class="h2" style="margin-bottom: 16px;">Infancia</h3>
            <p style="color: var(--color-text-sub); font-size: 17px; line-height: 1.6;">Fundamentales para el desarrollo cognitivo, crecimiento óseo acelerado y prevención de deficiencias nutricionales tempranas.</p>
          </div>
          <div style="background-image: url('/images/etapa_infancia.png'); background-size: cover; background-position: center; min-height: 400px; border-radius: 24px; overflow: hidden;"></div>
        </article>
        
        <!-- Adultez (Invertido) -->
        <article class="premium-panel fade-up" style="display: grid; grid-template-columns: 1fr 1fr; gap: 0; padding: 0; overflow: hidden; align-items: stretch;">
          <div style="background-image: url('/images/etapa_adultez.png'); background-size: cover; background-position: center; min-height: 400px; border-radius: 24px; overflow: hidden;"></div>
          <div style="padding: 64px 48px; display: flex; flex-direction: column; justify-content: center;">
            <p class="overline" style="margin-bottom: 16px;">Energía y Mantenimiento</p>
            <h3 class="h2" style="margin-bottom: 16px;">Adultez</h3>
            <p style="color: var(--color-text-sub); font-size: 17px; line-height: 1.6;">Vitales para el mantenimiento de masa muscular, recuperación post-ejercicio y regulación metabólica constante.</p>
          </div>
        </article>
        
        <!-- Edad Mayor -->
        <article class="premium-panel fade-up" style="display: grid; grid-template-columns: 1fr 1fr; gap: 0; padding: 0; overflow: hidden; align-items: stretch;">
          <div style="padding: 64px 48px; display: flex; flex-direction: column; justify-content: center;">
            <p class="overline" style="margin-bottom: 16px;">Vitalidad e Independencia</p>
            <h3 class="h2" style="margin-bottom: 16px;">Edad Mayor</h3>
            <p style="color: var(--color-text-sub); font-size: 17px; line-height: 1.6;">Previene enfermedades degenerativas como la osteoporosis y la sarcopenia, garantizando independencia y vitalidad.</p>
          </div>
          <div style="background-image: url('/images/etapa_adulto_mayor.png'); background-size: cover; background-position: center; min-height: 400px; border-radius: 24px; overflow: hidden;"></div>
        </article>
      </div>
    </div>
  </section>

  <!-- 6. Mitos y realidades -->
  <section id="educativo" class="section" style="background: var(--color-bg-page); padding: 120px 0;">
    <div class="container">
      <div class="section-header text-center fade-up" style="max-width: 600px; margin: 0 auto 80px;">
        <p class="overline">Evidencia Científica</p>
        <h2 class="h2">Mitos y Realidades</h2>
      </div>
      <div class="grid-2 fade-up" style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 64px 80px;">
        <div class="premium-panel" style="border-left: 4px solid var(--c-accent); padding: 48px; display: flex; flex-direction: column; gap: 40px;">
          <div style="display: flex; flex-direction: column;">
            <div style="color: var(--color-text-main); margin-bottom: 12px;">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
            </div>
            <div style="font-weight: 600; font-size: 12px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-text-sub); margin-bottom: 12px;">Mito</div>
            <p style="font-size: 20px; color: var(--color-text-main); font-weight: 400; line-height: 1.4;">"Los adultos no necesitan consumir lácteos para estar saludables."</p>
          </div>
          <div style="border-top: 1px solid rgba(0,0,0,0.06);"></div>
          <div style="display: flex; flex-direction: column;">
            <div style="color: var(--c-green); margin-bottom: 12px;">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </div>
            <div style="font-weight: 600; font-size: 12px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-text-sub); margin-bottom: 12px;">Realidad</div>
            <p style="color: var(--color-text-sub); line-height: 1.6;">Los adultos necesitan calcio y vitamina D diariamente para reponer la pérdida ósea natural. Ningún otro alimento ofrece un balance tan completo como los lácteos.</p>
          </div>
        </div>
        <div class="premium-panel" style="border-left: 4px solid var(--c-accent); padding: 48px; display: flex; flex-direction: column; gap: 40px;">
          <div style="display: flex; flex-direction: column;">
            <div style="color: var(--color-text-main); margin-bottom: 12px;">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
            </div>
            <div style="font-weight: 600; font-size: 12px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-text-sub); margin-bottom: 12px;">Mito</div>
            <p style="font-size: 20px; color: var(--color-text-main); font-weight: 400; line-height: 1.4;">"Las alternativas vegetales son iguales o superiores a la leche de vaca."</p>
          </div>
          <div style="border-top: 1px solid rgba(0,0,0,0.06);"></div>
          <div style="display: flex; flex-direction: column;">
            <div style="color: var(--c-green); margin-bottom: 12px;">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </div>
            <div style="font-weight: 600; font-size: 12px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-text-sub); margin-bottom: 12px;">Realidad</div>
            <p style="color: var(--color-text-sub); line-height: 1.6;">A diferencia de las alternativas vegetales, la leche aporta de forma natural un perfil completo de aminoácidos esenciales y calcio con alta biodisponibilidad.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 7. Recetas destacadas -->
  <section id="recetas" class="section" style="padding: 120px 0;">
    <div class="container">
      <div class="section-header text-center fade-up" style="max-width: 600px; margin: 0 auto 64px;">
        <p class="overline">Gastronomía y Nutrición</p>
        <h2 class="h2">Versatilidad del Lácteo</h2>
        <p style="font-size: 19px; color: var(--color-text-sub); margin-top: 16px;">Incentivamos el consumo integrando de forma deliciosa y saludable los lácteos en la dieta diaria.</p>
      </div>
      
      <div class="grid-2 fade-up" style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 48px;">
        {recipes.map((r) => (
          <article class="recipe-card" style="background: var(--color-bg-white); border: 1px solid rgba(0,0,0,0.04); border-radius: var(--radius-card); overflow: hidden; box-shadow: 0 4px 24px rgba(0,0,0,0.02); display: flex; flex-direction: column; cursor: pointer;">
            <div style="height: 400px; overflow: hidden; position: relative; border-radius: 24px;">
              <img src={r.img} alt={r.title} style="width: 100%; height: 100%; object-fit: cover;" class="recipe-img" loading="lazy" />
              <div style="position: absolute; top: 20px; right: 20px;">
                <span class="tag tag--filled" style="background: rgba(255,255,255,0.95); color: var(--color-green-dark); font-weight: 500; font-size: 14px; padding: 8px 16px;">{r.time}</span>
              </div>
            </div>
            <div style="padding: 32px; display: flex; flex-direction: column; gap: 16px;">
              <h3 style="font-size: 28px; font-weight: 400; color: var(--color-text-main); line-height: 1.2; letter-spacing: -0.02em;">{r.title}</h3>
              <div style="display: flex; justify-content: space-between; align-items: center; padding-top: 16px; border-top: 1px solid rgba(0,0,0,0.05);">
                <span style="font-size: 15px; color: var(--color-text-sub);">{r.difficulty}</span>
                <span class="tag" style="font-size: 13px; font-weight: 500;">{r.ingredient}</span>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

