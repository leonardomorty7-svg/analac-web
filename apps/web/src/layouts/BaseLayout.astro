---
// src/layouts/BaseLayout.astro
// Layout base para todas las páginas de analac-web

import '../styles/global.css'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'

interface Props {
  title?: string
  description?: string
  ogImage?: string
  ogType?: 'website' | 'article'
  noIndex?: boolean
  customSchema?: string
  customCanonical?: string
}

const {
  title = 'ANALAC — Asociación Nacional de Productores de Leche de Colombia',
  description = 'Más de 68 años representando a los productores de leche de Colombia. Gremio, conocimiento y futuro para la cadena láctea nacional.',
  ogImage = '/og-analac.jpg',
  ogType = 'website',
  noIndex = false,
  customSchema,
  customCanonical
} = Astro.props

const canonicalURL = customCanonical ? new URL(customCanonical, Astro.site ?? 'https://analac.com') : new URL(Astro.url.pathname, Astro.site ?? 'https://analac.com')

const defaultSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "ANALAC",
  "url": "https://analac.com",
  "logo": "https://analac.com/logo.svg",
  "foundingDate": "1957",
  "description": "Asociación Nacional de Productores de Leche de Colombia",
  "address": {
    "@type": "PostalAddress",
    "addressCountry": "CO",
    "addressLocality": "Bogotá"
  }
});
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0f2211" />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="ANALAC" />
    <meta property="og:locale" content="es_CO" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />

    <!-- Structured data -->
    <script type="application/ld+json" set:html={customSchema || defaultSchema}></script>
    
    <!-- Analytics Init -->
    <script>
      import { initAnalytics, trackEvent } from '../lib/analytics';
      initAnalytics();

      // Rastrear la vista de página por defecto
      trackEvent('page_view', {
        page_path: window.location.pathname,
        page_title: document.title
      });
    </script>
    <slot name="head" />
  </head>
  <body>
    <Nav />
    <main id="main-content">
      <slot />
    </main>
    <Footer />

    <!-- Payment Floating Button -->
    <a 
      href="/zona-pagos" 
      class="payment-pill" 
      id="payment-pill"
      aria-label="Zona de Pagos"
    >
      <span>Zona de pagos PSE</span>
    </a>

    <!-- WhatsApp Floating Button -->
    <a 
      href="https://wa.me/573118995256" 
      class="wa-float" 
      target="_blank" 
      rel="noopener noreferrer"
      aria-label="Contactar por WhatsApp"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="currentColor">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.885-9.885 9.885m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/>
      </svg>
    </a>

    <!-- Scroll-triggered fade-up animations -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible')
              // Unobserve after triggering (fire-once)
              observer.unobserve(entry.target)
            }
          })
        },
        { threshold: 0.08, rootMargin: '0px 0px -40px 0px' },
      )

      document.querySelectorAll('.fade-up').forEach((el) => observer.observe(el))
    </script>

    <style is:global>
      .wa-float {
        position: fixed;
        bottom: 32px;
        right: 32px;
        width: 60px;
        height: 60px;
        background-color: #25D366;
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 8px 24px rgba(37, 211, 102, 0.3);
        z-index: 9999;
        transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.3s ease, background-color 0.3s ease;
      }
      .wa-float:hover {
        transform: scale(1.08) translateY(-4px);
        box-shadow: 0 12px 32px rgba(37, 211, 102, 0.5);
        background-color: #20BA5A;
      }
      .wa-float svg {
        width: 32px;
        height: 32px;
      }
      .payment-pill {
        position: fixed;
        bottom: 108px;
        right: 32px;
        background-color: #1b4f2c;
        color: white;
        border-radius: 100px;
        display: flex;
        align-items: center;
        padding: 16px 24px;
        font-size: 15px;
        font-weight: 600;
        text-decoration: none;
        box-shadow: 0 8px 24px rgba(6, 45, 23, 0.25);
        z-index: 9998;
        transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.3s ease, background-color 0.3s ease;
      }
      .payment-pill:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 32px rgba(6, 45, 23, 0.4);
        background-color: #041f10;
      }
      @media (max-width: 768px) {
        .wa-float {
          bottom: 24px;
          right: 24px;
          width: 56px;
          height: 56px;
        }
        .wa-float svg {
          width: 28px;
          height: 28px;
        }
        .payment-pill {
          bottom: 96px;
          right: 24px;
          padding: 12px 20px;
          font-size: 14px;
        }
      }
      @media (max-width: 480px) {
        .payment-pill {
          padding: 10px 16px;
          font-size: 13px;
        }
        .payment-pill span {
          white-space: nowrap;
        }
      }
    </style>
  </body>
</html>
