---
import '../styles/global.css';

interface Props {
  title: string;
  adminName: string;
  adminRole: string;
}

const { title, adminName, adminRole } = Astro.props;

const roleText = 
  adminRole === 'super_admin' ? 'Super Admin' : 
  adminRole === 'analac_admin' ? 'Administrador' : 'Moderador';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Panel Admin ANALAC</title>
    <!-- Noindex estricto -->
    <meta name="robots" content="noindex, nofollow" />
  </head>
  <body style="background: #f1f5f9; margin: 0; font-family: 'Inter', system-ui, sans-serif; display: flex; height: 100vh;">
    
    <!-- Sidebar Administrativo -->
    <aside style="width: 260px; background: #1e293b; color: white; display: flex; flex-direction: column;">
      <div style="padding: 24px; border-bottom: 1px solid rgba(255,255,255,0.1);">
        <h2 style="font-size: 20px; font-weight: 800; margin: 0; color: #38bdf8;">ANALAC Admin</h2>
        <span style="font-size: 12px; color: #94a3b8;">Directorio Inteligente</span>
      </div>
      
      <nav style="flex: 1; padding: 24px 16px; display: flex; flex-direction: column; gap: 8px;">
        <a href="/admin-analac" class="admin-nav-link">Dashboard</a>
        <a href="/admin-analac/directorio/pendientes" class="admin-nav-link active">Bandeja de Moderación</a>
        <a href="/admin-analac/directorio" class="admin-nav-link">Directorio Público</a>
        <a href="#" class="admin-nav-link">Categorías</a>
      </nav>

      <div style="padding: 24px; border-top: 1px solid rgba(255,255,255,0.1);">
        <div style="font-size: 14px; font-weight: 600;">{adminName}</div>
        <div style="font-size: 12px; color: #38bdf8; margin-bottom: 12px;">{roleText}</div>
        <form action="/api/auth/signout" method="POST">
          <button type="submit" style="background: transparent; border: 1px solid #475569; color: #cbd5e1; padding: 8px 16px; border-radius: 6px; font-size: 13px; cursor: pointer; width: 100%; transition: all 0.2s;">
            Cerrar Sesión
          </button>
        </form>
      </div>
    </aside>

    <!-- Contenido Principal -->
    <main style="flex: 1; overflow-y: auto;">
      <header style="background: white; padding: 20px 32px; border-bottom: 1px solid #e2e8f0; display: flex; justify-content: space-between; align-items: center;">
        <h1 style="font-size: 24px; font-weight: 700; color: #0f172a; margin: 0;">{title}</h1>
      </header>
      <div style="padding: 32px;">
        <slot />
      </div>
    </main>
  </body>
</html>

<style>
  .admin-nav-link {
    color: #cbd5e1; 
    text-decoration: none; 
    padding: 10px 16px; 
    border-radius: 6px; 
    font-size: 14px; 
    font-weight: 500; 
    transition: background 0.2s, color 0.2s;
  }
  .admin-nav-link:hover {
    background: rgba(255,255,255,0.05);
    color: white;
  }
  .admin-nav-link.active {
    background: rgba(56, 189, 248, 0.1);
    color: #38bdf8;
  }
</style>
