# Variables de Entorno - Entorno Local
# Copia este archivo como .env y reemplaza con los valores de tu proyecto de Supabase

# URL base del proyecto en Supabase (ej: https://xyz.supabase.co)
PUBLIC_SUPABASE_URL=tu_supabase_url_aqui

# Clave anon (Pública y segura para el cliente, respeta RLS)
PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_aqui

# Clave de Servicio (Privada, NUNCA usar en el cliente. Otorga privilegios de admin)
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui

# Nombres de Buckets (Storage)
PUBLIC_MEDIA_BUCKET=public-media
PRIVATE_DOCS_BUCKET=private-docs
