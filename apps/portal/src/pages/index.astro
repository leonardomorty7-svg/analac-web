---
import PortalLayout from '../layouts/PortalLayout.astro'
---

<PortalLayout title="Dashboard — Portal ANALAC">
  <div class="flex min-h-screen">
    <!-- Sidebar -->
    <aside class="portal-sidebar">
      <div class="flex h-16 items-center gap-3 border-b border-white/10 px-6">
        <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-white/20">
          <span class="text-xs font-bold text-white">A</span>
        </div>
        <span class="font-display font-semibold text-white">Portal ANALAC</span>
      </div>
      <nav class="flex-1 space-y-1 overflow-y-auto p-4">
        <a href="/dashboard" class="nav-link active">Dashboard</a>
        <a href="/perfil" class="nav-link">Mi Perfil</a>
        <a href="/pagos" class="nav-link">Cuotas y Pagos</a>
        <a href="/documentos" class="nav-link">Documentos</a>
        <a href="/directorio" class="nav-link">Directorio</a>
        <a href="/noticias" class="nav-link">Noticias</a>
      </nav>
      <div class="border-t border-white/10 p-4">
        <a href="/api/auth/signout" class="nav-link text-white/60">Cerrar sesión</a>
      </div>
    </aside>

    <!-- Main content -->
    <main class="portal-content">
      <h1 class="text-2xl font-bold text-gray-900">Dashboard</h1>
      <p class="mt-1 text-gray-600">Bienvenido al portal de afiliados de ANALAC</p>

      <!-- Stats Cards -->
      <div class="mt-8 grid gap-6 sm:grid-cols-2 xl:grid-cols-4">
        {[
          { label: 'Estado', value: 'Activo', color: 'text-green-600 bg-green-50' },
          { label: 'Cuotas al día', value: 'Sí', color: 'text-green-600 bg-green-50' },
          { label: 'Producción', value: '-- L/día', color: 'text-blue-600 bg-blue-50' },
          { label: 'Afiliado desde', value: '--', color: 'text-gray-600 bg-gray-50' },
        ].map((card) => (
          <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
            <p class="text-sm font-medium text-gray-500">{card.label}</p>
            <p class={`mt-2 text-2xl font-bold ${card.color} rounded-lg px-3 py-1 w-fit`}>
              {card.value}
            </p>
          </div>
        ))}
      </div>
    </main>
  </div>
</PortalLayout>
