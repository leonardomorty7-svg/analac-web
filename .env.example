# ============================================
# ANALAC Web — Variables de Entorno
# ============================================
# Copia este archivo como .env y rellena los valores
# NUNCA commitees el archivo .env real

# ── Base de Datos ──────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/analac"

# ── Clerk (Autenticación) ──────────────────
CLERK_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_WEBHOOK_SECRET="whsec_..."

# ── Wompi (Pagos) ──────────────────────────
WOMPI_PUBLIC_KEY="pub_test_..."
WOMPI_PRIVATE_KEY="prv_test_..."
WOMPI_EVENTS_SECRET="test_events_..."
WOMPI_SANDBOX=true

# ── Payload CMS ───────────────────────────
PAYLOAD_SECRET="change-me-super-secret-payload-key"
PAYLOAD_PUBLIC_SERVER_URL="http://localhost:3001"

# ── API ────────────────────────────────────
API_URL="http://localhost:4000"
API_SECRET_KEY="change-me-api-secret"

# ── Apps ───────────────────────────────────
PUBLIC_SITE_URL="http://localhost:4321"
PUBLIC_PORTAL_URL="http://localhost:4322"
PUBLIC_CMS_URL="http://localhost:3001"

# ── Email (Resend) ─────────────────────────
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@analac.com"

# ── S3 / Storage ──────────────────────────
S3_BUCKET="analac-media"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_ENDPOINT=""

# ── Misc ───────────────────────────────────
NODE_ENV="development"
